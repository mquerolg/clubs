{% extends 'ontology_base.html.twig' %}

{% block title %}Llibres de l'Ontologia{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fa fa-book"></i> Llibres de l'Ontologia</h3>
                    <div class="card-tools">
                        <a href="{{ path('admin') }}" class="btn btn-sm btn-secondary">
                            <i class="fa fa-arrow-left"></i> Tornar
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <form method="get" action="{{ path('admin_ontology_books_index') }}" class="form-inline mb-3">
                        <div class="form-group mr-2">
                            <input type="text" 
                                   name="query" 
                                   value="{{ searchQuery }}" 
                                   class="form-control" 
                                   placeholder="Cercar per títol, autor o gènere..."
                                   style="width: 300px;">
                        </div>
                        
                        <div class="form-group mr-2">
                            <select name="sort" class="form-control">
                                <option value="title" {% if sortField == 'title' %}selected{% endif %}>Ordenar per Títol</option>
                                <option value="authorName" {% if sortField == 'authorName' %}selected{% endif %}>Ordenar per Autor</option>
                                <option value="genre" {% if sortField == 'genre' %}selected{% endif %}>Ordenar per Gènere</option>
                                <option value="datePublished" {% if sortField == 'datePublished' %}selected{% endif %}>Ordenar per Data</option>
                            </select>
                        </div>
                        
                        <div class="form-group mr-2">
                            <select name="order" class="form-control">
                                <option value="ASC" {% if sortDirection == 'ASC' %}selected{% endif %}>Ascendent</option>
                                <option value="DESC" {% if sortDirection == 'DESC' %}selected{% endif %}>Descendent</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-primary mr-2">
                            <i class="fa fa-search"></i> Cercar
                        </button>
                        
                        {% if searchQuery %}
                            <a href="{{ path('admin_ontology_books_index') }}" class="btn btn-secondary">
                                <i class="fa fa-times"></i> Netejar
                            </a>
                        {% endif %}
                    </form>

                    <p class="text-muted"><strong>{{ totalBooks }}</strong> llibres trobats</p>

                    {% if books|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 40%;">Títol</th>
                                        <th style="width: 25%;">Autor</th>
                                        <th style="width: 20%;">Gènere</th>
                                        <th style="width: 10%;">Data</th>
                                        <th style="width: 5%;" class="text-center">Accions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for book in books %}
                                        <tr>
                                            <td><strong>{{ book.title }}</strong></td>
                                            <td>{{ book.authorName }}</td>
                                            <td><span class="badge badge-secondary">{{ book.genre }}</span></td>
                                            <td>{{ book.datePublished }}</td>
                                            <td class="text-center">
                                                <a href="{{ path('admin_ontology_books_detail', {bookId: book.id}) }}" 
                                                   class="btn btn-sm btn-info"
                                                   title="Veure detalls">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {% if totalPages > 1 %}
                            <nav aria-label="Paginació">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('admin_ontology_books_index', {
                                            page: currentPage - 1,
                                            query: searchQuery,
                                            sort: sortField,
                                            order: sortDirection
                                        }) }}">Anterior</a>
                                    </li>

                                    {% for p in 1..totalPages %}
                                        {% if p == currentPage or (p >= currentPage - 2 and p <= currentPage + 2) or p == 1 or p == totalPages %}
                                            <li class="page-item {% if p == currentPage %}active{% endif %}">
                                                <a class="page-link" href="{{ path('admin_ontology_books_index', {
                                                    page: p,
                                                    query: searchQuery,
                                                    sort: sortField,
                                                    order: sortDirection
                                                }) }}">{{ p }}</a>
                                            </li>
                                        {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        {% endif %}
                                    {% endfor %}

                                    <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('admin_ontology_books_index', {
                                            page: currentPage + 1,
                                            query: searchQuery,
                                            sort: sortField,
                                            order: sortDirection
                                        }) }}">Següent</a>
                                    </li>
                                </ul>
                            </nav>
                            <p class="text-center text-muted">
                                <small>Pàgina {{ currentPage }} de {{ totalPages }}</small>
                            </p>
                        {% endif %}
                    {% else %}
                        <div class="alert alert-info">
                            <i class="fa fa-info-circle"></i>
                            {% if searchQuery %}
                                No s'han trobat llibres que coincideixin amb "<strong>{{ searchQuery }}</strong>"
                            {% else %}
                                No hi ha llibres disponibles a l'ontologia
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
