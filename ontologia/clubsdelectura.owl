        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1253"/>
        <rdfs:comment>The act of transferring money from one place to another place. This may occur electronically or physically.</rdfs:comment>
        <rdfs:label>MoneyTransfer</rdfs:label>
    </Class>
    


    <!-- http://schema.org/MortgageLoan -->

