        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2543"/>
    </Class>
    


    <!-- https://schema.org/NailSalon -->

    <Class rdf:about="https://schema.org/NailSalon">
        <rdfs:subClassOf rdf:resource="https://schema.org/HealthAndBeautyBusiness"/>
        <rdfs:comment>A nail salon.</rdfs:comment>
        <rdfs:label>NailSalon</rdfs:label>
    </Class>
    


    <!-- https://schema.org/Nerve -->

    <Class rdf:about="https://schema.org/Nerve">
        <rdfs:subClassOf rdf:resource="https://schema.org/AnatomicalStructure"/>
        <rdfs:comment>A common pathway for the electrochemical nerve impulses that are transmitted along each of the axons.</rdfs:comment>
        <rdfs:label>Nerve</rdfs:label>
        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
    </Class>
    


    <!-- https://schema.org/NewsArticle -->

    <Class rdf:about="https://schema.org/NewsArticle">
        <rdfs:subClassOf rdf:resource="https://schema.org/Article"/>
        <rdfs:comment>A NewsArticle is an article whose content reports news, or provides background context and supporting materials for understanding the news.&lt;br/&gt;&lt;br/&gt;

A more detailed overview of &lt;a href=&quot;/docs/news.html&quot;&gt;schema.org News markup&lt;/a&gt; is also available.</rdfs:comment>
        <rdfs:label>NewsArticle</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_rNews"/>
        <schema:source rdf:resource="https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP-draws"/>
    </Class>
    


    <!-- https://schema.org/NewsMediaOrganization -->

    <Class rdf:about="https://schema.org/NewsMediaOrganization">
        <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment>A News/Media organization such as a newspaper or TV station.</rdfs:comment>
        <rdfs:label>NewsMediaOrganization</rdfs:label>
        <schema:category>issue-1525</schema:category>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1525"/>
        <schema:source rdf:resource="https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP"/>
    </Class>
    


    <!-- https://schema.org/Newspaper -->

    <Class rdf:about="https://schema.org/Newspaper">
        <rdfs:subClassOf rdf:resource="https://schema.org/Periodical"/>
