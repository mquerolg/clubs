        <schema:domainIncludes rdf:resource="https://schema.org/NutritionInformation"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Mass"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/suggestedGender">
        <rdfs:comment>The gender of the person or audience.</rdfs:comment>
