    <Class rdf:about="https://schema.org/NonprofitType">
        <rdfs:subClassOf rdf:resource="https://schema.org/Enumeration"/>
        <rdfs:comment>NonprofitType enumerates several kinds of official non-profit types of which a non-profit organization can be.</rdfs:comment>
