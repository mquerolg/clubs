        <schema:category>issue-2288</schema:category>
        <schema:domainIncludes rdf:resource="https://schema.org/MerchantReturnPolicy"/>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/MerchantReturnEnumeration"/>
