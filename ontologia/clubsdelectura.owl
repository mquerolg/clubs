        <schema1:category>issue-1576</schema1:category>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1589"/>
        <rdfs:comment>An &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/EmployerReview&quot;&gt;EmployerReview&lt;/a&gt; is a review of an &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Organization&quot;&gt;Organization&lt;/a&gt; regarding its role as an employer, written by a current or former employee of that organization.</rdfs:comment>
        <rdfs:label>EmployerReview</rdfs:label>
    </Class>
    


