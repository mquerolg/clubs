        <schema1:domainIncludes rdf:resource="http://schema.org/Offer"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/OpeningHoursSpecification"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Permit"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/PriceSpecification"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Date"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/DateTime"/>
        <schema1:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms"/>
