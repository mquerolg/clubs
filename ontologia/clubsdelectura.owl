        <rdfs:label>sportsActivityLocation</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/location"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/sportsEvent -->

    <AnnotationProperty rdf:about="http://schema.org/sportsEvent">
        <schema1:domainIncludes rdf:resource="http://schema.org/ExerciseAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/SportsEvent"/>
