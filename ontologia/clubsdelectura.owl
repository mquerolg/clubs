        <rdfs:label>sportsTeam</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/participant"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/step -->

    <AnnotationProperty rdf:about="http://schema.org/step">
        <schema1:domainIncludes rdf:resource="http://schema.org/HowTo"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/HowToSection"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/HowToStep"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>A single step item (as HowToStep, text, document, video, etc.) or a HowToSection.</rdfs:comment>
        <rdfs:label>step</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/suggestedAnswer -->

    <AnnotationProperty rdf:about="http://schema.org/suggestedAnswer">
        <schema1:domainIncludes rdf:resource="http://schema.org/Question"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Answer"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/ItemList"/>
        <rdfs:comment>An answer (possibly one of several, possibly incorrect) to a Question, e.g. on a Question/Answer site.</rdfs:comment>
        <rdfs:label>suggestedAnswer</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/supersededBy -->

    <AnnotationProperty rdf:about="http://schema.org/supersededBy">
        <schema1:domainIncludes rdf:resource="http://schema.org/Class"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Enumeration"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Property"/>
        <schema1:isPartOf rdf:resource="http://meta.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Class"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Enumeration"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Property"/>
        <rdfs:comment>Relates a term (i.e. a property, class or enumeration) to one that supersedes it.</rdfs:comment>
        <rdfs:label>supersededBy</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/supply -->

    <AnnotationProperty rdf:about="http://schema.org/supply">
        <schema1:domainIncludes rdf:resource="http://schema.org/HowTo"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/HowToDirection"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/HowToSupply"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>A sub-property of instrument. A supply consumed when performing instructions or a direction.</rdfs:comment>
        <rdfs:label>supply</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/instrument"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/surface -->

    <AnnotationProperty rdf:about="http://schema.org/surface">
        <schema1:domainIncludes rdf:resource="http://schema.org/VisualArtwork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:supersededBy rdf:resource="http://schema.org/artworkSurface"/>
        <rdfs:comment>A material used as a surface in some artwork, e.g. Canvas, Paper, Wood, Board, etc.</rdfs:comment>
        <rdfs:label>surface</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/material"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/targetCollection -->

    <AnnotationProperty rdf:about="http://schema.org/targetCollection">
        <schema1:domainIncludes rdf:resource="http://schema.org/UpdateAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Thing"/>
        <rdfs:comment>A sub property of object. The collection target of the action.</rdfs:comment>
        <rdfs:label>targetCollection</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/object"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/taxID -->

    <AnnotationProperty rdf:about="http://schema.org/taxID">
        <schema1:domainIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Person"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms"/>
