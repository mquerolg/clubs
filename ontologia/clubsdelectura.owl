        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/ownedThrough">
        <rdfs:comment>The date and time of giving up ownership on the product.</rdfs:comment>
