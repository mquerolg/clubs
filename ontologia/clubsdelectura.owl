        <rdfs:subPropertyOf rdf:resource="http://schema.org/result"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/resultReview -->

    <AnnotationProperty rdf:about="http://schema.org/resultReview">
        <schema1:domainIncludes rdf:resource="http://schema.org/ReviewAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Review"/>
