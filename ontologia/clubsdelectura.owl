        <schema1:domainIncludes rdf:resource="http://schema.org/TVSeries"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/VideoGameSeries"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CreativeWorkSeason"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:supersededBy rdf:resource="http://schema.org/containsSeason"/>
        <rdfs:comment>A season in a media series.</rdfs:comment>
        <rdfs:label>season</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/hasPart"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/seasonNumber -->

