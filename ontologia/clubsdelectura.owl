    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/requiresSubscription">
        <rdfs:comment>Indicates if use of the media require a subscription  (either paid or free). Allowed values are &lt;code&gt;true&lt;/code&gt; or &lt;code&gt;false&lt;/code&gt; (note that an earlier version had &apos;yes&apos;, &apos;no&apos;).</rdfs:comment>
        <rdfs:label>requiresSubscription</rdfs:label>
        <schema:category>issue-1741</schema:category>
