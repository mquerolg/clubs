        <rdfs:comment>Information about disease prevention.</rdfs:comment>
        <rdfs:label>diseasePreventionInfo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/diseaseSpreadStatistics">
        <schema1:category>issue-2490</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/SpecialAnnouncement"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Dataset"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Observation"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/WebContent"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2490"/>
        <rdfs:comment>Statistical information about the spread of a disease, either as &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/WebContent&quot;&gt;WebContent&lt;/a&gt;, or
  described directly as a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Dataset&quot;&gt;Dataset&lt;/a&gt;, or the specific &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Observation&quot;&gt;Observation&lt;/a&gt;s in the dataset. When a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/WebContent&quot;&gt;WebContent&lt;/a&gt; URL is
  provided, the page indicated might also contain more such markup.</rdfs:comment>
        <rdfs:label>diseaseSpreadStatistics</rdfs:label>
    </rdf:Description>
