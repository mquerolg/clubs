        <rdfs:comment>Event type: Exhibition event, e.g. at a museum, library, archive, tradeshow, ...</rdfs:comment>
        <rdfs:label>ExhibitionEvent</rdfs:label>
    </Class>
    


    <!-- https://schema.org/FAQPage -->

    <Class rdf:about="https://schema.org/FAQPage">
        <rdfs:subClassOf rdf:resource="https://schema.org/WebPage"/>
        <rdfs:comment>A &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/FAQPage&quot;&gt;FAQPage&lt;/a&gt; is a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/WebPage&quot;&gt;WebPage&lt;/a&gt; presenting one or more &quot;&lt;a href=&quot;https://en.wikipedia.org/wiki/FAQ&quot;&gt;Frequently asked questions&lt;/a&gt;&quot; (see also &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/QAPage&quot;&gt;QAPage&lt;/a&gt;).</rdfs:comment>
        <rdfs:label>FAQPage</rdfs:label>
        <schema:category>issue-1723</schema:category>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1723"/>
    </Class>
    


    <!-- https://schema.org/FMRadioChannel -->

    <Class rdf:about="https://schema.org/FMRadioChannel">
        <rdfs:subClassOf rdf:resource="https://schema.org/RadioChannel"/>
        <rdfs:comment>A radio channel that uses FM.</rdfs:comment>
        <rdfs:label>FMRadioChannel</rdfs:label>
        <schema:category>issue-1004</schema:category>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1004"/>
    </Class>
    


    <!-- https://schema.org/FastFoodRestaurant -->

    <Class rdf:about="https://schema.org/FastFoodRestaurant">
