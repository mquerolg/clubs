        <rdfs:label>MusicAlbumProductionType</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#MBZ"/>
    </Class>
    


    <!-- https://schema.org/MusicAlbumReleaseType -->

    <Class rdf:about="https://schema.org/MusicAlbumReleaseType">
        <rdfs:subClassOf rdf:resource="https://schema.org/Enumeration"/>
