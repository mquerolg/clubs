        <schema:rangeIncludes rdf:resource="https://schema.org/BusStation"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/BusStop"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalGate">
        <rdfs:comment>Identifier of the flight&apos;s arrival gate.</rdfs:comment>
        <rdfs:label>arrivalGate</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Flight"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalPlatform">
        <rdfs:comment>The platform where the train arrives.</rdfs:comment>
        <rdfs:label>arrivalPlatform</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/TrainTrip"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalStation">
        <rdfs:comment>The station where the train trip ends.</rdfs:comment>
        <rdfs:label>arrivalStation</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/TrainTrip"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/TrainStation"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalTerminal">
        <rdfs:comment>Identifier of the flight&apos;s arrival terminal.</rdfs:comment>
        <rdfs:label>arrivalTerminal</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Flight"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalTime">
        <rdfs:comment>The expected arrival time.</rdfs:comment>
        <rdfs:label>arrivalTime</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Trip"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/DateTime"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Time"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/artEdition">
        <rdfs:comment>The number of copies when multiple copies of a piece of artwork are produced - e.g. for a limited edition of 20 prints, &apos;artEdition&apos; refers to the total number of copies (in this example &quot;20&quot;).</rdfs:comment>
        <rdfs:label>artEdition</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/VisualArtwork"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Integer"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arterialBranch">
        <rdfs:comment>The branches that comprise the arterial structure.</rdfs:comment>
        <rdfs:label>arterialBranch</rdfs:label>
