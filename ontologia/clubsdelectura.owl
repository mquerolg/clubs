        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/WebContent"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2490"/>
        <rdfs:comment>Information about school closures.</rdfs:comment>
        <rdfs:label>schoolClosuresInfo</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/screenCount">
