    <!-- http://schema.org/contentLocation -->

    <AnnotationProperty rdf:about="http://schema.org/contentLocation">
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Place"/>
        <rdfs:comment>The location depicted or described in the content. For example, the location in a photograph or painting.</rdfs:comment>
