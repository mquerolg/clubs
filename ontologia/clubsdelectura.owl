    <Class rdf:about="https://schema.org/ExchangeRateSpecification">
        <rdfs:subClassOf rdf:resource="https://schema.org/StructuredValue"/>
        <rdfs:comment>A structured value representing exchange rate.</rdfs:comment>
        <rdfs:label>ExchangeRateSpecification</rdfs:label>
