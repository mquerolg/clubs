        <schema:domainIncludes rdf:resource="https://schema.org/Person"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Person"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/cholesterolContent">
        <rdfs:comment>The number of milligrams of cholesterol.</rdfs:comment>
