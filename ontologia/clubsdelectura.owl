    <!-- http://www.semanticweb.org/clubslectura#Exemplar -->

    <Class rdf:about="http://www.semanticweb.org/clubslectura#Exemplar">
        <rdfs:subClassOf rdf:resource="http://schema.org/Book"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#teAutor"/>
                <allValuesFrom rdf:resource="http://www.semanticweb.org/clubslectura#Persona"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#ubicatA"/>
                <allValuesFrom rdf:resource="http://www.semanticweb.org/clubslectura#Biblioteca"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#teAutor"/>
                <minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</minCardinality>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#teISBN"/>
                <cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</cardinality>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/clubslectura#Llibre -->

    <Class rdf:about="http://www.semanticweb.org/clubslectura#Llibre">
        <rdfs:subClassOf rdf:resource="http://schema.org/Book"/>
    </Class>
    


    <!-- http://www.semanticweb.org/clubslectura#LlibreRecomanat -->

    <Class rdf:about="http://www.semanticweb.org/clubslectura#LlibreRecomanat">
