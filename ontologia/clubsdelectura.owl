    <!-- https://schema.org/ShippingRateSettings -->

    <Class rdf:about="https://schema.org/ShippingRateSettings">
        <rdfs:subClassOf rdf:resource="https://schema.org/StructuredValue"/>
        <rdfs:comment>A ShippingRateSettings represents re-usable pieces of shipping information. It is designed for publication on an URL that may be referenced via the &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/shippingSettingsLink&quot;&gt;shippingSettingsLink&lt;/a&gt; property of an &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/OfferShippingDetails&quot;&gt;OfferShippingDetails&lt;/a&gt;. Several occurrences can be published, distinguished and matched (i.e. identified/referenced) by their different values for &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/shippingLabel&quot;&gt;shippingLabel&lt;/a&gt;.</rdfs:comment>
        <rdfs:label>ShippingRateSettings</rdfs:label>
        <schema:category>issue-2506</schema:category>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2506"/>
    </Class>
    


