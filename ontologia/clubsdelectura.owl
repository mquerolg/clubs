    </Class>
    


    <!-- https://schema.org/Number -->

    <Class rdf:about="https://schema.org/Number"/>
    


    <!-- https://schema.org/Nursing -->

    <Class rdf:about="https://schema.org/Nursing">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalBusiness"/>
    </Class>
    


    <!-- https://schema.org/NutritionInformation -->

    <Class rdf:about="https://schema.org/NutritionInformation">
