        <schema1:rangeIncludes rdf:resource="http://schema.org/DoseSchedule"/>
        <rdfs:comment>A dosing schedule for the drug for a given population, either observed, recommended, or maximum dose based on the type used.</rdfs:comment>
        <rdfs:label>doseSchedule</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/doseUnit">
        <schema1:domainIncludes rdf:resource="http://schema.org/DoseSchedule"/>
