        <schema1:author rdf:resource="http://example.org/author95"/>
        <schema1:datePublished>2012-05-15</schema1:datePublished>
        <schema1:isbn>9781137008206</schema1:isbn>
        <schema1:name>Stateless Nations</schema1:name>
        <schema1:authorName>J. Friend</schema1:authorName>
        <schema1:description>Why are regional nationalisms threatening the old nations? This book explores examples such as why Scotland might become independent, why Wales wants more autonomy, and why Catalonia emphasizes its distinctive language and institutions but does not want separation from Spain. Stateless Nations explores the historical roots of modern nationalisms.</schema1:description>
        <schema1:genre>Political Science</schema1:genre>
