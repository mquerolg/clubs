        <rdfs:comment>A tattoo parlor.</rdfs:comment>
        <rdfs:label>TattooParlor</rdfs:label>
    </Class>
    


    <!-- https://schema.org/Taxi -->

    <Class rdf:about="https://schema.org/Taxi">
        <rdfs:subClassOf rdf:resource="https://schema.org/Service"/>
