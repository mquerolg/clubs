        <schema:domainIncludes rdf:resource="https://schema.org/MediaObject"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/NewsArticle"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/associatedMedia">
        <rdfs:comment>A media object that encodes this CreativeWork. This property is a synonym for encoding.</rdfs:comment>
