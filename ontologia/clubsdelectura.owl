        <schema:domainIncludes rdf:resource="https://schema.org/Demand"/>
        <schema:domainIncludes rdf:resource="https://schema.org/Offer"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/ItemAvailability"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/availabilityEnds">
        <rdfs:comment>The end of the availability of the product or service included in the offer.</rdfs:comment>
