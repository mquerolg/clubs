        <rdfs:label>result</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/resultComment -->

    <AnnotationProperty rdf:about="http://schema.org/resultComment">
        <schema1:domainIncludes rdf:resource="http://schema.org/CommentAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/ReplyAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Comment"/>
        <rdfs:comment>A sub property of result. The Comment created or sent as a result of this action.</rdfs:comment>
