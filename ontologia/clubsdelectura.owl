    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/dosageForm">
        <schema1:domainIncludes rdf:resource="http://schema.org/Drug"/>
        <schema1:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
