        <rdfs:label>operatingSystem</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/SoftwareApplication"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderDate">
        <rdfs:comment>Date order was placed.</rdfs:comment>
        <rdfs:label>orderDate</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Order"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Date"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/DateTime"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderDelivery">
        <rdfs:comment>The delivery of the parcel related to this order or order item.</rdfs:comment>
        <rdfs:label>orderDelivery</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Order"/>
        <schema:domainIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/ParcelDelivery"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderItemNumber">
        <rdfs:comment>The identifier of the order item.</rdfs:comment>
        <rdfs:label>orderItemNumber</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderItemStatus">
        <rdfs:comment>The current status of the order item.</rdfs:comment>
        <rdfs:label>orderItemStatus</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/OrderStatus"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderQuantity">
        <rdfs:comment>The number of the item ordered. If the property is not set, assume the quantity is one.</rdfs:comment>
        <rdfs:label>orderQuantity</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Number"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderStatus">
        <rdfs:comment>The current status of the order.</rdfs:comment>
        <rdfs:label>orderStatus</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Order"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/OrderStatus"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/orderedItem">
        <rdfs:comment>The item ordered.</rdfs:comment>
        <rdfs:label>orderedItem</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Order"/>
        <schema:domainIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/OrderItem"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Product"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Service"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/organizer">
        <rdfs:comment>An organizer of an Event.</rdfs:comment>
        <rdfs:label>organizer</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Event"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Organization"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Person"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/originAddress">
        <rdfs:comment>Shipper&apos;s address.</rdfs:comment>
        <rdfs:label>originAddress</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/ParcelDelivery"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/PostalAddress"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/originatesFrom">
        <rdfs:comment>The vasculature the lymphatic structure originates, or afferents, from.</rdfs:comment>
        <rdfs:label>originatesFrom</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/LymphaticVessel"/>
        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Vessel"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/overdosage">
