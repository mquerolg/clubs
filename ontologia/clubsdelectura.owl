        <rdfs:label>TaxiService</rdfs:label>
    </Class>
    


    <!-- https://schema.org/TaxiStand -->

    <Class rdf:about="https://schema.org/TaxiStand">
        <rdfs:subClassOf rdf:resource="https://schema.org/CivicStructure"/>
        <rdfs:comment>A taxi stand.</rdfs:comment>
        <rdfs:label>TaxiStand</rdfs:label>
    </Class>
    


    <!-- https://schema.org/TechArticle -->

    <Class rdf:about="https://schema.org/TechArticle">
