        <rdfs:label>AutomotiveBusiness</rdfs:label>
    </Class>
    


    <!-- https://schema.org/BackgroundNewsArticle -->

    <Class rdf:about="https://schema.org/BackgroundNewsArticle">
        <rdfs:subClassOf rdf:resource="https://schema.org/NewsArticle"/>
        <rdfs:comment>A &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/NewsArticle&quot;&gt;NewsArticle&lt;/a&gt; providing historical context, definition and detail on a specific topic (aka &quot;explainer&quot; or &quot;backgrounder&quot;). For example, an in-depth article or frequently-asked-questions (&lt;a href=&quot;https://en.wikipedia.org/wiki/FAQ&quot;&gt;FAQ&lt;/a&gt;) document on topics such as Climate Change or the European Union. Other kinds of background material from a non-news setting are often described using &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Book&quot;&gt;Book&lt;/a&gt; or &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Article&quot;&gt;Article&lt;/a&gt;, in particular &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/ScholarlyArticle&quot;&gt;ScholarlyArticle&lt;/a&gt;. See also &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/NewsArticle&quot;&gt;NewsArticle&lt;/a&gt; for related vocabulary from a learning/education perspective.</rdfs:comment>
        <rdfs:label>BackgroundNewsArticle</rdfs:label>
        <schema:category>issue-1525</schema:category>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1525"/>
        <schema:source rdf:resource="https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP"/>
    </Class>
    


    <!-- https://schema.org/Bakery -->

    <Class rdf:about="https://schema.org/Bakery">
        <rdfs:subClassOf rdf:resource="https://schema.org/FoodEstablishment"/>
        <rdfs:comment>A bakery.</rdfs:comment>
        <rdfs:label>Bakery</rdfs:label>
    </Class>
    


    <!-- https://schema.org/BankAccount -->

    <Class rdf:about="https://schema.org/BankAccount">
        <rdfs:subClassOf rdf:resource="https://schema.org/FinancialProduct"/>
        <rdfs:comment>A product or service offered by a bank whereby one may deposit, withdraw or transfer money and in some cases be paid interest.</rdfs:comment>
        <rdfs:label>BankAccount</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FIBO"/>
    </Class>
    


    <!-- https://schema.org/BankOrCreditUnion -->

    <Class rdf:about="https://schema.org/BankOrCreditUnion">
        <rdfs:subClassOf rdf:resource="https://schema.org/FinancialService"/>
        <rdfs:comment>Bank or credit union.</rdfs:comment>
        <rdfs:label>BankOrCreditUnion</rdfs:label>
    </Class>
    


    <!-- https://schema.org/BarOrPub -->

    <Class rdf:about="https://schema.org/BarOrPub">
        <rdfs:subClassOf rdf:resource="https://schema.org/FoodEstablishment"/>
        <rdfs:comment>A bar or pub.</rdfs:comment>
        <rdfs:label>BarOrPub</rdfs:label>
    </Class>
    


    <!-- https://schema.org/Barcode -->

    <Class rdf:about="https://schema.org/Barcode">
