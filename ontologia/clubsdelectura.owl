        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2109"/>
        <rdfs:comment>A &lt;a href=&quot;https://en.wikipedia.org/wiki/Call_sign&quot;&gt;callsign&lt;/a&gt;, as used in broadcasting and radio communications to identify people, radio and TV stations, or vehicles.</rdfs:comment>
        <rdfs:label>callSign</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
    </AnnotationProperty>
    


