        <rdfs:comment>A short segment/part of a movie.</rdfs:comment>
        <rdfs:label>MovieClip</rdfs:label>
    </Class>
    


    <!-- https://schema.org/MovieRentalStore -->

    <Class rdf:about="https://schema.org/MovieRentalStore">
