        <rdfs:label>MusicReleaseFormatType</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#MBZ"/>
    </Class>
    


    <!-- https://schema.org/MusicStore -->

    <Class rdf:about="https://schema.org/MusicStore">
        <rdfs:subClassOf rdf:resource="https://schema.org/Store"/>
        <rdfs:comment>A music store.</rdfs:comment>
        <rdfs:label>MusicStore</rdfs:label>
    </Class>
    


    <!-- https://schema.org/MusicVenue -->

    <Class rdf:about="https://schema.org/MusicVenue">
