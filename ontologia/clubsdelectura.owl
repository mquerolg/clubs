    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/safetyConsideration">
        <schema1:domainIncludes rdf:resource="http://schema.org/DietarySupplement"/>
        <schema1:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>Any potential safety concern associated with the supplement. May include interactions with other drugs and foods, pregnancy, breastfeeding, known adverse reactions, and documented efficacy of the supplement.</rdfs:comment>
        <rdfs:label>safetyConsideration</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/salaryCurrency">
        <schema1:domainIncludes rdf:resource="http://schema.org/EmployeeRole"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/JobPosting"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>The currency (coded using &lt;a href=&quot;http://en.wikipedia.org/wiki/ISO_4217&quot;&gt;ISO 4217&lt;/a&gt; ) used for the main salary information in this job posting or for this employee.</rdfs:comment>
        <rdfs:label>salaryCurrency</rdfs:label>
    </rdf:Description>
