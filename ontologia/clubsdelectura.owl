    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/subtitleLanguage">
        <rdfs:comment>Languages in which subtitles/captions are available, in &lt;a href=&quot;http://tools.ietf.org/html/bcp47&quot;&gt;IETF BCP 47 standard format&lt;/a&gt;.</rdfs:comment>
        <rdfs:label>subtitleLanguage</rdfs:label>
        <schema:category>issue-2110</schema:category>
        <schema:domainIncludes rdf:resource="https://schema.org/BroadcastEvent"/>
        <schema:domainIncludes rdf:resource="https://schema.org/Movie"/>
        <schema:domainIncludes rdf:resource="https://schema.org/ScreeningEvent"/>
        <schema:domainIncludes rdf:resource="https://schema.org/TVEpisode"/>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
