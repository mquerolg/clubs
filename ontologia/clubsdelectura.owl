        <schema:rangeIncludes rdf:resource="https://schema.org/Place"/>
        <schema:supersededBy rdf:resource="https://schema.org/serviceArea"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/arrivalAirport">
        <rdfs:comment>The airport where the flight terminates.</rdfs:comment>
