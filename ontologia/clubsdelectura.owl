        <schema:domainIncludes rdf:resource="https://schema.org/PeopleAudience"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/suggestedMaxAge">
        <rdfs:comment>Maximal age recommended for viewing content.</rdfs:comment>
