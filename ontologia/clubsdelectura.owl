        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/strengthValue">
        <rdfs:comment>The value of an active ingredient&apos;s strength, e.g. 325.</rdfs:comment>
        <rdfs:label>strengthValue</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/DrugStrength"/>
        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Number"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/structuralClass">
