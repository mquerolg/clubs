        <schema:domainIncludes rdf:resource="https://schema.org/Offer"/>
        <schema:domainIncludes rdf:resource="https://schema.org/Organization"/>
        <schema:domainIncludes rdf:resource="https://schema.org/Place"/>
        <schema:domainIncludes rdf:resource="https://schema.org/Product"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Review"/>
        <schema:supersededBy rdf:resource="https://schema.org/review"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/riskFactor">
        <rdfs:comment>A modifiable or non-modifiable factor that increases the risk of a patient contracting this condition, e.g. age,  coexisting condition.</rdfs:comment>
        <rdfs:label>riskFactor</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/MedicalCondition"/>
        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/MedicalRiskFactor"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/risks">
        <rdfs:comment>Specific physiologic risks associated to the diet plan.</rdfs:comment>
        <rdfs:label>risks</rdfs:label>
