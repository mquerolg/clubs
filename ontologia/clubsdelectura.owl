        <schema1:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Vessel"/>
        <rdfs:comment>The vasculature the lymphatic structure runs, or efferents, to.</rdfs:comment>
        <rdfs:label>runsTo</rdfs:label>
    </rdf:Description>
