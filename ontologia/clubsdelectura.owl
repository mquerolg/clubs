        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1698"/>
    </Class>
    


    <!-- https://schema.org/OccupationalTherapy -->

    <Class rdf:about="https://schema.org/OccupationalTherapy">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalTherapy"/>
