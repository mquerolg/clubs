        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms"/>
        <rdfs:comment>The &lt;a href=&quot;http://www.gs1.org/gln&quot;&gt;Global Location Number&lt;/a&gt; (GLN, sometimes also referred to as International Location Number or ILN) of the respective organization, person, or place. The GLN is a 13-digit number used to identify parties and physical locations.</rdfs:comment>
        <rdfs:label>globalLocationNumber</rdfs:label>
