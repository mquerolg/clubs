        <rdfs:label>replacee</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/object"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/replacer -->

    <AnnotationProperty rdf:about="http://schema.org/replacer">
        <schema1:domainIncludes rdf:resource="http://schema.org/ReplaceAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Thing"/>
