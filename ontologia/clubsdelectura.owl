        <schema:rangeIncludes rdf:resource="https://schema.org/SuperficialAnatomy"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/associatedArticle">
        <rdfs:comment>A NewsArticle associated with the Media Object.</rdfs:comment>
