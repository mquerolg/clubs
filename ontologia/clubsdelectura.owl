    <!-- http://example.org/book5 -->

    <NamedIndividual rdf:about="http://example.org/book5">
        <rdf:type rdf:resource="http://schema.org/Book"/>
        <schema1:author rdf:resource="http://example.org/author5"/>
        <schema1:authorName>Jaume Sobrequés i Callicó</schema1:authorName>
        <schema1:datePublished>2007</schema1:datePublished>
        <schema1:description>This is an ideal introduction to the whole history of Catalonia from the remotest times until the present. It is a rigorous and accessible vision aimed at everyone, which can be read quickly and easily. The book brings the Catalan past to all Catalans and to foreigners who, when they visit Catalonia, want a general understanding of what this country has been over its thousands of years of existence. This short history seeks to set out the formation of a nation with its own state, which played a key role in Europe for centuries. It also explains how this state was attacked for two centuries until its destruction on 11 September 1714 and the subsequent struggle by Catalans to be reborn from their ashes and recover their place in history.</schema1:description>
        <schema1:genre>History</schema1:genre>
        <schema1:isbn>9788485031863</schema1:isbn>
        <schema1:name>History of Catalonia</schema1:name>
    </NamedIndividual>
    


