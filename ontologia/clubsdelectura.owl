        <schema:rangeIncludes rdf:resource="https://schema.org/AnatomicalStructure"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/artform">
        <rdfs:comment>e.g. Painting, Drawing, Sculpture, Print, Photograph, Assemblage, Collage, etc.</rdfs:comment>
