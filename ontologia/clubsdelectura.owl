        <schema1:domainIncludes rdf:resource="http://schema.org/Demand"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/JobPosting"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/LocationFeatureSpecification"/>
