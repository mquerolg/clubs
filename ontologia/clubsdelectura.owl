        <rdfs:comment>A bowling alley.</rdfs:comment>
        <rdfs:label>BowlingAlley</rdfs:label>
    </Class>
    


    <!-- http://schema.org/BrainStructure -->

    <Class rdf:about="http://schema.org/BrainStructure">
