        <schema1:domainIncludes rdf:resource="http://schema.org/MediaObject"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Movie"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/MusicRecording"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/MusicRelease"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/QuantitativeValueDistribution"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Schedule"/>
