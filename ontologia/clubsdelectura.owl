        <rdfs:comment>A gym.</rdfs:comment>
        <rdfs:label>ExerciseGym</rdfs:label>
    </Class>
    


    <!-- https://schema.org/ExercisePlan -->

    <Class rdf:about="https://schema.org/ExercisePlan">
