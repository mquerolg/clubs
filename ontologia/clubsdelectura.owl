        <rdfs:label>scheduledPaymentDate</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/scheduledTime">
        <schema1:domainIncludes rdf:resource="http://schema.org/PlanAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/DateTime"/>
        <rdfs:comment>The time the object is scheduled to.</rdfs:comment>
        <rdfs:label>scheduledTime</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/schemaVersion">
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <rdfs:comment>Indicates (by URL or string) a particular version of a schema used in some CreativeWork. For example, a document could declare a schemaVersion using an URL such as http://schema.org/version/2.0/ if precise indication of schema version was required by some application.</rdfs:comment>
        <rdfs:label>schemaVersion</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/schoolClosuresInfo">
