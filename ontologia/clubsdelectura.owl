    <!-- http://schema.org/BackgroundNewsArticle -->

    <Class rdf:about="http://schema.org/BackgroundNewsArticle">
        <rdfs:subClassOf rdf:resource="http://schema.org/NewsArticle"/>
        <schema1:category>issue-1525</schema1:category>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1525"/>
        <schema1:source rdf:resource="https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP"/>
        <rdfs:comment>A &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/NewsArticle&quot;&gt;NewsArticle&lt;/a&gt; providing historical context, definition and detail on a specific topic (aka &quot;explainer&quot; or &quot;backgrounder&quot;). For example, an in-depth article or frequently-asked-questions (&lt;a href=&quot;https://en.wikipedia.org/wiki/FAQ&quot;&gt;FAQ&lt;/a&gt;) document on topics such as Climate Change or the European Union. Other kinds of background material from a non-news setting are often described using &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Book&quot;&gt;Book&lt;/a&gt; or &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Article&quot;&gt;Article&lt;/a&gt;, in particular &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/ScholarlyArticle&quot;&gt;ScholarlyArticle&lt;/a&gt;. See also &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/NewsArticle&quot;&gt;NewsArticle&lt;/a&gt; for related vocabulary from a learning/education perspective.</rdfs:comment>
        <rdfs:label>BackgroundNewsArticle</rdfs:label>
    </Class>
    


    <!-- http://schema.org/Bakery -->

    <Class rdf:about="http://schema.org/Bakery">
        <rdfs:subClassOf rdf:resource="http://schema.org/FoodEstablishment"/>
