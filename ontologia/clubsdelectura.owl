    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/about -->

    <AnnotationProperty rdf:about="http://schema.org/about">
        <schema1:category>issue-1670</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/CommunicateAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Event"/>
        <schema1:inverseOf rdf:resource="http://schema.org/subjectOf"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Thing"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1670"/>
        <rdfs:comment>The subject matter of the content.</rdfs:comment>
        <rdfs:label>about</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/acceptedAnswer -->

    <AnnotationProperty rdf:about="http://schema.org/acceptedAnswer">
        <schema1:domainIncludes rdf:resource="http://schema.org/Question"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Answer"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/ItemList"/>
        <rdfs:comment>The answer(s) that has been accepted as best, typically on a Question/Answer site. Sites vary in their selection mechanisms, e.g. drawing on community opinion and/or the view of the Question author.</rdfs:comment>
        <rdfs:label>acceptedAnswer</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/suggestedAnswer"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/accommodationCategory -->

    <AnnotationProperty rdf:about="http://schema.org/accommodationCategory">
        <schema1:category>issue-2373</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/Accommodation"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2373"/>
        <rdfs:comment>Category of an &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Accommodation&quot;&gt;Accommodation&lt;/a&gt;, following real estate conventions e.g. RESO (see &lt;a href=&quot;https://ddwiki.reso.org/display/DDW17/PropertySubType+Field&quot;&gt;PropertySubType&lt;/a&gt;, and &lt;a href=&quot;https://ddwiki.reso.org/display/DDW17/PropertyType+Field&quot;&gt;PropertyType&lt;/a&gt; fields  for suggested values).</rdfs:comment>
        <rdfs:label>accommodationCategory</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/category"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/accountId -->

    <AnnotationProperty rdf:about="http://schema.org/accountId">
        <schema1:domainIncludes rdf:resource="http://schema.org/Invoice"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>The identifier for the account the payment will be applied to.</rdfs:comment>
        <rdfs:label>accountId</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/acquireLicensePage -->

    <AnnotationProperty rdf:about="http://schema.org/acquireLicensePage">
        <schema1:category>issue-2454</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2454"/>
        <rdfs:comment>Indicates a page documenting how licenses can be purchased or otherwise acquired, for the current item.</rdfs:comment>
        <rdfs:label>acquireLicensePage</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/usageInfo"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/actionOption -->

    <AnnotationProperty rdf:about="http://schema.org/actionOption">
        <schema1:domainIncludes rdf:resource="http://schema.org/ChooseAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Thing"/>
        <rdfs:comment>A sub property of object. The options subject to this action.</rdfs:comment>
        <rdfs:label>actionOption</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/object"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/actionableFeedbackPolicy -->

    <AnnotationProperty rdf:about="http://schema.org/actionableFeedbackPolicy">
        <schema1:category>issue-1525</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/NewsMediaOrganization"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1525"/>
        <schema1:source rdf:resource="https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP"/>
        <rdfs:comment>For a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/NewsMediaOrganization&quot;&gt;NewsMediaOrganization&lt;/a&gt; or other news-related &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Organization&quot;&gt;Organization&lt;/a&gt;, a statement about public engagement activities (for news media, the newsroomâs), including involving the public - digitally or otherwise -- in coverage decisions, reporting and activities after publication.</rdfs:comment>
        <rdfs:label>actionableFeedbackPolicy</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/publishingPrinciples"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/actor -->

    <AnnotationProperty rdf:about="http://schema.org/actor">
        <schema1:domainIncludes rdf:resource="http://schema.org/Clip"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWorkSeason"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Episode"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Event"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Movie"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/MovieSeries"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/RadioSeries"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/TVSeries"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/VideoGame"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/VideoGameSeries"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/VideoObject"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>An actor, e.g. in tv, radio, movie, video games etc., or in an event. Actors can be associated with individual items or with a series, episode, clip.</rdfs:comment>
        <rdfs:label>actor</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/additionalType -->

    <AnnotationProperty rdf:about="http://schema.org/additionalType">
        <schema1:domainIncludes rdf:resource="http://schema.org/Thing"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <rdfs:comment>An additional type for the item, typically used for adding more specific types from external vocabularies in microdata syntax. This is a relationship between something and a class that the thing is in. In RDFa syntax, it is better to use the native RDFa syntax - the &apos;typeof&apos; attribute - for multiple types. Schema.org tools may have only weaker understanding of extra types, in particular those defined externally.</rdfs:comment>
        <rdfs:label>additionalType</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/affiliation -->

    <AnnotationProperty rdf:about="http://schema.org/affiliation">
        <schema1:domainIncludes rdf:resource="http://schema.org/Person"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Organization"/>
        <rdfs:comment>An organization that this person is affiliated with. For example, a school/university, a club, or a team.</rdfs:comment>
        <rdfs:label>affiliation</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/memberOf"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/aggregateRating -->

    <AnnotationProperty rdf:about="http://schema.org/aggregateRating">
        <schema1:domainIncludes rdf:resource="http://schema.org/Brand"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Event"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Offer"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Place"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Product"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Service"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/AggregateRating"/>
        <rdfs:comment>The overall rating, based on a collection of reviews or ratings, of the item.</rdfs:comment>
        <rdfs:label>aggregateRating</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/announcementLocation -->

    <AnnotationProperty rdf:about="http://schema.org/announcementLocation">
        <schema1:category>issue-2514</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/SpecialAnnouncement"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CivicStructure"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/LocalBusiness"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2514"/>
        <rdfs:comment>Indicates a specific &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/CivicStructure&quot;&gt;CivicStructure&lt;/a&gt; or &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/LocalBusiness&quot;&gt;LocalBusiness&lt;/a&gt; associated with the SpecialAnnouncement. For example, a specific testing facility or business with special opening hours. For a larger geographic region like a quarantine of an entire region, use &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/spatialCoverage&quot;&gt;spatialCoverage&lt;/a&gt;.</rdfs:comment>
        <rdfs:label>announcementLocation</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/spatialCoverage"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/appearance -->

    <AnnotationProperty rdf:about="http://schema.org/appearance">
        <schema1:category>issue-1828</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/Claim"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1828"/>
        <rdfs:comment>Indicates an occurence of a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Claim&quot;&gt;Claim&lt;/a&gt; in some &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/CreativeWork&quot;&gt;CreativeWork&lt;/a&gt;.</rdfs:comment>
        <rdfs:label>appearance</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/workExample"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/areaServed -->

    <AnnotationProperty rdf:about="http://schema.org/areaServed">
        <schema1:domainIncludes rdf:resource="http://schema.org/ContactPoint"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/DeliveryChargeSpecification"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Demand"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Offer"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Service"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/AdministrativeArea"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/GeoShape"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Place"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>The geographic area where a service or offered item is provided.</rdfs:comment>
        <rdfs:label>areaServed</rdfs:label>
    </AnnotationProperty>
    


    <!-- http://schema.org/artMedium -->

    <AnnotationProperty rdf:about="http://schema.org/artMedium">
        <schema1:domainIncludes rdf:resource="http://schema.org/VisualArtwork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <rdfs:comment>The material used. (e.g. Oil, Watercolour, Acrylic, Linoprint, Marble, Cyanotype, Digital, Lithograph, DryPoint, Intaglio, Pastel, Woodcut, Pencil, Mixed Media, etc.)</rdfs:comment>
        <rdfs:label>artMedium</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/material"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/authorName -->

    <AnnotationProperty rdf:about="http://schema.org/authorName"/>
    


    <!-- http://schema.org/availableAtOrFrom -->

    <AnnotationProperty rdf:about="http://schema.org/availableAtOrFrom">
        <schema1:domainIncludes rdf:resource="http://schema.org/Demand"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Offer"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Place"/>
        <schema1:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms"/>
        <rdfs:comment>The place(s) from which the offer can be obtained (e.g. store locations).</rdfs:comment>
        <rdfs:label>availableAtOrFrom</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/areaServed"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/awayTeam -->

    <AnnotationProperty rdf:about="http://schema.org/awayTeam">
