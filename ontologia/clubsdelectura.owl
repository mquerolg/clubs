        <schema:domainIncludes rdf:resource="https://schema.org/CreativeWork"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/MediaObject"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/associatedPathophysiology">
