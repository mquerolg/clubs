        <rdfs:label>Newspaper</rdfs:label>
        <schema:isPartOf rdf:resource="http://bib.schema.org"/>
        <schema:source rdf:resource="http://www.productontology.org/id/Newspaper"/>
    </Class>
    


    <!-- https://schema.org/NightClub -->

    <Class rdf:about="https://schema.org/NightClub">
        <rdfs:subClassOf rdf:resource="https://schema.org/EntertainmentBusiness"/>
        <rdfs:comment>A nightclub or discotheque.</rdfs:comment>
        <rdfs:label>NightClub</rdfs:label>
    </Class>
    


