        <rdfs:label>EventPostponed</rdfs:label>
    </NamedIndividual>
    


    <!-- https://schema.org/EventRescheduled -->

    <NamedIndividual rdf:about="https://schema.org/EventRescheduled">
        <rdf:type rdf:resource="https://schema.org/EventStatusType"/>
        <rdfs:comment>The event has been rescheduled. The event&apos;s previousStartDate should be set to the old date and the startDate should be set to the event&apos;s new date. (If the event has been rescheduled multiple times, the previousStartDate property may be repeated).</rdfs:comment>
        <rdfs:label>EventRescheduled</rdfs:label>
    </NamedIndividual>
    


