        <schema:isPartOf rdf:resource="http://bib.schema.org"/>
        <schema:source rdf:resource="http://www.productontology.org/id/Thesis"/>
    </Class>
    


    <!-- https://schema.org/Thing -->

    <Class rdf:about="https://schema.org/Thing">
        <rdfs:comment>The most generic type of item.</rdfs:comment>
        <rdfs:label>Thing</rdfs:label>
    </Class>
    


    <!-- https://schema.org/Ticket -->

    <Class rdf:about="https://schema.org/Ticket">
