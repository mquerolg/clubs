        <rdfs:subClassOf rdf:resource="https://schema.org/EntertainmentBusiness"/>
        <rdfs:comment>A movie theater.</rdfs:comment>
        <rdfs:label>MovieTheater</rdfs:label>
    </Class>
    


    <!-- https://schema.org/MovingCompany -->

    <Class rdf:about="https://schema.org/MovingCompany">
        <rdfs:subClassOf rdf:resource="https://schema.org/HomeAndConstructionBusiness"/>
        <rdfs:comment>A moving company.</rdfs:comment>
        <rdfs:label>MovingCompany</rdfs:label>
    </Class>
    


    <!-- https://schema.org/Muscle -->

    <Class rdf:about="https://schema.org/Muscle">
        <rdfs:subClassOf rdf:resource="https://schema.org/AnatomicalStructure"/>
