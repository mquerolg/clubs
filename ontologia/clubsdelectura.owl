    </AnnotationProperty>
    


    <!-- http://schema.org/buyer -->

    <AnnotationProperty rdf:about="http://schema.org/buyer">
        <schema1:domainIncludes rdf:resource="http://schema.org/SellAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>A sub property of participant. The participant/person/organization that bought the object.</rdfs:comment>
        <rdfs:label>buyer</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/participant"/>
    </AnnotationProperty>
    


