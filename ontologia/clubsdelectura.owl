        <schema:domainIncludes rdf:resource="https://schema.org/CreativeWork"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Person"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/characterAttribute">
        <rdfs:comment>A piece of data that represents a particular aspect of a fictional character (skill, power, character points, advantage, disadvantage).</rdfs:comment>
        <rdfs:label>characterAttribute</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/Game"/>
        <schema:domainIncludes rdf:resource="https://schema.org/VideoGameSeries"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Thing"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/characterName">
        <rdfs:comment>The name of a character played in some acting or performing role, i.e. in a PerformanceRole.</rdfs:comment>
        <rdfs:label>characterName</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/PerformanceRole"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/cheatCode">
        <rdfs:comment>Cheat codes to the game.</rdfs:comment>
