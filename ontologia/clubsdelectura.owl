        <schema1:domainIncludes rdf:resource="http://schema.org/DonateAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/GiveAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Message"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/PayAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/ReturnAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/SendAction"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/TipAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Audience"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/ContactPoint"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>A sub property of participant. The participant who is at the receiving end of the action.</rdfs:comment>
        <rdfs:label>recipient</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/participant"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/repeatFrequency -->

    <AnnotationProperty rdf:about="http://schema.org/repeatFrequency">
        <schema1:category>issue-1457</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/Schedule"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Duration"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1457"/>
        <rdfs:comment>Defines the frequency at which &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Events&quot;&gt;Events&lt;/a&gt; will occur according to a schedule &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Schedule&quot;&gt;Schedule&lt;/a&gt;. The intervals between
      events should be defined as a &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Duration&quot;&gt;Duration&lt;/a&gt; of time.</rdfs:comment>
        <rdfs:label>repeatFrequency</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/frequency"/>
    </AnnotationProperty>
    


