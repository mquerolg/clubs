        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#Tourism"/>
    </Class>
    


    <!-- https://schema.org/TypeAndQuantityNode -->

    <Class rdf:about="https://schema.org/TypeAndQuantityNode">
        <rdfs:subClassOf rdf:resource="https://schema.org/StructuredValue"/>
        <rdfs:comment>A structured value indicating the quantity, unit of measurement, and business function of goods included in a bundle offer.</rdfs:comment>
        <rdfs:label>TypeAndQuantityNode</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass"/>
    </Class>
    


    <!-- https://schema.org/UKNonprofitType -->

    <Class rdf:about="https://schema.org/UKNonprofitType">
        <rdfs:subClassOf rdf:resource="https://schema.org/NonprofitType"/>
        <rdfs:comment>UKNonprofitType: Non-profit organization type originating from the United Kingdom.</rdfs:comment>
