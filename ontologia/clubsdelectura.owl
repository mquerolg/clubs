    </Class>
    


    <!-- http://www.semanticweb.org/clubslectura#Lot -->

    <Class rdf:about="http://www.semanticweb.org/clubslectura#Lot">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#conteExemplar"/>
                <minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</minCardinality>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/clubslectura#LotActiu -->

    <Class rdf:about="http://www.semanticweb.org/clubslectura#LotActiu">
        <equivalentClass>
            <Class>
                <intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/clubslectura#Lot"/>
                    <Restriction>
                        <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#conteExemplar"/>
                        <someValuesFrom rdf:resource="http://www.semanticweb.org/clubslectura#Exemplar"/>
                    </Restriction>
                </intersectionOf>
            </Class>
        </equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/clubslectura#Lot"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.semanticweb.org/clubslectura#conteExemplar"/>
                <minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</minCardinality>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


