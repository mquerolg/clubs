        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/AdministrativeArea"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/studySubject">
        <rdfs:comment>A subject of the study, i.e. one of the medical conditions, therapies, devices, drugs, etc. investigated by the study.</rdfs:comment>
