    <!-- https://schema.org/TVSeason -->

    <Class rdf:about="https://schema.org/TVSeason">
        <rdfs:subClassOf rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/CreativeWorkSeason"/>
        <rdfs:comment>Season dedicated to TV broadcast and associated online delivery.</rdfs:comment>
        <rdfs:label>TVSeason</rdfs:label>
