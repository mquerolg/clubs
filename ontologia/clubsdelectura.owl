    <!-- http://schema.org/EducationalOccupationalCredential -->

    <Class rdf:about="http://schema.org/EducationalOccupationalCredential">
        <rdfs:subClassOf rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:category>issue-1779</schema1:category>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1779"/>
        <rdfs:comment>An educational or occupational credential. A diploma, academic degree, certification, qualification, badge, etc., that may be awarded to a person or other entity that meets the requirements defined by the credentialer.</rdfs:comment>
        <rdfs:label>EducationalOccupationalCredential</rdfs:label>
