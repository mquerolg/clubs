    </Class>
    


    <!-- https://schema.org/VirtualLocation -->

    <Class rdf:about="https://schema.org/VirtualLocation">
        <rdfs:subClassOf rdf:resource="https://schema.org/Intangible"/>
        <rdfs:comment>An online or virtual location for attending events. For example, one may attend an online seminar or educational event. While a virtual location may be used as the location of an event, virtual locations should not be confused with physical locations in the real world.</rdfs:comment>
        <rdfs:label>VirtualLocation</rdfs:label>
        <schema:category>issue-1842</schema:category>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1842"/>
    </Class>
    


