        <schema1:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
        <rdfs:comment>A medical procedure involving an incision with instruments; performed for diagnose, or therapeutic purposes.</rdfs:comment>
        <rdfs:label>SurgicalProcedure</rdfs:label>
    </Class>
    


