        <schema:domainIncludes rdf:resource="https://schema.org/LodgingReservation"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/DateTime"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Time"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/childMaxAge">
        <rdfs:comment>Maximal age of the child.</rdfs:comment>
        <rdfs:label>childMaxAge</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/ParentAudience"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Number"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/childMinAge">
        <rdfs:comment>Minimal age of the child.</rdfs:comment>
        <rdfs:label>childMinAge</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/ParentAudience"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Number"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/children">
        <rdfs:comment>A child of the person.</rdfs:comment>
