        <rdfs:label>departureBoatTerminal</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/departureBusStop">
        <schema1:domainIncludes rdf:resource="http://schema.org/BusTrip"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/BusStation"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/BusStop"/>
