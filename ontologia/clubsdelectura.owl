        <schema:domainIncludes rdf:resource="https://schema.org/NutritionInformation"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Mass"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/circle">
        <rdfs:comment>A circle is the circular region of a specified radius centered at a specified latitude and longitude. A circle is expressed as a pair followed by a radius in meters.</rdfs:comment>
        <rdfs:label>circle</rdfs:label>
        <schema:domainIncludes rdf:resource="https://schema.org/GeoShape"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/citation">
        <rdfs:comment>A citation or reference to another creative work, such as another publication, web page, scholarly article, etc.</rdfs:comment>
