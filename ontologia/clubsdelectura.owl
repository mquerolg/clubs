        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <rdfs:comment>A colleague of the person.</rdfs:comment>
        <rdfs:label>colleague</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/colleagues">
        <schema1:domainIncludes rdf:resource="http://schema.org/Person"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <schema1:supersededBy rdf:resource="http://schema.org/colleague"/>
        <rdfs:comment>A colleague of the person.</rdfs:comment>
        <rdfs:label>colleagues</rdfs:label>
    </rdf:Description>
