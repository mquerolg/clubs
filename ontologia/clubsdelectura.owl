        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2543"/>
    </Class>
    


    <!-- https://schema.org/Notary -->

    <Class rdf:about="https://schema.org/Notary">
        <rdfs:subClassOf rdf:resource="https://schema.org/LegalService"/>
        <rdfs:comment>A notary.</rdfs:comment>
        <rdfs:label>Notary</rdfs:label>
    </Class>
    


