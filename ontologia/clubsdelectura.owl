        <rdfs:label>ticketedSeat</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/timeOfDay">
        <schema1:category>issue-2419</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/EducationalOccupationalProgram"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2419"/>
        <rdfs:comment>The time of day the program normally runs. For example, &quot;evenings&quot;.</rdfs:comment>
        <rdfs:label>timeOfDay</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/timeRequired">
        <schema1:domainIncludes rdf:resource="http://schema.org/CreativeWork"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Duration"/>
        <rdfs:comment>Approximate or typical time it takes to work with or through this learning resource for the typical intended target audience, e.g. &apos;PT30M&apos;, &apos;PT1H25M&apos;.</rdfs:comment>
        <rdfs:label>timeRequired</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/timeToComplete">
        <schema1:category>issue-2289</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/EducationalOccupationalProgram"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Duration"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/2289"/>
        <rdfs:comment>The expected length of time to complete the program if attending full-time.</rdfs:comment>
        <rdfs:label>timeToComplete</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/tissueSample">
