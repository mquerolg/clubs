        <rdfs:comment>The act of traveling from an fromLocation to a destination by a specified mode of transport, optionally with participants.</rdfs:comment>
        <rdfs:label>TravelAction</rdfs:label>
    </Class>
    


    <!-- https://schema.org/TravelAgency -->

    <Class rdf:about="https://schema.org/TravelAgency">
        <rdfs:subClassOf rdf:resource="https://schema.org/LocalBusiness"/>
        <rdfs:comment>A travel agency.</rdfs:comment>
        <rdfs:label>TravelAgency</rdfs:label>
    </Class>
    


    <!-- https://schema.org/TreatmentIndication -->

    <Class rdf:about="https://schema.org/TreatmentIndication">
        <rdfs:subClassOf rdf:resource="https://schema.org/MedicalIndication"/>
        <rdfs:comment>An indication for treating an underlying condition, symptom, etc.</rdfs:comment>
        <rdfs:label>TreatmentIndication</rdfs:label>
        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
    </Class>
    


    <!-- https://schema.org/Trip -->

    <Class rdf:about="https://schema.org/Trip">
        <rdfs:subClassOf rdf:resource="https://schema.org/Intangible"/>
        <rdfs:comment>A trip or journey. An itinerary of visits to one or more places.</rdfs:comment>
