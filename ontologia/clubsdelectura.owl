        <schema1:domainIncludes rdf:resource="http://schema.org/Demand"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Flight"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Offer"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/Order"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
        <rdfs:comment>An entity which offers (sells / leases / lends / loans) the services / goods.  A seller may also be a provider.</rdfs:comment>
        <rdfs:label>seller</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://schema.org/participant"/>
    </AnnotationProperty>
    


    <!-- http://schema.org/sender -->

    <AnnotationProperty rdf:about="http://schema.org/sender">
        <schema1:domainIncludes rdf:resource="http://schema.org/Message"/>
        <schema1:domainIncludes rdf:resource="http://schema.org/ReceiveAction"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Audience"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Organization"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Person"/>
