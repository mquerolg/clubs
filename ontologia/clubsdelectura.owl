        <schema:isPartOf rdf:resource="http://health-lifesci.schema.org"/>
    </Class>
    


    <!-- https://schema.org/Museum -->

    <Class rdf:about="https://schema.org/Museum">
        <rdfs:subClassOf rdf:resource="https://schema.org/CivicStructure"/>
        <rdfs:comment>A museum.</rdfs:comment>
        <rdfs:label>Museum</rdfs:label>
    </Class>
    


    <!-- https://schema.org/MusicAlbum -->

    <Class rdf:about="https://schema.org/MusicAlbum">
        <rdfs:subClassOf rdf:resource="https://schema.org/MusicPlaylist"/>
        <rdfs:comment>A collection of music tracks.</rdfs:comment>
        <rdfs:label>MusicAlbum</rdfs:label>
    </Class>
    


    <!-- https://schema.org/MusicAlbumProductionType -->

    <Class rdf:about="https://schema.org/MusicAlbumProductionType">
        <rdfs:subClassOf rdf:resource="https://schema.org/Enumeration"/>
