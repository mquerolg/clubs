        <rdfs:label>departureAirport</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/departureBoatTerminal">
        <schema1:category>issue-1755</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/BoatTrip"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/BoatTerminal"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1755"/>
