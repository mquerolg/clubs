        <schema:domainIncludes rdf:resource="https://schema.org/MobileApplication"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Text"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/cashBack">
        <rdfs:comment>A cardholder benefit that pays the cardholder a small percentage of their net expenditures.</rdfs:comment>
        <rdfs:label>cashBack</rdfs:label>
        <schema:category>issue-1253</schema:category>
        <schema:domainIncludes rdf:resource="https://schema.org/PaymentCard"/>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/Boolean"/>
