        <rdfs:comment>Car repair business.</rdfs:comment>
        <rdfs:label>AutoRepair</rdfs:label>
    </Class>
    


    <!-- https://schema.org/AutoWash -->

    <Class rdf:about="https://schema.org/AutoWash">
