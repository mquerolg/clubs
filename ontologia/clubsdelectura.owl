    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/runtimePlatform">
        <schema1:domainIncludes rdf:resource="http://schema.org/SoftwareSourceCode"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <rdfs:comment>Runtime platform or script interpreter dependencies (Example - Java v1, Python2.3, .Net Framework 3.0).</rdfs:comment>
        <rdfs:label>runtimePlatform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/rxcui">
