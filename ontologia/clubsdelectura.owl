    </Class>
    


    <!-- https://schema.org/MusicVideoObject -->

    <Class rdf:about="https://schema.org/MusicVideoObject">
        <rdfs:subClassOf rdf:resource="https://schema.org/MediaObject"/>
        <rdfs:comment>A music video file.</rdfs:comment>
        <rdfs:label>MusicVideoObject</rdfs:label>
    </Class>
    


    <!-- https://schema.org/NGO -->

    <Class rdf:about="https://schema.org/NGO">
        <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment>Organization: Non-governmental Organization.</rdfs:comment>
        <rdfs:label>NGO</rdfs:label>
    </Class>
    


    <!-- https://schema.org/NLNonprofitType -->

    <Class rdf:about="https://schema.org/NLNonprofitType">
        <rdfs:subClassOf rdf:resource="https://schema.org/NonprofitType"/>
        <rdfs:comment>NLNonprofitType: Non-profit organization type originating from the Netherlands.</rdfs:comment>
        <rdfs:label>NLNonprofitType</rdfs:label>
