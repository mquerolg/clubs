        <rdfs:label>saturatedFatContent</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/scheduleTimezone">
        <schema1:category>issue-1457</schema1:category>
        <schema1:domainIncludes rdf:resource="http://schema.org/Schedule"/>
        <schema1:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
        <schema1:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1457"/>
        <rdfs:comment>Indicates the timezone for which the time(s) indicated in the &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/Schedule&quot;&gt;Schedule&lt;/a&gt; are given. The value provided should be among those listed in the IANA Time Zone Database.</rdfs:comment>
        <rdfs:label>scheduleTimezone</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/scheduledPaymentDate">
