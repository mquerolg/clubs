    <!-- http://example.org/book11 -->

    <NamedIndividual rdf:about="http://example.org/book11">
        <rdf:type rdf:resource="http://schema.org/Book"/>
        <schema1:author rdf:resource="http://example.org/author10"/>
        <schema1:datePublished>2020-04-24</schema1:datePublished>
        <schema1:isbn>9781912387410</schema1:isbn>
        <schema1:name>Catalonia Reborn</schema1:name>
        <schema1:authorName>Chris Bambery</schema1:authorName>
        <schema1:description>2017 saw Catalonia come under the world&apos;s spotlight as it again fought for independence and the preservation and protection of its unique Catalan culture. Answering the questions and complications behind the fight for Catalonian Independence, Catalonia Reborn is a detailed guide to the region&apos;s political, historical and cultural issues. For the layman as well as the expert, it takes the reader through the rich history of Catalonia â its language, culture and political background â to the present day, covering defining eras of the region from Franco&apos;s dictatorship to the 2017 independence referendum and elections.</schema1:description>
        <schema1:genre>History</schema1:genre>
    </NamedIndividual>
    


