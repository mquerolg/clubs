        <rdfs:label>MusicAlbumReleaseType</rdfs:label>
        <schema:source rdf:resource="http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#MBZ"/>
    </Class>
    


    <!-- https://schema.org/MusicComposition -->

    <Class rdf:about="https://schema.org/MusicComposition">
