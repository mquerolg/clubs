    <rdf:Description rdf:about="https://schema.org/archiveHeld">
        <rdfs:comment>Collection, &lt;a href=&quot;https://en.wikipedia.org/wiki/Fonds&quot;&gt;fonds&lt;/a&gt;, or item held, kept or maintained by an &lt;a class=&quot;localLink&quot; href=&quot;http://schema.org/ArchiveOrganization&quot;&gt;ArchiveOrganization&lt;/a&gt;.</rdfs:comment>
        <rdfs:label xml:lang="en">archiveHeld</rdfs:label>
        <schema:category xml:lang="en">issue-1758</schema:category>
        <schema:domainIncludes rdf:resource="https://schema.org/ArchiveOrganization"/>
        <schema:inverseOf rdf:resource="https://schema.org/holdingArchive"/>
        <schema:isPartOf rdf:resource="http://pending.schema.org"/>
        <schema:rangeIncludes rdf:resource="https://schema.org/ArchiveComponent"/>
        <schema:source rdf:resource="https://github.com/schemaorg/schemaorg/issues/1758"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://schema.org/area">
        <rdfs:comment>The area within which users can expect to reach the broadcast service.</rdfs:comment>
