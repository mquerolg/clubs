        <schema1:domainIncludes rdf:resource="http://schema.org/SoftwareSourceCode"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/URL"/>
        <rdfs:comment>Link to the repository where the un-compiled, human readable code and related code is located (SVN, github, CodePlex).</rdfs:comment>
        <rdfs:label>codeRepository</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://schema.org/codeSampleType">
        <schema1:domainIncludes rdf:resource="http://schema.org/SoftwareSourceCode"/>
        <schema1:rangeIncludes rdf:resource="http://schema.org/Text"/>
