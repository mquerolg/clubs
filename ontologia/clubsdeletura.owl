    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>schema1:MedicalStudyStatus</AbbreviatedIRI>
        <Literal>The status of a medical study. Enumerated type.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>schema1:MedicalStudyStatus</AbbreviatedIRI>
        <Literal>MedicalStudyStatus</Literal>
    </AnnotationAssertion>
