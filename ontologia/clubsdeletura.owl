AnnotationAssertion(schema1:isPartOf schema1:DietarySupplement <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DietarySupplement "A product taken by mouth that contains a dietary ingredient intended to supplement the diet. Dietary ingredients may include vitamins, minerals, herbs or other botanicals, amino acids, and substances such as enzymes, organ tissues, glandulars and metabolites.")
AnnotationAssertion(rdfs:label schema1:DietarySupplement "DietarySupplement")
SubClassOf(schema1:DietarySupplement schema1:Substance)

