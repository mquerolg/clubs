AnnotationAssertion(rdfs:label schema1:NoteDigitalDocument "NoteDigitalDocument")
SubClassOf(schema1:NoteDigitalDocument schema1:DigitalDocument)

# Class: schema1:Number (Number)

AnnotationAssertion(rdfs:comment schema1:Number "Data type: Number.<br/><br/>

Usage guidelines:<br/><br/>

<ul>
<li>Use values from 0123456789 (Unicode 'DIGIT ZERO' (U+0030) to 'DIGIT NINE' (U+0039)) rather than superficially similiar Unicode symbols.</li>
<li>Use '.' (Unicode 'FULL STOP' (U+002E)) rather than ',' to indicate a decimal point. Avoid using these symbols as a readability separator.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:Number "Number")

# Class: schema1:Nursing (Nursing)

AnnotationAssertion(schema1:isPartOf schema1:Nursing <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Nursing "A health profession of a person formally educated and trained in the care of the sick or infirm person.")
AnnotationAssertion(rdfs:label schema1:Nursing "Nursing")
SubClassOf(schema1:Nursing schema1:MedicalBusiness)

