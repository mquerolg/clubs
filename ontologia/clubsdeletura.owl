# Class: schema1:Article (Article)

AnnotationAssertion(schema1:source schema1:Article <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_rNews>)
AnnotationAssertion(rdfs:comment schema1:Article "An article, such as a news article or piece of investigative report. Newspapers and magazines have articles of many different types and this is intended to cover them all.<br/><br/>

See also <a href=\"https://blog.schema.org/2014/09/02/schema-org-support-for-bibliographic-relationships-and-periodicals/\">blog post</a>.")
AnnotationAssertion(rdfs:label schema1:Article "Article")
SubClassOf(schema1:Article schema1:CreativeWork)

# Class: schema1:AskAction (AskAction)

AnnotationAssertion(rdfs:comment schema1:AskAction "The act of posing a question / favor to someone.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/ReplyAction\">ReplyAction</a>: Appears generally as a response to AskAction.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:AskAction "AskAction")
SubClassOf(schema1:AskAction schema1:CommunicateAction)

# Class: schema1:AskPublicNewsArticle (AskPublicNewsArticle)

