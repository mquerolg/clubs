AnnotationAssertion(rdfs:comment schema1:Distance "Properties that take Distances as values are of the form '&lt;Number&gt; &lt;Length unit of measure&gt;'. E.g., '7 ft'.")
AnnotationAssertion(rdfs:label schema1:Distance "Distance")
SubClassOf(schema1:Distance schema1:Quantity)

