AnnotationAssertion(rdfs:label schema1:DiagnosticProcedure "DiagnosticProcedure")
SubClassOf(schema1:DiagnosticProcedure schema1:MedicalProcedure)

# Class: schema1:Diet (Diet)

AnnotationAssertion(schema1:isPartOf schema1:Diet <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Diet "A strategy of regulating the intake of food to achieve or maintain a specific health-related goal.")
