AnnotationAssertion(rdfs:comment schema1:DriveWheelConfigurationValue "A value indicating which roadwheels will receive torque.")
AnnotationAssertion(rdfs:label schema1:DriveWheelConfigurationValue "DriveWheelConfigurationValue")
SubClassOf(schema1:DriveWheelConfigurationValue schema1:QualitativeValue)

# Class: schema1:Drug (Drug)

AnnotationAssertion(schema1:isPartOf schema1:Drug <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Drug "A chemical or biologic substance, used as a medical therapy, that has a physiological effect on an organism. Here the term drug is used interchangeably with the term medicine although clinical knowledge make a clear difference between them.")
AnnotationAssertion(rdfs:label schema1:Drug "Drug")
SubClassOf(schema1:Drug schema1:Substance)

# Class: schema1:DrugClass (DrugClass)

AnnotationAssertion(schema1:isPartOf schema1:DrugClass <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugClass "A class of medical drugs, e.g., statins. Classes can represent general pharmacological class, common mechanisms of action, common physiological effects, etc.")
AnnotationAssertion(rdfs:label schema1:DrugClass "DrugClass")
SubClassOf(schema1:DrugClass schema1:MedicalEntity)

# Class: schema1:DrugCost (DrugCost)

AnnotationAssertion(schema1:isPartOf schema1:DrugCost <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugCost "The cost per unit of a medical drug. Note that this type is not meant to represent the price in an offer of a drug for sale; see the Offer type for that. This type will typically be used to tag wholesale or average retail cost of a drug, or maximum reimbursable cost. Costs of medical drugs vary widely depending on how and where they are paid for, so while this type captures some of the variables, costs should be used with caution by consumers of this schema's markup.")
AnnotationAssertion(rdfs:label schema1:DrugCost "DrugCost")
SubClassOf(schema1:DrugCost schema1:MedicalEntity)

# Class: schema1:DrugCostCategory (DrugCostCategory)

AnnotationAssertion(schema1:isPartOf schema1:DrugCostCategory <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugCostCategory "Enumerated categories of medical drug costs.")
AnnotationAssertion(rdfs:label schema1:DrugCostCategory "DrugCostCategory")
SubClassOf(schema1:DrugCostCategory schema1:MedicalEnumeration)

# Class: schema1:DrugLegalStatus (DrugLegalStatus)

AnnotationAssertion(schema1:isPartOf schema1:DrugLegalStatus <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugLegalStatus "The legal availability status of a medical drug.")
AnnotationAssertion(rdfs:label schema1:DrugLegalStatus "DrugLegalStatus")
SubClassOf(schema1:DrugLegalStatus schema1:MedicalIntangible)

# Class: schema1:DrugPregnancyCategory (DrugPregnancyCategory)

AnnotationAssertion(schema1:isPartOf schema1:DrugPregnancyCategory <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugPregnancyCategory "Categories that represent an assessment of the risk of fetal injury due to a drug or pharmaceutical used as directed by the mother during pregnancy.")
AnnotationAssertion(rdfs:label schema1:DrugPregnancyCategory "DrugPregnancyCategory")
SubClassOf(schema1:DrugPregnancyCategory schema1:MedicalEnumeration)

# Class: schema1:DrugPrescriptionStatus (DrugPrescriptionStatus)

AnnotationAssertion(schema1:isPartOf schema1:DrugPrescriptionStatus <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugPrescriptionStatus "Indicates whether this drug is available by prescription or over-the-counter.")
AnnotationAssertion(rdfs:label schema1:DrugPrescriptionStatus "DrugPrescriptionStatus")
SubClassOf(schema1:DrugPrescriptionStatus schema1:MedicalEnumeration)

# Class: schema1:DrugStrength (DrugStrength)

AnnotationAssertion(schema1:isPartOf schema1:DrugStrength <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:DrugStrength "A specific strength in which a medical drug is available in a specific country.")
AnnotationAssertion(rdfs:label schema1:DrugStrength "DrugStrength")
SubClassOf(schema1:DrugStrength schema1:MedicalIntangible)

# Class: schema1:DryCleaningOrLaundry (DryCleaningOrLaundry)

AnnotationAssertion(rdfs:comment schema1:DryCleaningOrLaundry "A dry-cleaning business.")
AnnotationAssertion(rdfs:label schema1:DryCleaningOrLaundry "DryCleaningOrLaundry")
SubClassOf(schema1:DryCleaningOrLaundry schema1:LocalBusiness)

