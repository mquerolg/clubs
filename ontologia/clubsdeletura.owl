AnnotationAssertion(schema1:rangeIncludes schema1:geoCoveredBy schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoCoveredBy schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoCoveredBy "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that covers it. As defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>.")
AnnotationAssertion(rdfs:label schema1:geoCoveredBy "geoCoveredBy")
AnnotationAssertion(schema1:domainIncludes schema1:geoCovers schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoCovers schema1:Place)
AnnotationAssertion(schema1:rangeIncludes schema1:geoCovers schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoCovers schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoCovers "Represents a relationship between two geometries (or the places they represent), relating a covering geometry to a covered geometry. \"Every point of b is a point of (the interior or boundary of) a\". As defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>.")
AnnotationAssertion(rdfs:label schema1:geoCovers "geoCovers")
AnnotationAssertion(schema1:domainIncludes schema1:geoCrosses schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoCrosses schema1:Place)
AnnotationAssertion(schema1:rangeIncludes schema1:geoCrosses schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoCrosses schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoCrosses "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that crosses it: \"a crosses b: they have some but not all interior points in common, and the dimension of the intersection is less than that of at least one of them\". As defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>.")
AnnotationAssertion(rdfs:label schema1:geoCrosses "geoCrosses")
AnnotationAssertion(schema1:domainIncludes schema1:geoDisjoint schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoDisjoint schema1:Place)
AnnotationAssertion(schema1:rangeIncludes schema1:geoDisjoint schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoDisjoint schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoDisjoint "Represents spatial relations in which two geometries (or the places they represent) are topologically disjoint: they have no point in common. They form a set of disconnected geometries.\" (a symmetric relationship, as defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>)")
AnnotationAssertion(rdfs:label schema1:geoDisjoint "geoDisjoint")
AnnotationAssertion(schema1:domainIncludes schema1:geoEquals schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoEquals schema1:Place)
AnnotationAssertion(schema1:rangeIncludes schema1:geoEquals schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoEquals schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoEquals "Represents spatial relations in which two geometries (or the places they represent) are topologically equal, as defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>. \"Two geometries are topologically equal if their interiors intersect and no part of the interior or boundary of one geometry intersects the exterior of the other\" (a symmetric relationship)")
AnnotationAssertion(rdfs:label schema1:geoEquals "geoEquals")
AnnotationAssertion(schema1:domainIncludes schema1:geoIntersects schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoIntersects schema1:Place)
AnnotationAssertion(schema1:rangeIncludes schema1:geoIntersects schema1:GeospatialGeometry)
AnnotationAssertion(schema1:rangeIncludes schema1:geoIntersects schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoIntersects "Represents spatial relations in which two geometries (or the places they represent) have at least one point in common. As defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>.")
AnnotationAssertion(rdfs:label schema1:geoIntersects "geoIntersects")
