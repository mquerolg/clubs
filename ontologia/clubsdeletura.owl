AnnotationAssertion(schema1:source schema1:legislationDateVersion <https://github.com/schemaorg/schemaorg/issues/1156>)
AnnotationAssertion(rdfs:comment schema1:legislationDateVersion "The point-in-time at which the provided description of the legislation is valid (e.g. : when looking at the law on the 2016-04-07 (= dateVersion), I get the consolidation of 2015-04-12 of the \"National Insurance Contributions Act 2015\")")
AnnotationAssertion(rdfs:label schema1:legislationDateVersion "legislationDateVersion")
AnnotationAssertion(skos:exactMatch schema1:legislationDateVersion eli:version_date)
