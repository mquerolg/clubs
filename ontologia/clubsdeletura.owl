# Class: schema1:VirtualLocation (VirtualLocation)

AnnotationAssertion(schema1:category schema1:VirtualLocation "issue-1842")
AnnotationAssertion(schema1:isPartOf schema1:VirtualLocation <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:VirtualLocation <https://github.com/schemaorg/schemaorg/issues/1842>)
AnnotationAssertion(rdfs:comment schema1:VirtualLocation "An online or virtual location for attending events. For example, one may attend an online seminar or educational event. While a virtual location may be used as the location of an event, virtual locations should not be confused with physical locations in the real world.")
AnnotationAssertion(rdfs:label schema1:VirtualLocation "VirtualLocation")
SubClassOf(schema1:VirtualLocation schema1:Intangible)

# Class: schema1:VisualArtsEvent (VisualArtsEvent)

AnnotationAssertion(rdfs:comment schema1:VisualArtsEvent "Event type: Visual arts event.")
AnnotationAssertion(rdfs:label schema1:VisualArtsEvent "VisualArtsEvent")
