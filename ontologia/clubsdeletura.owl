AnnotationAssertion(rdfs:comment schema1:DietNutrition "Dietetic and nutrition as a medical speciality.")
AnnotationAssertion(rdfs:label schema1:DietNutrition "DietNutrition")
SubClassOf(schema1:DietNutrition schema1:MedicalBusiness)

