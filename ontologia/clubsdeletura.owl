AnnotationAssertion(schema1:domainIncludes schema1:gtin14 schema1:Demand)
AnnotationAssertion(schema1:domainIncludes schema1:gtin14 schema1:Offer)
AnnotationAssertion(schema1:domainIncludes schema1:gtin14 schema1:Product)
AnnotationAssertion(schema1:rangeIncludes schema1:gtin14 schema1:Text)
AnnotationAssertion(schema1:source schema1:gtin14 <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms>)
AnnotationAssertion(rdfs:comment schema1:gtin14 "The GTIN-14 code of the product, or the product to which the offer refers. See <a href=\"http://www.gs1.org/barcodes/technical/idkeys/gtin\">GS1 GTIN Summary</a> for more details.")
AnnotationAssertion(rdfs:label schema1:gtin14 "gtin14")
SubAnnotationPropertyOf(schema1:gtin14 schema1:gtin)
SubAnnotationPropertyOf(schema1:gtin14 schema1:identifier)

