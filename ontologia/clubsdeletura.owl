AnnotationAssertion(schema1:rangeIncludes schema1:geoOverlaps schema1:Place)
AnnotationAssertion(rdfs:comment schema1:geoOverlaps "Represents a relationship between two geometries (or the places they represent), relating a geometry to another that geospatially overlaps it, i.e. they have some but not all points in common. As defined in <a href=\"https://en.wikipedia.org/wiki/DE-9IM\">DE-9IM</a>.")
AnnotationAssertion(rdfs:label schema1:geoOverlaps "geoOverlaps")
