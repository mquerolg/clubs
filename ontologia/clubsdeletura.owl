    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>schema1:MedicalObservationalStudyDesign</AbbreviatedIRI>
        <Literal>MedicalObservationalStudyDesign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
