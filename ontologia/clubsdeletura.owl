# Class: schema1:InfectiousAgentClass (InfectiousAgentClass)

AnnotationAssertion(schema1:isPartOf schema1:InfectiousAgentClass <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:InfectiousAgentClass "Classes of agents or pathogens that transmit infectious diseases. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:InfectiousAgentClass "InfectiousAgentClass")
SubClassOf(schema1:InfectiousAgentClass schema1:MedicalEnumeration)

# Class: schema1:InfectiousDisease (InfectiousDisease)

AnnotationAssertion(schema1:isPartOf schema1:InfectiousDisease <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:InfectiousDisease "An infectious disease is a clinically evident human disease resulting from the presence of pathogenic microbial agents, like pathogenic viruses, pathogenic bacteria, fungi, protozoa, multicellular parasites, and prions. To be considered an infectious disease, such pathogens are known to be able to cause this disease.")
AnnotationAssertion(rdfs:label schema1:InfectiousDisease "InfectiousDisease")
SubClassOf(schema1:InfectiousDisease schema1:MedicalCondition)

# Class: schema1:InformAction (InformAction)

AnnotationAssertion(rdfs:comment schema1:InformAction "The act of notifying someone of information pertinent to them, with no expectation of a response.")
AnnotationAssertion(rdfs:label schema1:InformAction "InformAction")
SubClassOf(schema1:InformAction schema1:CommunicateAction)

# Class: schema1:InsertAction (InsertAction)

AnnotationAssertion(rdfs:comment schema1:InsertAction "The act of adding at a specific location in an ordered collection.")
AnnotationAssertion(rdfs:label schema1:InsertAction "InsertAction")
SubClassOf(schema1:InsertAction schema1:AddAction)

# Class: schema1:InstallAction (InstallAction)

AnnotationAssertion(rdfs:comment schema1:InstallAction "The act of installing an application.")
AnnotationAssertion(rdfs:label schema1:InstallAction "InstallAction")
SubClassOf(schema1:InstallAction schema1:ConsumeAction)

# Class: schema1:InsuranceAgency (InsuranceAgency)

AnnotationAssertion(rdfs:comment schema1:InsuranceAgency "An Insurance agency.")
AnnotationAssertion(rdfs:label schema1:InsuranceAgency "InsuranceAgency")
SubClassOf(schema1:InsuranceAgency schema1:FinancialService)

# Class: schema1:Intangible (Intangible)

AnnotationAssertion(rdfs:comment schema1:Intangible "A utility class that serves as the umbrella for a number of 'intangible' things such as quantities, structured values, etc.")
AnnotationAssertion(rdfs:label schema1:Intangible "Intangible")
SubClassOf(schema1:Intangible schema1:Thing)

# Class: schema1:Integer (Integer)

AnnotationAssertion(rdfs:comment schema1:Integer "Data type: Integer.")
AnnotationAssertion(rdfs:label schema1:Integer "Integer")
SubClassOf(schema1:Integer schema1:Number)

# Class: schema1:InteractAction (InteractAction)

AnnotationAssertion(rdfs:comment schema1:InteractAction "The act of interacting with another person or organization.")
AnnotationAssertion(rdfs:label schema1:InteractAction "InteractAction")
SubClassOf(schema1:InteractAction schema1:Action)

# Class: schema1:InteractionCounter (InteractionCounter)

AnnotationAssertion(rdfs:comment schema1:InteractionCounter "A summary of how users have interacted with this CreativeWork. In most cases, authors will use a subtype to specify the specific type of interaction.")
AnnotationAssertion(rdfs:label schema1:InteractionCounter "InteractionCounter")
SubClassOf(schema1:InteractionCounter schema1:StructuredValue)

# Class: schema1:InternetCafe (InternetCafe)

AnnotationAssertion(rdfs:comment schema1:InternetCafe "An internet cafe.")
AnnotationAssertion(rdfs:label schema1:InternetCafe "InternetCafe")
SubClassOf(schema1:InternetCafe schema1:LocalBusiness)

# Class: schema1:InvestmentFund (InvestmentFund)

AnnotationAssertion(schema1:category schema1:InvestmentFund "issue-1253")
AnnotationAssertion(schema1:isPartOf schema1:InvestmentFund <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:InvestmentFund <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FIBO>)
AnnotationAssertion(schema1:source schema1:InvestmentFund <https://github.com/schemaorg/schemaorg/issues/1253>)
AnnotationAssertion(rdfs:comment schema1:InvestmentFund "A company or fund that gathers capital from a number of investors to create a pool of money that is then re-invested into stocks, bonds and other assets.")
AnnotationAssertion(rdfs:label schema1:InvestmentFund "InvestmentFund")
SubClassOf(schema1:InvestmentFund schema1:InvestmentOrDeposit)

# Class: schema1:InvestmentOrDeposit (InvestmentOrDeposit)

AnnotationAssertion(schema1:source schema1:InvestmentOrDeposit <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FIBO>)
AnnotationAssertion(rdfs:comment schema1:InvestmentOrDeposit "A type of financial product that typically requires the client to transfer funds to a financial service in return for potential beneficial financial return.")
AnnotationAssertion(rdfs:label schema1:InvestmentOrDeposit "InvestmentOrDeposit")
SubClassOf(schema1:InvestmentOrDeposit schema1:FinancialProduct)

# Class: schema1:InviteAction (InviteAction)

AnnotationAssertion(rdfs:comment schema1:InviteAction "The act of asking someone to attend an event. Reciprocal of RsvpAction.")
AnnotationAssertion(rdfs:label schema1:InviteAction "InviteAction")
SubClassOf(schema1:InviteAction schema1:CommunicateAction)

# Class: schema1:Invoice (Invoice)

AnnotationAssertion(rdfs:comment schema1:Invoice "A statement of the money due for goods or services; a bill.")
AnnotationAssertion(rdfs:label schema1:Invoice "Invoice")
SubClassOf(schema1:Invoice schema1:Intangible)

# Class: schema1:ItemAvailability (ItemAvailability)

AnnotationAssertion(rdfs:comment schema1:ItemAvailability "A list of possible product availability options.")
AnnotationAssertion(rdfs:label schema1:ItemAvailability "ItemAvailability")
SubClassOf(schema1:ItemAvailability schema1:Enumeration)

# Class: schema1:ItemList (ItemList)

AnnotationAssertion(rdfs:comment schema1:ItemList "A list of items of any sort&#x2014;for example, Top 10 Movies About Weathermen, or Top 100 Party Songs. Not to be confused with HTML lists, which are often used only for formatting.")
AnnotationAssertion(rdfs:label schema1:ItemList "ItemList")
SubClassOf(schema1:ItemList schema1:Intangible)

# Class: schema1:ItemListOrderType (ItemListOrderType)

AnnotationAssertion(rdfs:comment schema1:ItemListOrderType "Enumerated for values for itemListOrder for indicating how an ordered ItemList is organized.")
AnnotationAssertion(rdfs:label schema1:ItemListOrderType "ItemListOrderType")
SubClassOf(schema1:ItemListOrderType schema1:Enumeration)

# Class: schema1:ItemPage (ItemPage)

AnnotationAssertion(rdfs:comment schema1:ItemPage "A page devoted to a single item, such as a particular product or hotel.")
AnnotationAssertion(rdfs:label schema1:ItemPage "ItemPage")
SubClassOf(schema1:ItemPage schema1:WebPage)

# Class: schema1:JewelryStore (JewelryStore)

AnnotationAssertion(rdfs:comment schema1:JewelryStore "A jewelry store.")
AnnotationAssertion(rdfs:label schema1:JewelryStore "JewelryStore")
SubClassOf(schema1:JewelryStore schema1:Store)

# Class: schema1:JobPosting (JobPosting)

AnnotationAssertion(rdfs:comment schema1:JobPosting "A listing that describes a job opening in a certain organization.")
AnnotationAssertion(rdfs:label schema1:JobPosting "JobPosting")
SubClassOf(schema1:JobPosting schema1:Intangible)

# Class: schema1:JoinAction (JoinAction)

AnnotationAssertion(rdfs:comment schema1:JoinAction "An agent joins an event/group with participants/friends at a location.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/RegisterAction\">RegisterAction</a>: Unlike RegisterAction, JoinAction refers to joining a group/team of people.</li>
<li><a class=\"localLink\" href=\"http://schema.org/SubscribeAction\">SubscribeAction</a>: Unlike SubscribeAction, JoinAction does not imply that you'll be receiving updates.</li>
<li><a class=\"localLink\" href=\"http://schema.org/FollowAction\">FollowAction</a>: Unlike FollowAction, JoinAction does not imply that you'll be polling for updates.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:JoinAction "JoinAction")
SubClassOf(schema1:JoinAction schema1:InteractAction)

# Class: schema1:Joint (Joint)

AnnotationAssertion(schema1:isPartOf schema1:Joint <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Joint "The anatomical location at which two or more bones make contact.")
AnnotationAssertion(rdfs:label schema1:Joint "Joint")
SubClassOf(schema1:Joint schema1:AnatomicalStructure)

# Class: schema1:LakeBodyOfWater (LakeBodyOfWater)

AnnotationAssertion(rdfs:comment schema1:LakeBodyOfWater "A lake (for example, Lake Pontrachain).")
AnnotationAssertion(rdfs:label schema1:LakeBodyOfWater "LakeBodyOfWater")
SubClassOf(schema1:LakeBodyOfWater schema1:BodyOfWater)

# Class: schema1:Landform (Landform)

AnnotationAssertion(rdfs:comment schema1:Landform "A landform or physical feature.  Landform elements include mountains, plains, lakes, rivers, seascape and oceanic waterbody interface features such as bays, peninsulas, seas and so forth, including sub-aqueous terrain features such as submersed mountain ranges, volcanoes, and the great ocean basins.")
AnnotationAssertion(rdfs:label schema1:Landform "Landform")
SubClassOf(schema1:Landform schema1:Place)

# Class: schema1:LandmarksOrHistoricalBuildings (LandmarksOrHistoricalBuildings)

AnnotationAssertion(rdfs:comment schema1:LandmarksOrHistoricalBuildings "An historical landmark or building.")
AnnotationAssertion(rdfs:label schema1:LandmarksOrHistoricalBuildings "LandmarksOrHistoricalBuildings")
SubClassOf(schema1:LandmarksOrHistoricalBuildings schema1:Place)

# Class: schema1:Language (Language)

AnnotationAssertion(rdfs:comment schema1:Language "Natural languages such as Spanish, Tamil, Hindi, English, etc. Formal language code tags expressed in <a href=\"https://en.wikipedia.org/wiki/IETF_language_tag\">BCP 47</a> can be used via the <a class=\"localLink\" href=\"http://schema.org/alternateName\">alternateName</a> property. The Language type previously also covered programming languages such as Scheme and Lisp, which are now best represented using <a class=\"localLink\" href=\"http://schema.org/ComputerLanguage\">ComputerLanguage</a>.")
AnnotationAssertion(rdfs:label schema1:Language "Language")
SubClassOf(schema1:Language schema1:Intangible)

# Class: schema1:LearningResource (LearningResource)

AnnotationAssertion(schema1:category schema1:LearningResource "issue-1401")
AnnotationAssertion(schema1:isPartOf schema1:LearningResource <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LearningResource <https://github.com/schemaorg/schemaorg/issues/1401>)
AnnotationAssertion(rdfs:comment schema1:LearningResource "The LearningResource type can be used to indicate <a class=\"localLink\" href=\"http://schema.org/CreativeWork\">CreativeWork</a>s (whether physical or digital) that have a particular and explicit orientation towards learning, education, skill acquisition, and other educational purposes.<br/><br/>

<a class=\"localLink\" href=\"http://schema.org/LearningResource\">LearningResource</a> is expected to be used as an addition to a primary type such as <a class=\"localLink\" href=\"http://schema.org/Book\">Book</a>, <a class=\"localLink\" href=\"http://schema.org/Video\">Video</a>, <a class=\"localLink\" href=\"http://schema.org/Product\">Product</a> etc.<br/><br/>

<a class=\"localLink\" href=\"http://schema.org/EducationEvent\">EducationEvent</a> serves a similar purpose for event-like things (e.g. a <a class=\"localLink\" href=\"http://schema.org/Trip\">Trip</a>). A <a class=\"localLink\" href=\"http://schema.org/LearningResource\">LearningResource</a> may be created as a result of an <a class=\"localLink\" href=\"http://schema.org/EducationEvent\">EducationEvent</a>, for example by recording one.")
AnnotationAssertion(rdfs:label schema1:LearningResource "LearningResource")
SubClassOf(schema1:LearningResource schema1:CreativeWork)

# Class: schema1:LeaveAction (LeaveAction)

AnnotationAssertion(rdfs:comment schema1:LeaveAction "An agent leaves an event / group with participants/friends at a location.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/JoinAction\">JoinAction</a>: The antonym of LeaveAction.</li>
<li><a class=\"localLink\" href=\"http://schema.org/UnRegisterAction\">UnRegisterAction</a>: Unlike UnRegisterAction, LeaveAction implies leaving a group/team of people rather than a service.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:LeaveAction "LeaveAction")
SubClassOf(schema1:LeaveAction schema1:InteractAction)

# Class: schema1:LegalForceStatus (LegalForceStatus)

AnnotationAssertion(schema1:category schema1:LegalForceStatus "issue-1156")
AnnotationAssertion(schema1:isPartOf schema1:LegalForceStatus <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LegalForceStatus <http://publications.europa.eu/mdr/eli/index.html>)
AnnotationAssertion(schema1:source schema1:LegalForceStatus <https://github.com/schemaorg/schemaorg/issues/1156>)
AnnotationAssertion(rdfs:comment schema1:LegalForceStatus "A list of possible statuses for the legal force of a legislation.")
AnnotationAssertion(rdfs:label schema1:LegalForceStatus "LegalForceStatus")
AnnotationAssertion(skos:exactMatch schema1:LegalForceStatus eli:InForce)
SubClassOf(schema1:LegalForceStatus schema1:StatusEnumeration)

# Class: schema1:LegalService (LegalService)

AnnotationAssertion(rdfs:comment schema1:LegalService "A LegalService is a business that provides legally-oriented services, advice and representation, e.g. law firms.<br/><br/>

As a <a class=\"localLink\" href=\"http://schema.org/LocalBusiness\">LocalBusiness</a> it can be described as a <a class=\"localLink\" href=\"http://schema.org/provider\">provider</a> of one or more <a class=\"localLink\" href=\"http://schema.org/Service\">Service</a>(s).")
AnnotationAssertion(rdfs:label schema1:LegalService "LegalService")
SubClassOf(schema1:LegalService schema1:LocalBusiness)

# Class: schema1:LegalValueLevel (LegalValueLevel)

AnnotationAssertion(schema1:category schema1:LegalValueLevel "issue-1156")
AnnotationAssertion(schema1:isPartOf schema1:LegalValueLevel <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LegalValueLevel <http://publications.europa.eu/mdr/eli/index.html>)
AnnotationAssertion(schema1:source schema1:LegalValueLevel <https://github.com/schemaorg/schemaorg/issues/1156>)
AnnotationAssertion(rdfs:comment schema1:LegalValueLevel "A list of possible levels for the legal validity of a legislation.")
AnnotationAssertion(rdfs:label schema1:LegalValueLevel "LegalValueLevel")
AnnotationAssertion(skos:closeMatch schema1:LegalValueLevel eli:LegalValue)
SubClassOf(schema1:LegalValueLevel schema1:Enumeration)

# Class: schema1:Legislation (Legislation)

AnnotationAssertion(schema1:category schema1:Legislation "issue-1156")
AnnotationAssertion(schema1:isPartOf schema1:Legislation <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:Legislation <http://publications.europa.eu/mdr/eli/index.html>)
AnnotationAssertion(schema1:source schema1:Legislation <https://github.com/schemaorg/schemaorg/issues/1156>)
AnnotationAssertion(rdfs:comment schema1:Legislation "A legal document such as an act, decree, bill, etc. (enforceable or not) or a component of a legal act (like an article).")
AnnotationAssertion(rdfs:label schema1:Legislation "Legislation")
AnnotationAssertion(skos:closeMatch schema1:Legislation eli:LegalExpression)
AnnotationAssertion(skos:closeMatch schema1:Legislation eli:LegalResource)
SubClassOf(schema1:Legislation schema1:CreativeWork)

# Class: schema1:LegislationObject (LegislationObject)

AnnotationAssertion(schema1:category schema1:LegislationObject "issue-1156")
AnnotationAssertion(schema1:isPartOf schema1:LegislationObject <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LegislationObject <http://publications.europa.eu/mdr/eli/index.html>)
AnnotationAssertion(schema1:source schema1:LegislationObject <https://github.com/schemaorg/schemaorg/issues/1156>)
AnnotationAssertion(rdfs:comment schema1:LegislationObject "A specific object or file containing a Legislation. Note that the same Legislation can be published in multiple files. For example, a digitally signed PDF, a plain PDF and an HTML version.")
AnnotationAssertion(rdfs:label schema1:LegislationObject "LegislationObject")
AnnotationAssertion(skos:closeMatch schema1:LegislationObject eli:Format)
SubClassOf(schema1:LegislationObject schema1:Legislation)
SubClassOf(schema1:LegislationObject schema1:MediaObject)

# Class: schema1:LegislativeBuilding (LegislativeBuilding)

AnnotationAssertion(rdfs:comment schema1:LegislativeBuilding "A legislative building&#x2014;for example, the state capitol.")
AnnotationAssertion(rdfs:label schema1:LegislativeBuilding "LegislativeBuilding")
SubClassOf(schema1:LegislativeBuilding schema1:GovernmentBuilding)

# Class: schema1:LendAction (LendAction)

AnnotationAssertion(rdfs:comment schema1:LendAction "The act of providing an object under an agreement that it will be returned at a later date. Reciprocal of BorrowAction.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/BorrowAction\">BorrowAction</a>: Reciprocal of LendAction.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:LendAction "LendAction")
SubClassOf(schema1:LendAction schema1:TransferAction)

# Class: schema1:Library (Library)

AnnotationAssertion(rdfs:comment schema1:Library "A library.")
AnnotationAssertion(rdfs:label schema1:Library "Library")
SubClassOf(schema1:Library schema1:LocalBusiness)

# Class: schema1:LibrarySystem (LibrarySystem)

AnnotationAssertion(schema1:category schema1:LibrarySystem "issue-1495")
AnnotationAssertion(schema1:isPartOf schema1:LibrarySystem <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LibrarySystem <https://github.com/schemaorg/schemaorg/issues/1495>)
AnnotationAssertion(rdfs:comment schema1:LibrarySystem "A <a class=\"localLink\" href=\"http://schema.org/LibrarySystem\">LibrarySystem</a> is a collaborative system amongst several libraries.")
AnnotationAssertion(rdfs:label schema1:LibrarySystem "LibrarySystem")
SubClassOf(schema1:LibrarySystem schema1:Organization)

# Class: schema1:LifestyleModification (LifestyleModification)

AnnotationAssertion(schema1:isPartOf schema1:LifestyleModification <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:LifestyleModification "A process of care involving exercise, changes to diet, fitness routines, and other lifestyle changes aimed at improving a health condition.")
AnnotationAssertion(rdfs:label schema1:LifestyleModification "LifestyleModification")
SubClassOf(schema1:LifestyleModification schema1:MedicalEntity)

# Class: schema1:Ligament (Ligament)

AnnotationAssertion(schema1:isPartOf schema1:Ligament <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Ligament "A short band of tough, flexible, fibrous connective tissue that functions to connect multiple bones, cartilages, and structurally support joints.")
AnnotationAssertion(rdfs:label schema1:Ligament "Ligament")
SubClassOf(schema1:Ligament schema1:AnatomicalStructure)

# Class: schema1:LikeAction (LikeAction)

AnnotationAssertion(rdfs:comment schema1:LikeAction "The act of expressing a positive sentiment about the object. An agent likes an object (a proposition, topic or theme) with participants.")
AnnotationAssertion(rdfs:label schema1:LikeAction "LikeAction")
SubClassOf(schema1:LikeAction schema1:ReactAction)

# Class: schema1:LinkRole (LinkRole)

AnnotationAssertion(schema1:category schema1:LinkRole "issue-1045")
AnnotationAssertion(schema1:isPartOf schema1:LinkRole <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:LinkRole <https://github.com/schemaorg/schemaorg/issues/1045>)
AnnotationAssertion(rdfs:comment schema1:LinkRole "A Role that represents a Web link e.g. as expressed via the 'url' property. Its linkRelationship property can indicate URL-based and plain textual link types e.g. those in IANA link registry or others such as 'amphtml'. This structure provides a placeholder where details from HTML's link element can be represented outside of HTML, e.g. in JSON-LD feeds.")
AnnotationAssertion(rdfs:label schema1:LinkRole "LinkRole")
SubClassOf(schema1:LinkRole schema1:Role)

# Class: schema1:LiquorStore (LiquorStore)

AnnotationAssertion(rdfs:comment schema1:LiquorStore "A shop that sells alcoholic drinks such as wine, beer, whisky and other spirits.")
AnnotationAssertion(rdfs:label schema1:LiquorStore "LiquorStore")
SubClassOf(schema1:LiquorStore schema1:Store)

# Class: schema1:ListItem (ListItem)

AnnotationAssertion(rdfs:comment schema1:ListItem "An list item, e.g. a step in a checklist or how-to description.")
AnnotationAssertion(rdfs:label schema1:ListItem "ListItem")
SubClassOf(schema1:ListItem schema1:Intangible)

# Class: schema1:ListenAction (ListenAction)

AnnotationAssertion(rdfs:comment schema1:ListenAction "The act of consuming audio content.")
AnnotationAssertion(rdfs:label schema1:ListenAction "ListenAction")
SubClassOf(schema1:ListenAction schema1:ConsumeAction)

# Class: schema1:LiteraryEvent (LiteraryEvent)

AnnotationAssertion(rdfs:comment schema1:LiteraryEvent "Event type: Literary event.")
AnnotationAssertion(rdfs:label schema1:LiteraryEvent "LiteraryEvent")
SubClassOf(schema1:LiteraryEvent schema1:Event)

# Class: schema1:LiveBlogPosting (LiveBlogPosting)

AnnotationAssertion(rdfs:comment schema1:LiveBlogPosting "A blog post intended to provide a rolling textual coverage of an ongoing event through continuous updates.")
AnnotationAssertion(rdfs:label schema1:LiveBlogPosting "LiveBlogPosting")
SubClassOf(schema1:LiveBlogPosting schema1:BlogPosting)

# Class: schema1:LoanOrCredit (LoanOrCredit)

AnnotationAssertion(schema1:source schema1:LoanOrCredit <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FIBO>)
AnnotationAssertion(rdfs:comment schema1:LoanOrCredit "A financial product for the loaning of an amount of money under agreed terms and charges.")
AnnotationAssertion(rdfs:label schema1:LoanOrCredit "LoanOrCredit")
SubClassOf(schema1:LoanOrCredit schema1:FinancialProduct)

# Class: schema1:LocalBusiness (LocalBusiness)

AnnotationAssertion(rdfs:comment schema1:LocalBusiness "A particular physical business or branch of an organization. Examples of LocalBusiness include a restaurant, a particular branch of a restaurant chain, a branch of a bank, a medical practice, a club, a bowling alley, etc.")
AnnotationAssertion(rdfs:label schema1:LocalBusiness "LocalBusiness")
AnnotationAssertion(skos:closeMatch schema1:LocalBusiness <http://www.w3.org/ns/regorg#RegisteredOrganization>)
SubClassOf(schema1:LocalBusiness schema1:Organization)
SubClassOf(schema1:LocalBusiness schema1:Place)

# Class: schema1:LocationFeatureSpecification (LocationFeatureSpecification)

AnnotationAssertion(schema1:source schema1:LocationFeatureSpecification <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#STI_Accommodation_Ontology>)
AnnotationAssertion(rdfs:comment schema1:LocationFeatureSpecification "Specifies a location feature by providing a structured value representing a feature of an accommodation as a property-value pair of varying degrees of formality.")
AnnotationAssertion(rdfs:label schema1:LocationFeatureSpecification "LocationFeatureSpecification")
SubClassOf(schema1:LocationFeatureSpecification schema1:PropertyValue)

# Class: schema1:Locksmith (Locksmith)

AnnotationAssertion(rdfs:comment schema1:Locksmith "A locksmith.")
AnnotationAssertion(rdfs:label schema1:Locksmith "Locksmith")
SubClassOf(schema1:Locksmith schema1:HomeAndConstructionBusiness)

# Class: schema1:LodgingBusiness (LodgingBusiness)

AnnotationAssertion(rdfs:comment schema1:LodgingBusiness "A lodging business, such as a motel, hotel, or inn.")
AnnotationAssertion(rdfs:label schema1:LodgingBusiness "LodgingBusiness")
SubClassOf(schema1:LodgingBusiness schema1:LocalBusiness)

# Class: schema1:LodgingReservation (LodgingReservation)

AnnotationAssertion(rdfs:comment schema1:LodgingReservation "A reservation for lodging at a hotel, motel, inn, etc.<br/><br/>

Note: This type is for information about actual reservations, e.g. in confirmation emails or HTML pages with individual confirmations of reservations.")
AnnotationAssertion(rdfs:label schema1:LodgingReservation "LodgingReservation")
SubClassOf(schema1:LodgingReservation schema1:Reservation)

# Class: schema1:LoseAction (LoseAction)

AnnotationAssertion(rdfs:comment schema1:LoseAction "The act of being defeated in a competitive activity.")
AnnotationAssertion(rdfs:label schema1:LoseAction "LoseAction")
SubClassOf(schema1:LoseAction schema1:AchieveAction)

# Class: schema1:LymphaticVessel (LymphaticVessel)

AnnotationAssertion(schema1:isPartOf schema1:LymphaticVessel <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:LymphaticVessel "A type of blood vessel that specifically carries lymph fluid unidirectionally toward the heart.")
AnnotationAssertion(rdfs:label schema1:LymphaticVessel "LymphaticVessel")
SubClassOf(schema1:LymphaticVessel schema1:Vessel)

# Class: schema1:Manuscript (Manuscript)

AnnotationAssertion(schema1:category schema1:Manuscript "issue-1448")
AnnotationAssertion(schema1:isPartOf schema1:Manuscript <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:Manuscript <https://github.com/schemaorg/schemaorg/issues/1448>)
AnnotationAssertion(rdfs:comment schema1:Manuscript "A book, document, or piece of music written by hand rather than typed or printed.")
AnnotationAssertion(rdfs:label schema1:Manuscript "Manuscript")
SubClassOf(schema1:Manuscript schema1:CreativeWork)

# Class: schema1:Map (Map)

AnnotationAssertion(rdfs:comment schema1:Map "A map.")
AnnotationAssertion(rdfs:label schema1:Map "Map")
SubClassOf(schema1:Map schema1:CreativeWork)

# Class: schema1:MapCategoryType (MapCategoryType)

AnnotationAssertion(rdfs:comment schema1:MapCategoryType "An enumeration of several kinds of Map.")
AnnotationAssertion(rdfs:label schema1:MapCategoryType "MapCategoryType")
SubClassOf(schema1:MapCategoryType schema1:Enumeration)

# Class: schema1:MarryAction (MarryAction)

AnnotationAssertion(rdfs:comment schema1:MarryAction "The act of marrying a person.")
AnnotationAssertion(rdfs:label schema1:MarryAction "MarryAction")
SubClassOf(schema1:MarryAction schema1:InteractAction)

# Class: schema1:Mass (Mass)

AnnotationAssertion(rdfs:comment schema1:Mass "Properties that take Mass as values are of the form '&lt;Number&gt; &lt;Mass unit of measure&gt;'. E.g., '7 kg'.")
AnnotationAssertion(rdfs:label schema1:Mass "Mass")
SubClassOf(schema1:Mass schema1:Quantity)

# Class: schema1:MaximumDoseSchedule (MaximumDoseSchedule)

AnnotationAssertion(schema1:isPartOf schema1:MaximumDoseSchedule <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MaximumDoseSchedule "The maximum dosing schedule considered safe for a drug or supplement as recommended by an authority or by the drug/supplement's manufacturer. Capture the recommending authority in the recognizingAuthority property of MedicalEntity.")
AnnotationAssertion(rdfs:label schema1:MaximumDoseSchedule "MaximumDoseSchedule")
SubClassOf(schema1:MaximumDoseSchedule schema1:DoseSchedule)

# Class: schema1:MediaGallery (MediaGallery)

AnnotationAssertion(rdfs:comment schema1:MediaGallery "Web page type: Media gallery page. A mixed-media page that can contains media such as images, videos, and other multimedia.")
AnnotationAssertion(rdfs:label schema1:MediaGallery "MediaGallery")
SubClassOf(schema1:MediaGallery schema1:CollectionPage)

# Class: schema1:MediaManipulationRatingEnumeration (MediaManipulationRatingEnumeration)

AnnotationAssertion(schema1:category schema1:MediaManipulationRatingEnumeration "issue-2450")
AnnotationAssertion(schema1:isPartOf schema1:MediaManipulationRatingEnumeration <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:MediaManipulationRatingEnumeration <https://github.com/schemaorg/schemaorg/issues/2450>)
AnnotationAssertion(rdfs:comment schema1:MediaManipulationRatingEnumeration "(editorial work in progress, this definition is incomplete and unreviewed) MediaManipulationRatingEnumeration classifies a number of ways in which a media item (video, image, audio) can be manipulated, taking into account the context within which they are published or presented.")
AnnotationAssertion(rdfs:label schema1:MediaManipulationRatingEnumeration "MediaManipulationRatingEnumeration")
SubClassOf(schema1:MediaManipulationRatingEnumeration schema1:Enumeration)

# Class: schema1:MediaObject (MediaObject)

AnnotationAssertion(rdfs:comment schema1:MediaObject "A media object, such as an image, video, or audio object embedded in a web page or a downloadable dataset i.e. DataDownload. Note that a creative work may have many media objects associated with it on the same web page. For example, a page about a single song (MusicRecording) may have a music video (VideoObject), and a high and low bandwidth audio stream (2 AudioObject's).")
AnnotationAssertion(rdfs:label schema1:MediaObject "MediaObject")
SubClassOf(schema1:MediaObject schema1:CreativeWork)

# Class: schema1:MediaReview (MediaReview)

AnnotationAssertion(schema1:category schema1:MediaReview "issue-2450")
AnnotationAssertion(schema1:isPartOf schema1:MediaReview <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:MediaReview <https://github.com/schemaorg/schemaorg/issues/2450>)
AnnotationAssertion(rdfs:comment schema1:MediaReview "(editorial work in progress, this definition is incomplete and unreviewed)
    A <a class=\"localLink\" href=\"http://schema.org/MediaReview\">MediaReview</a> is a more specialized form of Review dedicated to the evaluation of media content online, typically in the context of fact-checking and misinformation.
    For more general reviews of media in the broader sense, use <a class=\"localLink\" href=\"http://schema.org/UserReview\">UserReview</a>, <a class=\"localLink\" href=\"http://schema.org/CriticReview\">CriticReview</a> or other <a class=\"localLink\" href=\"http://schema.org/Review\">Review</a> types.")
AnnotationAssertion(rdfs:label schema1:MediaReview "MediaReview")
SubClassOf(schema1:MediaReview schema1:Review)

# Class: schema1:MediaSubscription (MediaSubscription)

AnnotationAssertion(schema1:category schema1:MediaSubscription "issue-1741")
AnnotationAssertion(schema1:source schema1:MediaSubscription <https://github.com/schemaorg/schemaorg/issues/1741>)
AnnotationAssertion(rdfs:comment schema1:MediaSubscription "A subscription which allows a user to access media including audio, video, books, etc.")
AnnotationAssertion(rdfs:label schema1:MediaSubscription "MediaSubscription")
SubClassOf(schema1:MediaSubscription schema1:Intangible)

# Class: schema1:MedicalAudience (MedicalAudience)

AnnotationAssertion(schema1:isPartOf schema1:MedicalAudience <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalAudience "Target audiences for medical web pages.")
AnnotationAssertion(rdfs:label schema1:MedicalAudience "MedicalAudience")
SubClassOf(schema1:MedicalAudience schema1:Audience)
SubClassOf(schema1:MedicalAudience schema1:PeopleAudience)

# Class: schema1:MedicalAudienceType (MedicalAudienceType)

AnnotationAssertion(schema1:isPartOf schema1:MedicalAudienceType <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalAudienceType "Target audiences types for medical web pages. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalAudienceType "MedicalAudienceType")
SubClassOf(schema1:MedicalAudienceType schema1:MedicalEnumeration)

# Class: schema1:MedicalBusiness (MedicalBusiness)

AnnotationAssertion(schema1:isPartOf schema1:MedicalBusiness <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalBusiness "A particular physical or virtual business of an organization for medical purposes. Examples of MedicalBusiness include differents business run by health professionals.")
AnnotationAssertion(rdfs:label schema1:MedicalBusiness "MedicalBusiness")
SubClassOf(schema1:MedicalBusiness schema1:LocalBusiness)

# Class: schema1:MedicalCause (MedicalCause)

AnnotationAssertion(schema1:isPartOf schema1:MedicalCause <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalCause "The causative agent(s) that are responsible for the pathophysiologic process that eventually results in a medical condition, symptom or sign. In this schema, unless otherwise specified this is meant to be the proximate cause of the medical condition, symptom or sign. The proximate cause is defined as the causative agent that most directly results in the medical condition, symptom or sign. For example, the HIV virus could be considered a cause of AIDS. Or in a diagnostic context, if a patient fell and sustained a hip fracture and two days later sustained a pulmonary embolism which eventuated in a cardiac arrest, the cause of the cardiac arrest (the proximate cause) would be the pulmonary embolism and not the fall. Medical causes can include cardiovascular, chemical, dermatologic, endocrine, environmental, gastroenterologic, genetic, hematologic, gynecologic, iatrogenic, infectious, musculoskeletal, neurologic, nutritional, obstetric, oncologic, otolaryngologic, pharmacologic, psychiatric, pulmonary, renal, rheumatologic, toxic, traumatic, or urologic causes; medical conditions can be causes as well.")
AnnotationAssertion(rdfs:label schema1:MedicalCause "MedicalCause")
SubClassOf(schema1:MedicalCause schema1:MedicalEntity)

# Class: schema1:MedicalClinic (MedicalClinic)

AnnotationAssertion(schema1:isPartOf schema1:MedicalClinic <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalClinic "A facility, often associated with a hospital or medical school, that is devoted to the specific diagnosis and/or healthcare. Previously limited to outpatients but with evolution it may be open to inpatients as well.")
AnnotationAssertion(rdfs:label schema1:MedicalClinic "MedicalClinic")
SubClassOf(schema1:MedicalClinic schema1:MedicalBusiness)
SubClassOf(schema1:MedicalClinic schema1:MedicalOrganization)

# Class: schema1:MedicalCode (MedicalCode)

AnnotationAssertion(schema1:isPartOf schema1:MedicalCode <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalCode "A code for a medical entity.")
AnnotationAssertion(rdfs:label schema1:MedicalCode "MedicalCode")
SubClassOf(schema1:MedicalCode schema1:CategoryCode)
SubClassOf(schema1:MedicalCode schema1:MedicalIntangible)

# Class: schema1:MedicalCondition (MedicalCondition)

AnnotationAssertion(schema1:isPartOf schema1:MedicalCondition <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalCondition "Any condition of the human body that affects the normal functioning of a person, whether physically or mentally. Includes diseases, injuries, disabilities, disorders, syndromes, etc.")
AnnotationAssertion(rdfs:label schema1:MedicalCondition "MedicalCondition")
SubClassOf(schema1:MedicalCondition schema1:MedicalEntity)

# Class: schema1:MedicalConditionStage (MedicalConditionStage)

AnnotationAssertion(schema1:isPartOf schema1:MedicalConditionStage <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalConditionStage "A stage of a medical condition, such as 'Stage IIIa'.")
AnnotationAssertion(rdfs:label schema1:MedicalConditionStage "MedicalConditionStage")
SubClassOf(schema1:MedicalConditionStage schema1:MedicalIntangible)

# Class: schema1:MedicalContraindication (MedicalContraindication)

AnnotationAssertion(schema1:isPartOf schema1:MedicalContraindication <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalContraindication "A condition or factor that serves as a reason to withhold a certain medical therapy. Contraindications can be absolute (there are no reasonable circumstances for undertaking a course of action) or relative (the patient is at higher risk of complications, but that these risks may be outweighed by other considerations or mitigated by other measures).")
AnnotationAssertion(rdfs:label schema1:MedicalContraindication "MedicalContraindication")
SubClassOf(schema1:MedicalContraindication schema1:MedicalEntity)

# Class: schema1:MedicalDevice (MedicalDevice)

AnnotationAssertion(schema1:isPartOf schema1:MedicalDevice <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalDevice "Any object used in a medical capacity, such as to diagnose or treat a patient.")
AnnotationAssertion(rdfs:label schema1:MedicalDevice "MedicalDevice")
SubClassOf(schema1:MedicalDevice schema1:MedicalEntity)

# Class: schema1:MedicalDevicePurpose (MedicalDevicePurpose)

AnnotationAssertion(schema1:isPartOf schema1:MedicalDevicePurpose <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalDevicePurpose "Categories of medical devices, organized by the purpose or intended use of the device.")
AnnotationAssertion(rdfs:label schema1:MedicalDevicePurpose "MedicalDevicePurpose")
SubClassOf(schema1:MedicalDevicePurpose schema1:MedicalEnumeration)

# Class: schema1:MedicalEntity (MedicalEntity)

AnnotationAssertion(schema1:isPartOf schema1:MedicalEntity <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalEntity "The most generic type of entity related to health and the practice of medicine.")
AnnotationAssertion(rdfs:label schema1:MedicalEntity "MedicalEntity")
SubClassOf(schema1:MedicalEntity schema1:Thing)

# Class: schema1:MedicalEnumeration (MedicalEnumeration)

AnnotationAssertion(schema1:isPartOf schema1:MedicalEnumeration <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalEnumeration "Enumerations related to health and the practice of medicine: A concept that is used to attribute a quality to another concept, as a qualifier, a collection of items or a listing of all of the elements of a set in medicine practice.")
AnnotationAssertion(rdfs:label schema1:MedicalEnumeration "MedicalEnumeration")
SubClassOf(schema1:MedicalEnumeration schema1:Enumeration)

# Class: schema1:MedicalEvidenceLevel (MedicalEvidenceLevel)

AnnotationAssertion(schema1:isPartOf schema1:MedicalEvidenceLevel <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalEvidenceLevel "Level of evidence for a medical guideline. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalEvidenceLevel "MedicalEvidenceLevel")
SubClassOf(schema1:MedicalEvidenceLevel schema1:MedicalEnumeration)

# Class: schema1:MedicalGuideline (MedicalGuideline)

AnnotationAssertion(schema1:isPartOf schema1:MedicalGuideline <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalGuideline "Any recommendation made by a standard society (e.g. ACC/AHA) or consensus statement that denotes how to diagnose and treat a particular condition. Note: this type should be used to tag the actual guideline recommendation; if the guideline recommendation occurs in a larger scholarly article, use MedicalScholarlyArticle to tag the overall article, not this type. Note also: the organization making the recommendation should be captured in the recognizingAuthority base property of MedicalEntity.")
AnnotationAssertion(rdfs:label schema1:MedicalGuideline "MedicalGuideline")
SubClassOf(schema1:MedicalGuideline schema1:MedicalEntity)

# Class: schema1:MedicalGuidelineContraindication (MedicalGuidelineContraindication)

AnnotationAssertion(schema1:isPartOf schema1:MedicalGuidelineContraindication <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalGuidelineContraindication "A guideline contraindication that designates a process as harmful and where quality of the data supporting the contraindication is sound.")
AnnotationAssertion(rdfs:label schema1:MedicalGuidelineContraindication "MedicalGuidelineContraindication")
SubClassOf(schema1:MedicalGuidelineContraindication schema1:MedicalGuideline)

# Class: schema1:MedicalGuidelineRecommendation (MedicalGuidelineRecommendation)

AnnotationAssertion(schema1:isPartOf schema1:MedicalGuidelineRecommendation <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalGuidelineRecommendation "A guideline recommendation that is regarded as efficacious and where quality of the data supporting the recommendation is sound.")
AnnotationAssertion(rdfs:label schema1:MedicalGuidelineRecommendation "MedicalGuidelineRecommendation")
SubClassOf(schema1:MedicalGuidelineRecommendation schema1:MedicalGuideline)

# Class: schema1:MedicalImagingTechnique (MedicalImagingTechnique)

AnnotationAssertion(schema1:isPartOf schema1:MedicalImagingTechnique <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalImagingTechnique "Any medical imaging modality typically used for diagnostic purposes. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalImagingTechnique "MedicalImagingTechnique")
SubClassOf(schema1:MedicalImagingTechnique schema1:MedicalEnumeration)

# Class: schema1:MedicalIndication (MedicalIndication)

AnnotationAssertion(schema1:isPartOf schema1:MedicalIndication <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalIndication "A condition or factor that indicates use of a medical therapy, including signs, symptoms, risk factors, anatomical states, etc.")
AnnotationAssertion(rdfs:label schema1:MedicalIndication "MedicalIndication")
SubClassOf(schema1:MedicalIndication schema1:MedicalEntity)

# Class: schema1:MedicalIntangible (MedicalIntangible)

AnnotationAssertion(schema1:isPartOf schema1:MedicalIntangible <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalIntangible "A utility class that serves as the umbrella for a number of 'intangible' things in the medical space.")
AnnotationAssertion(rdfs:label schema1:MedicalIntangible "MedicalIntangible")
SubClassOf(schema1:MedicalIntangible schema1:MedicalEntity)

# Class: schema1:MedicalObservationalStudy (MedicalObservationalStudy)

AnnotationAssertion(schema1:isPartOf schema1:MedicalObservationalStudy <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalObservationalStudy "An observational study is a type of medical study that attempts to infer the possible effect of a treatment through observation of a cohort of subjects over a period of time. In an observational study, the assignment of subjects into treatment groups versus control groups is outside the control of the investigator. This is in contrast with controlled studies, such as the randomized controlled trials represented by MedicalTrial, where each subject is randomly assigned to a treatment group or a control group before the start of the treatment.")
AnnotationAssertion(rdfs:label schema1:MedicalObservationalStudy "MedicalObservationalStudy")
SubClassOf(schema1:MedicalObservationalStudy schema1:MedicalStudy)

# Class: schema1:MedicalObservationalStudyDesign (MedicalObservationalStudyDesign)

AnnotationAssertion(schema1:isPartOf schema1:MedicalObservationalStudyDesign <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalObservationalStudyDesign "Design models for observational medical studies. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalObservationalStudyDesign "MedicalObservationalStudyDesign")
SubClassOf(schema1:MedicalObservationalStudyDesign schema1:MedicalEnumeration)

# Class: schema1:MedicalOrganization (MedicalOrganization)

AnnotationAssertion(rdfs:comment schema1:MedicalOrganization "A medical organization (physical or not), such as hospital, institution or clinic.")
AnnotationAssertion(rdfs:label schema1:MedicalOrganization "MedicalOrganization")
SubClassOf(schema1:MedicalOrganization schema1:Organization)

# Class: schema1:MedicalProcedure (MedicalProcedure)

AnnotationAssertion(schema1:isPartOf schema1:MedicalProcedure <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalProcedure "A process of care used in either a diagnostic, therapeutic, preventive or palliative capacity that relies on invasive (surgical), non-invasive, or other techniques.")
AnnotationAssertion(rdfs:label schema1:MedicalProcedure "MedicalProcedure")
SubClassOf(schema1:MedicalProcedure schema1:MedicalEntity)

# Class: schema1:MedicalProcedureType (MedicalProcedureType)

AnnotationAssertion(schema1:isPartOf schema1:MedicalProcedureType <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalProcedureType "An enumeration that describes different types of medical procedures.")
AnnotationAssertion(rdfs:label schema1:MedicalProcedureType "MedicalProcedureType")
SubClassOf(schema1:MedicalProcedureType schema1:MedicalEnumeration)

# Class: schema1:MedicalRiskCalculator (MedicalRiskCalculator)

AnnotationAssertion(schema1:isPartOf schema1:MedicalRiskCalculator <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalRiskCalculator "A complex mathematical calculation requiring an online calculator, used to assess prognosis. Note: use the url property of Thing to record any URLs for online calculators.")
AnnotationAssertion(rdfs:label schema1:MedicalRiskCalculator "MedicalRiskCalculator")
SubClassOf(schema1:MedicalRiskCalculator schema1:MedicalRiskEstimator)

# Class: schema1:MedicalRiskEstimator (MedicalRiskEstimator)

AnnotationAssertion(schema1:isPartOf schema1:MedicalRiskEstimator <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalRiskEstimator "Any rule set or interactive tool for estimating the risk of developing a complication or condition.")
AnnotationAssertion(rdfs:label schema1:MedicalRiskEstimator "MedicalRiskEstimator")
SubClassOf(schema1:MedicalRiskEstimator schema1:MedicalEntity)

# Class: schema1:MedicalRiskFactor (MedicalRiskFactor)

AnnotationAssertion(schema1:isPartOf schema1:MedicalRiskFactor <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalRiskFactor "A risk factor is anything that increases a person's likelihood of developing or contracting a disease, medical condition, or complication.")
AnnotationAssertion(rdfs:label schema1:MedicalRiskFactor "MedicalRiskFactor")
SubClassOf(schema1:MedicalRiskFactor schema1:MedicalEntity)

# Class: schema1:MedicalRiskScore (MedicalRiskScore)

AnnotationAssertion(schema1:isPartOf schema1:MedicalRiskScore <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalRiskScore "A simple system that adds up the number of risk factors to yield a score that is associated with prognosis, e.g. CHAD score, TIMI risk score.")
AnnotationAssertion(rdfs:label schema1:MedicalRiskScore "MedicalRiskScore")
SubClassOf(schema1:MedicalRiskScore schema1:MedicalRiskEstimator)

# Class: schema1:MedicalScholarlyArticle (MedicalScholarlyArticle)

AnnotationAssertion(schema1:isPartOf schema1:MedicalScholarlyArticle <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalScholarlyArticle "A scholarly article in the medical domain.")
AnnotationAssertion(rdfs:label schema1:MedicalScholarlyArticle "MedicalScholarlyArticle")
SubClassOf(schema1:MedicalScholarlyArticle schema1:ScholarlyArticle)

# Class: schema1:MedicalSign (MedicalSign)

AnnotationAssertion(schema1:isPartOf schema1:MedicalSign <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalSign "Any physical manifestation of a person's medical condition discoverable by objective diagnostic tests or physical examination.")
AnnotationAssertion(rdfs:label schema1:MedicalSign "MedicalSign")
SubClassOf(schema1:MedicalSign schema1:MedicalSignOrSymptom)

# Class: schema1:MedicalSignOrSymptom (MedicalSignOrSymptom)

AnnotationAssertion(schema1:isPartOf schema1:MedicalSignOrSymptom <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalSignOrSymptom "Any feature associated or not with a medical condition. In medicine a symptom is generally subjective while a sign is objective.")
AnnotationAssertion(rdfs:label schema1:MedicalSignOrSymptom "MedicalSignOrSymptom")
SubClassOf(schema1:MedicalSignOrSymptom schema1:MedicalCondition)

# Class: schema1:MedicalSpecialty (MedicalSpecialty)

AnnotationAssertion(schema1:isPartOf schema1:MedicalSpecialty <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalSpecialty "Any specific branch of medical science or practice. Medical specialities include clinical specialties that pertain to particular organ systems and their respective disease states, as well as allied health specialties. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalSpecialty "MedicalSpecialty")
SubClassOf(schema1:MedicalSpecialty schema1:MedicalEnumeration)
SubClassOf(schema1:MedicalSpecialty schema1:Specialty)

# Class: schema1:MedicalStudy (MedicalStudy)

AnnotationAssertion(schema1:isPartOf schema1:MedicalStudy <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalStudy "A medical study is an umbrella type covering all kinds of research studies relating to human medicine or health, including observational studies and interventional trials and registries, randomized, controlled or not. When the specific type of study is known, use one of the extensions of this type, such as MedicalTrial or MedicalObservationalStudy. Also, note that this type should be used to mark up data that describes the study itself; to tag an article that publishes the results of a study, use MedicalScholarlyArticle. Note: use the code property of MedicalEntity to store study IDs, e.g. clinicaltrials.gov ID.")
AnnotationAssertion(rdfs:label schema1:MedicalStudy "MedicalStudy")
SubClassOf(schema1:MedicalStudy schema1:MedicalEntity)

# Class: schema1:MedicalStudyStatus (MedicalStudyStatus)

AnnotationAssertion(schema1:isPartOf schema1:MedicalStudyStatus <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalStudyStatus "The status of a medical study. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalStudyStatus "MedicalStudyStatus")
SubClassOf(schema1:MedicalStudyStatus schema1:MedicalEnumeration)

# Class: schema1:MedicalSymptom (MedicalSymptom)

AnnotationAssertion(schema1:isPartOf schema1:MedicalSymptom <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalSymptom "Any complaint sensed and expressed by the patient (therefore defined as subjective)  like stomachache, lower-back pain, or fatigue.")
AnnotationAssertion(rdfs:label schema1:MedicalSymptom "MedicalSymptom")
SubClassOf(schema1:MedicalSymptom schema1:MedicalSignOrSymptom)

# Class: schema1:MedicalTest (MedicalTest)

AnnotationAssertion(schema1:isPartOf schema1:MedicalTest <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalTest "Any medical test, typically performed for diagnostic purposes.")
AnnotationAssertion(rdfs:label schema1:MedicalTest "MedicalTest")
SubClassOf(schema1:MedicalTest schema1:MedicalEntity)

# Class: schema1:MedicalTestPanel (MedicalTestPanel)

AnnotationAssertion(schema1:isPartOf schema1:MedicalTestPanel <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalTestPanel "Any collection of tests commonly ordered together.")
AnnotationAssertion(rdfs:label schema1:MedicalTestPanel "MedicalTestPanel")
SubClassOf(schema1:MedicalTestPanel schema1:MedicalTest)

# Class: schema1:MedicalTherapy (MedicalTherapy)

AnnotationAssertion(schema1:isPartOf schema1:MedicalTherapy <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalTherapy "Any medical intervention designed to prevent, treat, and cure human diseases and medical conditions, including both curative and palliative therapies. Medical therapies are typically processes of care relying upon pharmacotherapy, behavioral therapy, supportive therapy (with fluid or nutrition for example), or detoxification (e.g. hemodialysis) aimed at improving or preventing a health condition.")
AnnotationAssertion(rdfs:label schema1:MedicalTherapy "MedicalTherapy")
SubClassOf(schema1:MedicalTherapy schema1:TherapeuticProcedure)

# Class: schema1:MedicalTrial (MedicalTrial)

AnnotationAssertion(schema1:isPartOf schema1:MedicalTrial <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalTrial "A medical trial is a type of medical study that uses scientific process used to compare the safety and efficacy of medical therapies or medical procedures. In general, medical trials are controlled and subjects are allocated at random to the different treatment and/or control groups.")
AnnotationAssertion(rdfs:label schema1:MedicalTrial "MedicalTrial")
SubClassOf(schema1:MedicalTrial schema1:MedicalStudy)

# Class: schema1:MedicalTrialDesign (MedicalTrialDesign)

AnnotationAssertion(schema1:isPartOf schema1:MedicalTrialDesign <http://health-lifesci.schema.org>)
AnnotationAssertion(schema1:source schema1:MedicalTrialDesign <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_WikiDoc>)
AnnotationAssertion(rdfs:comment schema1:MedicalTrialDesign "Design models for medical trials. Enumerated type.")
AnnotationAssertion(rdfs:label schema1:MedicalTrialDesign "MedicalTrialDesign")
SubClassOf(schema1:MedicalTrialDesign schema1:MedicalEnumeration)

# Class: schema1:MedicalWebPage (MedicalWebPage)

AnnotationAssertion(schema1:isPartOf schema1:MedicalWebPage <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicalWebPage "A web page that provides medical information.")
AnnotationAssertion(rdfs:label schema1:MedicalWebPage "MedicalWebPage")
SubClassOf(schema1:MedicalWebPage schema1:WebPage)

# Class: schema1:MedicineSystem (MedicineSystem)

AnnotationAssertion(schema1:isPartOf schema1:MedicineSystem <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:MedicineSystem "Systems of medical practice.")
AnnotationAssertion(rdfs:label schema1:MedicineSystem "MedicineSystem")
SubClassOf(schema1:MedicineSystem schema1:MedicalEnumeration)

# Class: schema1:MeetingRoom (MeetingRoom)

AnnotationAssertion(schema1:source schema1:MeetingRoom <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#STI_Accommodation_Ontology>)
AnnotationAssertion(rdfs:comment schema1:MeetingRoom "A meeting room, conference room, or conference hall is a room provided for singular events such as business conferences and meetings (Source: Wikipedia, the free encyclopedia, see <a href=\"http://en.wikipedia.org/wiki/Conference_hall\">http://en.wikipedia.org/wiki/Conference_hall</a>).
<br /><br />
See also the <a href=\"/docs/hotels.html\">dedicated document on the use of schema.org for marking up hotels and other forms of accommodations</a>.")
AnnotationAssertion(rdfs:label schema1:MeetingRoom "MeetingRoom")
SubClassOf(schema1:MeetingRoom schema1:Room)

# Class: schema1:MensClothingStore (MensClothingStore)

AnnotationAssertion(rdfs:comment schema1:MensClothingStore "A men's clothing store.")
AnnotationAssertion(rdfs:label schema1:MensClothingStore "MensClothingStore")
SubClassOf(schema1:MensClothingStore schema1:Store)

# Class: schema1:Menu (Menu)

AnnotationAssertion(rdfs:comment schema1:Menu "A structured representation of food or drink items available from a FoodEstablishment.")
AnnotationAssertion(rdfs:label schema1:Menu "Menu")
SubClassOf(schema1:Menu schema1:CreativeWork)

# Class: schema1:MenuItem (MenuItem)

AnnotationAssertion(rdfs:comment schema1:MenuItem "A food or drink item listed in a menu or menu section.")
AnnotationAssertion(rdfs:label schema1:MenuItem "MenuItem")
SubClassOf(schema1:MenuItem schema1:Intangible)

# Class: schema1:MenuSection (MenuSection)

AnnotationAssertion(rdfs:comment schema1:MenuSection "A sub-grouping of food or drink items in a menu. E.g. courses (such as 'Dinner', 'Breakfast', etc.), specific type of dishes (such as 'Meat', 'Vegan', 'Drinks', etc.), or some other classification made by the menu provider.")
AnnotationAssertion(rdfs:label schema1:MenuSection "MenuSection")
SubClassOf(schema1:MenuSection schema1:CreativeWork)

# Class: schema1:MerchantReturnEnumeration (MerchantReturnEnumeration)

AnnotationAssertion(schema1:category schema1:MerchantReturnEnumeration "issue-2288")
AnnotationAssertion(schema1:isPartOf schema1:MerchantReturnEnumeration <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:MerchantReturnEnumeration <https://github.com/schemaorg/schemaorg/issues/2288>)
AnnotationAssertion(rdfs:comment schema1:MerchantReturnEnumeration "MerchantReturnEnumeration enumerates several kinds of product return policy. Note that this structure may not capture all aspects of the policy.")
AnnotationAssertion(rdfs:label schema1:MerchantReturnEnumeration "MerchantReturnEnumeration")
SubClassOf(schema1:MerchantReturnEnumeration schema1:Enumeration)

# Class: schema1:MerchantReturnPolicy (MerchantReturnPolicy)

AnnotationAssertion(schema1:category schema1:MerchantReturnPolicy "issue-2288")
AnnotationAssertion(schema1:isPartOf schema1:MerchantReturnPolicy <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:MerchantReturnPolicy <https://github.com/schemaorg/schemaorg/issues/2288>)
AnnotationAssertion(rdfs:comment schema1:MerchantReturnPolicy "A MerchantReturnPolicy provides information about product return policies associated with an <a class=\"localLink\" href=\"http://schema.org/Organization\">Organization</a> or <a class=\"localLink\" href=\"http://schema.org/Product\">Product</a>.")
AnnotationAssertion(rdfs:label schema1:MerchantReturnPolicy "MerchantReturnPolicy")
SubClassOf(schema1:MerchantReturnPolicy schema1:Intangible)

# Class: schema1:Message (Message)

AnnotationAssertion(rdfs:comment schema1:Message "A single message from a sender to one or more organizations or people.")
AnnotationAssertion(rdfs:label schema1:Message "Message")
SubClassOf(schema1:Message schema1:CreativeWork)

# Class: schema1:MiddleSchool (MiddleSchool)

AnnotationAssertion(rdfs:comment schema1:MiddleSchool "A middle school (typically for children aged around 11-14, although this varies somewhat).")
AnnotationAssertion(rdfs:label schema1:MiddleSchool "MiddleSchool")
SubClassOf(schema1:MiddleSchool schema1:EducationalOrganization)

# Class: schema1:Midwifery (Midwifery)

AnnotationAssertion(schema1:isPartOf schema1:Midwifery <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Midwifery "A nurse-like health profession that deals with pregnancy, childbirth, and the postpartum period (including care of the newborn), besides sexual and reproductive health of women throughout their lives.")
AnnotationAssertion(rdfs:label schema1:Midwifery "Midwifery")
SubClassOf(schema1:Midwifery schema1:MedicalBusiness)

# Class: schema1:MobileApplication (MobileApplication)

