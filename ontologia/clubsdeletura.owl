# Annotation Property: schema1:about (about)

AnnotationAssertion(schema1:category schema1:about "issue-1670")
AnnotationAssertion(schema1:domainIncludes schema1:about schema1:CommunicateAction)
AnnotationAssertion(schema1:domainIncludes schema1:about schema1:CreativeWork)
AnnotationAssertion(schema1:domainIncludes schema1:about schema1:Event)
AnnotationAssertion(schema1:inverseOf schema1:about schema1:subjectOf)
AnnotationAssertion(schema1:rangeIncludes schema1:about schema1:Thing)
AnnotationAssertion(schema1:source schema1:about <https://github.com/schemaorg/schemaorg/issues/1670>)
AnnotationAssertion(rdfs:comment schema1:about "The subject matter of the content.")
AnnotationAssertion(rdfs:label schema1:about "about")

# Annotation Property: schema1:acceptedAnswer (acceptedAnswer)

AnnotationAssertion(schema1:domainIncludes schema1:acceptedAnswer schema1:Question)
AnnotationAssertion(schema1:rangeIncludes schema1:acceptedAnswer schema1:Answer)
AnnotationAssertion(schema1:rangeIncludes schema1:acceptedAnswer schema1:ItemList)
AnnotationAssertion(rdfs:comment schema1:acceptedAnswer "The answer(s) that has been accepted as best, typically on a Question/Answer site. Sites vary in their selection mechanisms, e.g. drawing on community opinion and/or the view of the Question author.")
AnnotationAssertion(rdfs:label schema1:acceptedAnswer "acceptedAnswer")
SubAnnotationPropertyOf(schema1:acceptedAnswer schema1:suggestedAnswer)

# Annotation Property: schema1:accommodationCategory (accommodationCategory)

AnnotationAssertion(schema1:category schema1:accommodationCategory "issue-2373")
AnnotationAssertion(schema1:domainIncludes schema1:accommodationCategory schema1:Accommodation)
AnnotationAssertion(schema1:isPartOf schema1:accommodationCategory <http://pending.schema.org>)
AnnotationAssertion(schema1:rangeIncludes schema1:accommodationCategory schema1:Text)
AnnotationAssertion(schema1:source schema1:accommodationCategory <https://github.com/schemaorg/schemaorg/issues/2373>)
AnnotationAssertion(rdfs:comment schema1:accommodationCategory "Category of an <a class=\"localLink\" href=\"http://schema.org/Accommodation\">Accommodation</a>, following real estate conventions e.g. RESO (see <a href=\"https://ddwiki.reso.org/display/DDW17/PropertySubType+Field\">PropertySubType</a>, and <a href=\"https://ddwiki.reso.org/display/DDW17/PropertyType+Field\">PropertyType</a> fields  for suggested values).")
AnnotationAssertion(rdfs:label schema1:accommodationCategory "accommodationCategory")
SubAnnotationPropertyOf(schema1:accommodationCategory schema1:category)

# Annotation Property: schema1:accountId (accountId)

AnnotationAssertion(schema1:domainIncludes schema1:accountId schema1:Invoice)
AnnotationAssertion(schema1:rangeIncludes schema1:accountId schema1:Text)
AnnotationAssertion(rdfs:comment schema1:accountId "The identifier for the account the payment will be applied to.")
AnnotationAssertion(rdfs:label schema1:accountId "accountId")
SubAnnotationPropertyOf(schema1:accountId schema1:identifier)

# Annotation Property: schema1:acquireLicensePage (acquireLicensePage)

AnnotationAssertion(schema1:category schema1:acquireLicensePage "issue-2454")
AnnotationAssertion(schema1:domainIncludes schema1:acquireLicensePage schema1:CreativeWork)
AnnotationAssertion(schema1:isPartOf schema1:acquireLicensePage <http://pending.schema.org>)
AnnotationAssertion(schema1:rangeIncludes schema1:acquireLicensePage schema1:CreativeWork)
AnnotationAssertion(schema1:rangeIncludes schema1:acquireLicensePage schema1:URL)
AnnotationAssertion(schema1:source schema1:acquireLicensePage <https://github.com/schemaorg/schemaorg/issues/2454>)
AnnotationAssertion(rdfs:comment schema1:acquireLicensePage "Indicates a page documenting how licenses can be purchased or otherwise acquired, for the current item.")
AnnotationAssertion(rdfs:label schema1:acquireLicensePage "acquireLicensePage")
SubAnnotationPropertyOf(schema1:acquireLicensePage schema1:usageInfo)

# Annotation Property: schema1:actionOption (actionOption)

AnnotationAssertion(schema1:domainIncludes schema1:actionOption schema1:ChooseAction)
AnnotationAssertion(schema1:rangeIncludes schema1:actionOption schema1:Text)
AnnotationAssertion(schema1:rangeIncludes schema1:actionOption schema1:Thing)
AnnotationAssertion(rdfs:comment schema1:actionOption "A sub property of object. The options subject to this action.")
AnnotationAssertion(rdfs:label schema1:actionOption "actionOption")
