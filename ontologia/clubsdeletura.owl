AnnotationAssertion(schema1:source schema1:ArchiveOrganization <https://github.com/schemaorg/schemaorg/issues/1758>)
AnnotationAssertion(rdfs:comment schema1:ArchiveOrganization "An organization with archival holdings. An organization which keeps and preserves archival material and typically makes it accessible to the public.")
AnnotationAssertion(rdfs:label schema1:ArchiveOrganization "ArchiveOrganization"@en)
SubClassOf(schema1:ArchiveOrganization schema1:LocalBusiness)

