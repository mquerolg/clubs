AnnotationAssertion(rdfs:label schema1:WPSideBar "WPSideBar")
SubClassOf(schema1:WPSideBar schema1:WebPageElement)

# Class: schema1:WantAction (WantAction)

AnnotationAssertion(rdfs:comment schema1:WantAction "The act of expressing a desire about the object. An agent wants an object.")
AnnotationAssertion(rdfs:label schema1:WantAction "WantAction")
SubClassOf(schema1:WantAction schema1:ReactAction)

# Class: schema1:WarrantyPromise (WarrantyPromise)

AnnotationAssertion(schema1:source schema1:WarrantyPromise <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:WarrantyPromise "A structured value representing the duration and scope of services that will be provided to a customer free of charge in case of a defect or malfunction of a product.")
AnnotationAssertion(rdfs:label schema1:WarrantyPromise "WarrantyPromise")
SubClassOf(schema1:WarrantyPromise schema1:StructuredValue)

# Class: schema1:WarrantyScope (WarrantyScope)

AnnotationAssertion(schema1:source schema1:WarrantyScope <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:WarrantyScope "A range of of services that will be provided to a customer free of charge in case of a defect or malfunction of a product.<br/><br/>

Commonly used values:<br/><br/>

<ul>
<li>http://purl.org/goodrelations/v1#Labor-BringIn</li>
<li>http://purl.org/goodrelations/v1#PartsAndLabor-BringIn</li>
<li>http://purl.org/goodrelations/v1#PartsAndLabor-PickUp</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:WarrantyScope "WarrantyScope")
SubClassOf(schema1:WarrantyScope schema1:Enumeration)

# Class: schema1:WatchAction (WatchAction)

