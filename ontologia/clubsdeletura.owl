AnnotationAssertion(rdfs:comment schema1:DrinkAction "The act of swallowing liquids.")
AnnotationAssertion(rdfs:label schema1:DrinkAction "DrinkAction")
SubClassOf(schema1:DrinkAction schema1:ConsumeAction)

