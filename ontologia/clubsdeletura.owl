# Class: schema1:IndividualProduct (IndividualProduct)

AnnotationAssertion(schema1:source schema1:IndividualProduct <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:IndividualProduct "A single, identifiable product instance (e.g. a laptop with a particular serial number).")
AnnotationAssertion(rdfs:label schema1:IndividualProduct "IndividualProduct")
