AnnotationAssertion(schema1:rangeIncludes schema1:events schema1:Event)
AnnotationAssertion(schema1:supersededBy schema1:events schema1:event)
AnnotationAssertion(rdfs:comment schema1:events "Upcoming or past events associated with this place or organization.")
AnnotationAssertion(rdfs:label schema1:events "events")
