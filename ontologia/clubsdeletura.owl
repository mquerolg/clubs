AnnotationAssertion(rdfs:comment schema1:Drawing "A picture or diagram made with a pencil, pen, or crayon rather than paint.")
AnnotationAssertion(rdfs:label schema1:Drawing "Drawing")
SubClassOf(schema1:Drawing schema1:CreativeWork)

