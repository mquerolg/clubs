AnnotationAssertion(rdfs:label schema1:OceanBodyOfWater "OceanBodyOfWater")
SubClassOf(schema1:OceanBodyOfWater schema1:BodyOfWater)

# Class: schema1:Offer (Offer)

AnnotationAssertion(schema1:source schema1:Offer <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsTerms>)
AnnotationAssertion(rdfs:comment schema1:Offer "An offer to transfer some rights to an item or to provide a service — for example, an offer to sell tickets to an event, to rent the DVD of a movie, to stream a TV show over the internet, to repair a motorcycle, or to loan a book.<br/><br/>

Note: As the <a class=\"localLink\" href=\"http://schema.org/businessFunction\">businessFunction</a> property, which identifies the form of offer (e.g. sell, lease, repair, dispose), defaults to http://purl.org/goodrelations/v1#Sell; an Offer without a defined businessFunction value can be assumed to be an offer to sell.<br/><br/>

For <a href=\"http://www.gs1.org/barcodes/technical/idkeys/gtin\">GTIN</a>-related fields, see <a href=\"http://www.gs1.org/barcodes/support/check_digit_calculator\">Check Digit calculator</a> and <a href=\"http://www.gs1us.org/resources/standards/gtin-validation-guide\">validation guide</a> from <a href=\"http://www.gs1.org/\">GS1</a>.")
AnnotationAssertion(rdfs:label schema1:Offer "Offer")
SubClassOf(schema1:Offer schema1:Intangible)

# Class: schema1:OfferCatalog (OfferCatalog)

AnnotationAssertion(rdfs:comment schema1:OfferCatalog "An OfferCatalog is an ItemList that contains related Offers and/or further OfferCatalogs that are offeredBy the same provider.")
AnnotationAssertion(rdfs:label schema1:OfferCatalog "OfferCatalog")
SubClassOf(schema1:OfferCatalog schema1:ItemList)

# Class: schema1:OfferForLease (OfferForLease)

AnnotationAssertion(schema1:category schema1:OfferForLease "issue-2348")
AnnotationAssertion(schema1:isPartOf schema1:OfferForLease <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:OfferForLease <https://github.com/schemaorg/schemaorg/issues/2348>)
AnnotationAssertion(rdfs:comment schema1:OfferForLease "An <a class=\"localLink\" href=\"http://schema.org/OfferForLease\">OfferForLease</a> in Schema.org represents an <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a> to lease out something, i.e. an <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a> whose
  <a class=\"localLink\" href=\"http://schema.org/businessFunction\">businessFunction</a> is <a href=\"http://purl.org/goodrelations/v1#LeaseOut.\">lease out</a>. See <a href=\"https://en.wikipedia.org/wiki/GoodRelations\">Good Relations</a> for
  background on the underlying concepts.")
AnnotationAssertion(rdfs:label schema1:OfferForLease "OfferForLease")
SubClassOf(schema1:OfferForLease schema1:Offer)

# Class: schema1:OfferForPurchase (OfferForPurchase)

AnnotationAssertion(schema1:category schema1:OfferForPurchase "issue-2348")
AnnotationAssertion(schema1:isPartOf schema1:OfferForPurchase <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:OfferForPurchase <https://github.com/schemaorg/schemaorg/issues/2348>)
AnnotationAssertion(rdfs:comment schema1:OfferForPurchase "An <a class=\"localLink\" href=\"http://schema.org/OfferForPurchase\">OfferForPurchase</a> in Schema.org represents an <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a> to sell something, i.e. an <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a> whose
  <a class=\"localLink\" href=\"http://schema.org/businessFunction\">businessFunction</a> is <a href=\"http://purl.org/goodrelations/v1#Sell.\">sell</a>. See <a href=\"https://en.wikipedia.org/wiki/GoodRelations\">Good Relations</a> for
  background on the underlying concepts.")
AnnotationAssertion(rdfs:label schema1:OfferForPurchase "OfferForPurchase")
SubClassOf(schema1:OfferForPurchase schema1:Offer)

# Class: schema1:OfferItemCondition (OfferItemCondition)

AnnotationAssertion(rdfs:comment schema1:OfferItemCondition "A list of possible conditions for the item.")
AnnotationAssertion(rdfs:label schema1:OfferItemCondition "OfferItemCondition")
SubClassOf(schema1:OfferItemCondition schema1:Enumeration)

# Class: schema1:OfferShippingDetails (OfferShippingDetails)

AnnotationAssertion(schema1:category schema1:OfferShippingDetails "issue-2506")
AnnotationAssertion(schema1:isPartOf schema1:OfferShippingDetails <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:OfferShippingDetails <https://github.com/schemaorg/schemaorg/issues/2506>)
AnnotationAssertion(rdfs:comment schema1:OfferShippingDetails "OfferShippingDetails represents information about shipping destinations.<br/><br/>

Multiple of these entities can be used to represent different shipping rates for different destinations:<br/><br/>

One entity for Alaska/Hawaii. A different one for continental US.A different one for all France.<br/><br/>

Multiple of these entities can be used to represent different shipping costs and delivery times.<br/><br/>

Two entities that are identical but differ in rate and time:<br/><br/>

e.g. Cheaper and slower: $5 in 5-7days
or Fast and expensive: $15 in 1-2 days")
AnnotationAssertion(rdfs:label schema1:OfferShippingDetails "OfferShippingDetails")
SubClassOf(schema1:OfferShippingDetails schema1:StructuredValue)

# Class: schema1:OfficeEquipmentStore (OfficeEquipmentStore)

AnnotationAssertion(rdfs:comment schema1:OfficeEquipmentStore "An office equipment store.")
AnnotationAssertion(rdfs:label schema1:OfficeEquipmentStore "OfficeEquipmentStore")
SubClassOf(schema1:OfficeEquipmentStore schema1:Store)

# Class: schema1:OnDemandEvent (OnDemandEvent)

AnnotationAssertion(rdfs:comment schema1:OnDemandEvent "A publication event e.g. catch-up TV or radio podcast, during which a program is available on-demand.")
AnnotationAssertion(rdfs:label schema1:OnDemandEvent "OnDemandEvent")
SubClassOf(schema1:OnDemandEvent schema1:PublicationEvent)

# Class: schema1:Oncologic (Oncologic)

AnnotationAssertion(schema1:isPartOf schema1:Oncologic <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:Oncologic "A specific branch of medical science that deals with benign and malignant tumors, including the study of their development, diagnosis, treatment and prevention.")
AnnotationAssertion(rdfs:label schema1:Oncologic "Oncologic")
SubClassOf(schema1:Oncologic schema1:MedicalBusiness)

# Class: schema1:OpeningHoursSpecification (OpeningHoursSpecification)

AnnotationAssertion(schema1:source schema1:OpeningHoursSpecification <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:OpeningHoursSpecification "A structured value providing information about the opening hours of a place or a certain service inside a place.<br/><br/>

The place is <strong>open</strong> if the <a class=\"localLink\" href=\"http://schema.org/opens\">opens</a> property is specified, and <strong>closed</strong> otherwise.<br/><br/>

If the value for the <a class=\"localLink\" href=\"http://schema.org/closes\">closes</a> property is less than the value for the <a class=\"localLink\" href=\"http://schema.org/opens\">opens</a> property then the hour range is assumed to span over the next day.")
AnnotationAssertion(rdfs:label schema1:OpeningHoursSpecification "OpeningHoursSpecification")
SubClassOf(schema1:OpeningHoursSpecification schema1:StructuredValue)

# Class: schema1:OpinionNewsArticle (OpinionNewsArticle)

AnnotationAssertion(schema1:category schema1:OpinionNewsArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:OpinionNewsArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:OpinionNewsArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:OpinionNewsArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:OpinionNewsArticle "An <a class=\"localLink\" href=\"http://schema.org/OpinionNewsArticle\">OpinionNewsArticle</a> is a <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> that primarily expresses opinions rather than journalistic reporting of news and events. For example, a <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> consisting of a column or <a class=\"localLink\" href=\"http://schema.org/Blog\">Blog</a>/<a class=\"localLink\" href=\"http://schema.org/BlogPosting\">BlogPosting</a> entry in the Opinions section of a news publication.")
AnnotationAssertion(rdfs:label schema1:OpinionNewsArticle "OpinionNewsArticle")
SubClassOf(schema1:OpinionNewsArticle schema1:NewsArticle)

