AnnotationAssertion(schema1:category schema1:measurementTechnique "issue-1425")
AnnotationAssertion(schema1:domainIncludes schema1:measurementTechnique schema1:DataCatalog)
AnnotationAssertion(schema1:domainIncludes schema1:measurementTechnique schema1:DataDownload)
AnnotationAssertion(schema1:domainIncludes schema1:measurementTechnique schema1:Dataset)
