# Class: schema1:TouristAttraction (TouristAttraction)

AnnotationAssertion(schema1:source schema1:TouristAttraction <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#IIT-CNR.it>)
AnnotationAssertion(schema1:source schema1:TouristAttraction <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#Tourism>)
AnnotationAssertion(rdfs:comment schema1:TouristAttraction "A tourist attraction.  In principle any Thing can be a <a class=\"localLink\" href=\"http://schema.org/TouristAttraction\">TouristAttraction</a>, from a <a class=\"localLink\" href=\"http://schema.org/Mountain\">Mountain</a> and <a class=\"localLink\" href=\"http://schema.org/LandmarksOrHistoricalBuildings\">LandmarksOrHistoricalBuildings</a> to a <a class=\"localLink\" href=\"http://schema.org/LocalBusiness\">LocalBusiness</a>.  This Type can be used on its own to describe a general <a class=\"localLink\" href=\"http://schema.org/TouristAttraction\">TouristAttraction</a>, or be used as an <a class=\"localLink\" href=\"http://schema.org/additionalType\">additionalType</a> to add tourist attraction properties to any other type.  (See examples below)")
AnnotationAssertion(rdfs:label schema1:TouristAttraction "TouristAttraction")
SubClassOf(schema1:TouristAttraction schema1:Place)

# Class: schema1:TouristDestination (TouristDestination)

AnnotationAssertion(schema1:category schema1:TouristDestination "issue-1810")
AnnotationAssertion(schema1:isPartOf schema1:TouristDestination <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:TouristDestination <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#IIT-CNR.it>)
AnnotationAssertion(schema1:source schema1:TouristDestination <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#Tourism>)
AnnotationAssertion(rdfs:comment schema1:TouristDestination "A tourist destination. In principle any <a class=\"localLink\" href=\"http://schema.org/Place\">Place</a> can be a <a class=\"localLink\" href=\"http://schema.org/TouristDestination\">TouristDestination</a> from a <a class=\"localLink\" href=\"http://schema.org/City\">City</a>, <a class=\"localLink\" href=\"http://schema.org/Region\">Region</a> or <a class=\"localLink\" href=\"http://schema.org/Country\">Country</a> to an <a class=\"localLink\" href=\"http://schema.org/AmusementPark\">AmusementPark</a> or <a class=\"localLink\" href=\"http://schema.org/Hotel\">Hotel</a>. This Type can be used on its own to describe a general <a class=\"localLink\" href=\"http://schema.org/TouristDestination\">TouristDestination</a>, or be used as an <a class=\"localLink\" href=\"http://schema.org/additionalType\">additionalType</a> to add tourist relevant properties to any other <a class=\"localLink\" href=\"http://schema.org/Place\">Place</a>.  A <a class=\"localLink\" href=\"http://schema.org/TouristDestination\">TouristDestination</a> is defined as a <a class=\"localLink\" href=\"http://schema.org/Place\">Place</a> that contains, or is colocated with, one or more <a class=\"localLink\" href=\"http://schema.org/TouristAttraction\">TouristAttraction</a>s, often linked by a similar theme or interest to a particular <a class=\"localLink\" href=\"http://schema.org/touristType\">touristType</a>. The <a href=\"http://www2.unwto.org/\">UNWTO</a> defines Destination (main destination of a tourism trip) as the place visited that is central to the decision to take the trip.
  (See examples below).")
AnnotationAssertion(rdfs:label schema1:TouristDestination "TouristDestination")
SubClassOf(schema1:TouristDestination schema1:Place)

# Class: schema1:TouristInformationCenter (TouristInformationCenter)

AnnotationAssertion(rdfs:comment schema1:TouristInformationCenter "A tourist information center.")
AnnotationAssertion(rdfs:label schema1:TouristInformationCenter "TouristInformationCenter")
SubClassOf(schema1:TouristInformationCenter schema1:LocalBusiness)

# Class: schema1:TouristTrip (TouristTrip)

AnnotationAssertion(schema1:category schema1:TouristTrip "issue-1810")
AnnotationAssertion(schema1:isPartOf schema1:TouristTrip <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:TouristTrip <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#IIT-CNR.it>)
AnnotationAssertion(schema1:source schema1:TouristTrip <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#Tourism>)
AnnotationAssertion(rdfs:comment schema1:TouristTrip "A tourist trip. A created itinerary of visits to one or more places of interest (<a class=\"localLink\" href=\"http://schema.org/TouristAttraction\">TouristAttraction</a>/<a class=\"localLink\" href=\"http://schema.org/TouristDestination\">TouristDestination</a>) often linked by a similar theme, geographic area, or interest to a particular <a class=\"localLink\" href=\"http://schema.org/touristType\">touristType</a>. The <a href=\"http://www2.unwto.org/\">UNWTO</a> defines tourism trip as the Trip taken by visitors.
  (See examples below).")
AnnotationAssertion(rdfs:label schema1:TouristTrip "TouristTrip")
SubClassOf(schema1:TouristTrip schema1:Trip)

