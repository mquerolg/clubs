AnnotationAssertion(rdfs:label schema1:EmploymentAgency "EmploymentAgency")
SubClassOf(schema1:EmploymentAgency schema1:LocalBusiness)

# Class: schema1:EndorseAction (EndorseAction)

AnnotationAssertion(rdfs:comment schema1:EndorseAction "An agent approves/certifies/likes/supports/sanction an object.")
AnnotationAssertion(rdfs:label schema1:EndorseAction "EndorseAction")
SubClassOf(schema1:EndorseAction schema1:ReactAction)

# Class: schema1:EndorsementRating (EndorsementRating)

AnnotationAssertion(schema1:category schema1:EndorsementRating "issue-1293")
AnnotationAssertion(schema1:source schema1:EndorsementRating <https://github.com/schemaorg/schemaorg/issues/1293>)
AnnotationAssertion(rdfs:comment schema1:EndorsementRating "An EndorsementRating is a rating that expresses some level of endorsement, for example inclusion in a \"critic's pick\" blog, a
\"Like\" or \"+1\" on a social network. It can be considered the <a class=\"localLink\" href=\"http://schema.org/result\">result</a> of an <a class=\"localLink\" href=\"http://schema.org/EndorseAction\">EndorseAction</a> in which the <a class=\"localLink\" href=\"http://schema.org/object\">object</a> of the action is rated positively by
some <a class=\"localLink\" href=\"http://schema.org/agent\">agent</a>. As is common elsewhere in schema.org, it is sometimes more useful to describe the results of such an action without explicitly describing the <a class=\"localLink\" href=\"http://schema.org/Action\">Action</a>.<br/><br/>

An <a class=\"localLink\" href=\"http://schema.org/EndorsementRating\">EndorsementRating</a> may be part of a numeric scale or organized system, but this is not required: having an explicit type for indicating a positive,
endorsement rating is particularly useful in the absence of numeric scales as it helps consumers understand that the rating is broadly positive.")
AnnotationAssertion(rdfs:label schema1:EndorsementRating "EndorsementRating")
SubClassOf(schema1:EndorsementRating schema1:Rating)

# Class: schema1:Energy (Energy)

AnnotationAssertion(rdfs:comment schema1:Energy "Properties that take Energy as values are of the form '&lt;Number&gt; &lt;Energy unit of measure&gt;'.")
AnnotationAssertion(rdfs:label schema1:Energy "Energy")
SubClassOf(schema1:Energy schema1:Quantity)

# Class: schema1:EngineSpecification (EngineSpecification)

AnnotationAssertion(schema1:source schema1:EngineSpecification <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#Automotive_Ontology_Working_Group>)
AnnotationAssertion(rdfs:comment schema1:EngineSpecification "Information about the engine of the vehicle. A vehicle can have multiple engines represented by multiple engine specification entities.")
AnnotationAssertion(rdfs:label schema1:EngineSpecification "EngineSpecification")
SubClassOf(schema1:EngineSpecification schema1:StructuredValue)

# Class: schema1:EntertainmentBusiness (EntertainmentBusiness)

AnnotationAssertion(rdfs:comment schema1:EntertainmentBusiness "A business providing entertainment.")
AnnotationAssertion(rdfs:label schema1:EntertainmentBusiness "EntertainmentBusiness")
SubClassOf(schema1:EntertainmentBusiness schema1:LocalBusiness)

