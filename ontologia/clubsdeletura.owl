# Class: schema1:WebAPI (WebAPI)

AnnotationAssertion(schema1:category schema1:WebAPI "issue-1423")
AnnotationAssertion(schema1:isPartOf schema1:WebAPI <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:WebAPI <https://github.com/schemaorg/schemaorg/issues/1423>)
AnnotationAssertion(rdfs:comment schema1:WebAPI "An application programming interface accessible over Web/Internet technologies.")
AnnotationAssertion(rdfs:label schema1:WebAPI "WebAPI")
SubClassOf(schema1:WebAPI schema1:Service)

# Class: schema1:WebApplication (WebApplication)

AnnotationAssertion(rdfs:comment schema1:WebApplication "Web applications.")
AnnotationAssertion(rdfs:label schema1:WebApplication "WebApplication")
SubClassOf(schema1:WebApplication schema1:SoftwareApplication)

# Class: schema1:WebContent (WebContent)

AnnotationAssertion(schema1:category schema1:WebContent "issue-2358")
AnnotationAssertion(schema1:isPartOf schema1:WebContent <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:WebContent <https://github.com/schemaorg/schemaorg/issues/2358>)
AnnotationAssertion(rdfs:comment schema1:WebContent "WebContent is a type representing all <a class=\"localLink\" href=\"http://schema.org/WebPage\">WebPage</a>, <a class=\"localLink\" href=\"http://schema.org/WebSite\">WebSite</a> and <a class=\"localLink\" href=\"http://schema.org/WebPageElement\">WebPageElement</a> content. It is sometimes the case that detailed distinctions between Web pages, sites and their parts is not always important or obvious. The  <a class=\"localLink\" href=\"http://schema.org/WebContent\">WebContent</a> type makes it easier to describe Web-addressable content without requiring such distinctions to always be stated. (The intent is that the existing types <a class=\"localLink\" href=\"http://schema.org/WebPage\">WebPage</a>, <a class=\"localLink\" href=\"http://schema.org/WebSite\">WebSite</a> and <a class=\"localLink\" href=\"http://schema.org/WebPageElement\">WebPageElement</a> will eventually be declared as subtypes of <a class=\"localLink\" href=\"http://schema.org/WebContent\">WebContent</a>.)")
AnnotationAssertion(rdfs:label schema1:WebContent "WebContent")
SubClassOf(schema1:WebContent schema1:CreativeWork)

# Class: schema1:WebPage (WebPage)

AnnotationAssertion(rdfs:comment schema1:WebPage "A web page. Every web page is implicitly assumed to be declared to be of type WebPage, so the various properties about that webpage, such as <code>breadcrumb</code> may be used. We recommend explicit declaration if these properties are specified, but if they are found outside of an itemscope, they will be assumed to be about the page.")
AnnotationAssertion(rdfs:label schema1:WebPage "WebPage")
SubClassOf(schema1:WebPage schema1:CreativeWork)

# Class: schema1:WebPageElement (WebPageElement)

AnnotationAssertion(rdfs:comment schema1:WebPageElement "A web page element, like a table or an image.")
AnnotationAssertion(rdfs:label schema1:WebPageElement "WebPageElement")
SubClassOf(schema1:WebPageElement schema1:CreativeWork)

# Class: schema1:WebSite (WebSite)

AnnotationAssertion(rdfs:comment schema1:WebSite "A WebSite is a set of related web pages and other items typically served from a single web domain and accessible via URLs.")
AnnotationAssertion(rdfs:label schema1:WebSite "WebSite")
SubClassOf(schema1:WebSite schema1:CreativeWork)

# Class: schema1:WholesaleStore (WholesaleStore)

AnnotationAssertion(rdfs:comment schema1:WholesaleStore "A wholesale store.")
AnnotationAssertion(rdfs:label schema1:WholesaleStore "WholesaleStore")
SubClassOf(schema1:WholesaleStore schema1:Store)

# Class: schema1:WinAction (WinAction)

AnnotationAssertion(rdfs:comment schema1:WinAction "The act of achieving victory in a competitive activity.")
AnnotationAssertion(rdfs:label schema1:WinAction "WinAction")
SubClassOf(schema1:WinAction schema1:AchieveAction)

# Class: schema1:Winery (Winery)

AnnotationAssertion(rdfs:comment schema1:Winery "A winery.")
AnnotationAssertion(rdfs:label schema1:Winery "Winery")
SubClassOf(schema1:Winery schema1:FoodEstablishment)

# Class: schema1:WorkBasedProgram (WorkBasedProgram)

AnnotationAssertion(schema1:category schema1:WorkBasedProgram "issue-2289")
AnnotationAssertion(schema1:isPartOf schema1:WorkBasedProgram <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:WorkBasedProgram <https://github.com/schemaorg/schemaorg/issues/2289>)
AnnotationAssertion(rdfs:comment schema1:WorkBasedProgram "A program with both an educational and employment component. Typically based at a workplace and structured around work-based learning, with the aim of instilling competencies related to an occupation. WorkBasedProgram is used to distinguish programs such as apprenticeships from school, college or other classroom based educational programs.")
AnnotationAssertion(rdfs:label schema1:WorkBasedProgram "WorkBasedProgram")
SubClassOf(schema1:WorkBasedProgram schema1:EducationalOccupationalProgram)

# Class: schema1:WorkersUnion (WorkersUnion)

AnnotationAssertion(schema1:category schema1:WorkersUnion "issue-243")
AnnotationAssertion(schema1:source schema1:WorkersUnion <https://github.com/schemaorg/schemaorg/issues/243>)
AnnotationAssertion(rdfs:comment schema1:WorkersUnion "A Workers Union (also known as a Labor Union, Labour Union, or Trade Union) is an organization that promotes the interests of its worker members by collectively bargaining with management, organizing, and political lobbying.")
AnnotationAssertion(rdfs:label schema1:WorkersUnion "WorkersUnion")
SubClassOf(schema1:WorkersUnion schema1:Organization)

# Class: schema1:WriteAction (WriteAction)

AnnotationAssertion(rdfs:comment schema1:WriteAction "The act of authoring written creative content.")
AnnotationAssertion(rdfs:label schema1:WriteAction "WriteAction")
SubClassOf(schema1:WriteAction schema1:CreateAction)

# Class: schema1:XPathType (XPathType)

AnnotationAssertion(schema1:category schema1:XPathType "issue-1672")
AnnotationAssertion(schema1:isPartOf schema1:XPathType <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:XPathType <https://github.com/schemaorg/schemaorg/issues/1672>)
AnnotationAssertion(rdfs:comment schema1:XPathType "Text representing an XPath (typically but not necessarily version 1.0).")
AnnotationAssertion(rdfs:label schema1:XPathType "XPathType")
SubClassOf(schema1:XPathType schema1:Text)

# Class: schema1:Zoo (Zoo)

AnnotationAssertion(rdfs:comment schema1:Zoo "A zoo.")
AnnotationAssertion(rdfs:label schema1:Zoo "Zoo")
SubClassOf(schema1:Zoo schema1:CivicStructure)

# Class: <http://schema.org/3DModel> (3DModel)

AnnotationAssertion(schema1:category <http://schema.org/3DModel> "issue-2140")
AnnotationAssertion(schema1:isPartOf <http://schema.org/3DModel> <http://pending.schema.org>)
AnnotationAssertion(schema1:source <http://schema.org/3DModel> <https://github.com/schemaorg/schemaorg/issues/2140>)
AnnotationAssertion(rdfs:comment <http://schema.org/3DModel> "A 3D model represents some kind of 3D content, which may have <a class=\"localLink\" href=\"http://schema.org/encoding\">encoding</a>s in one or more <a class=\"localLink\" href=\"http://schema.org/MediaObject\">MediaObject</a>s. Many 3D formats are available (e.g. see <a href=\"https://en.wikipedia.org/wiki/Category:3D_graphics_file_formats\">Wikipedia</a>); specific encoding formats can be represented using the <a class=\"localLink\" href=\"http://schema.org/encodingFormat\">encodingFormat</a> property applied to the relevant <a class=\"localLink\" href=\"http://schema.org/MediaObject\">MediaObject</a>. For the
case of a single file published after Zip compression, the convention of appending '+zip' to the <a class=\"localLink\" href=\"http://schema.org/encodingFormat\">encodingFormat</a> can be used. Geospatial, AR/VR, artistic/animation, gaming, engineering and scientific content can all be represented using <a class=\"localLink\" href=\"http://schema.org/3DModel\">3DModel</a>.")
AnnotationAssertion(rdfs:label <http://schema.org/3DModel> "3DModel")
SubClassOf(<http://schema.org/3DModel> schema1:MediaObject)


