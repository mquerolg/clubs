AnnotationAssertion(rdfs:label schema1:geoTouches "geoTouches")
AnnotationAssertion(schema1:domainIncludes schema1:geoWithin schema1:GeospatialGeometry)
AnnotationAssertion(schema1:domainIncludes schema1:geoWithin schema1:Place)
