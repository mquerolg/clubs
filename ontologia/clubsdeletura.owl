# Class: schema1:AdultEntertainment (AdultEntertainment)

AnnotationAssertion(rdfs:comment schema1:AdultEntertainment "An adult entertainment establishment.")
AnnotationAssertion(rdfs:label schema1:AdultEntertainment "AdultEntertainment")
SubClassOf(schema1:AdultEntertainment schema1:EntertainmentBusiness)

# Class: schema1:AdvertiserContentArticle (AdvertiserContentArticle)

AnnotationAssertion(schema1:category schema1:AdvertiserContentArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:AdvertiserContentArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:AdvertiserContentArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:AdvertiserContentArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:AdvertiserContentArticle "An <a class=\"localLink\" href=\"http://schema.org/Article\">Article</a> that an external entity has paid to place or to produce to its specifications. Includes <a href=\"https://en.wikipedia.org/wiki/Advertorial\">advertorials</a>, sponsored content, native advertising and other paid content.")
AnnotationAssertion(rdfs:label schema1:AdvertiserContentArticle "AdvertiserContentArticle")
SubClassOf(schema1:AdvertiserContentArticle schema1:Article)

# Class: schema1:AggregateOffer (AggregateOffer)

AnnotationAssertion(rdfs:comment schema1:AggregateOffer "When a single product is associated with multiple offers (for example, the same pair of shoes is offered by different merchants), then AggregateOffer can be used.<br/><br/>

Note: AggregateOffers are normally expected to associate multiple offers that all share the same defined <a class=\"localLink\" href=\"http://schema.org/businessFunction\">businessFunction</a> value, or default to http://purl.org/goodrelations/v1#Sell if businessFunction is not explicitly defined.")
AnnotationAssertion(rdfs:label schema1:AggregateOffer "AggregateOffer")
SubClassOf(schema1:AggregateOffer schema1:Offer)

# Class: schema1:AggregateRating (AggregateRating)

AnnotationAssertion(rdfs:comment schema1:AggregateRating "The average rating based on multiple ratings or reviews.")
AnnotationAssertion(rdfs:label schema1:AggregateRating "AggregateRating")
SubClassOf(schema1:AggregateRating schema1:Rating)

# Class: schema1:AgreeAction (AgreeAction)

AnnotationAssertion(rdfs:comment schema1:AgreeAction "The act of expressing a consistency of opinion with the object. An agent agrees to/about an object (a proposition, topic or theme) with participants.")
AnnotationAssertion(rdfs:label schema1:AgreeAction "AgreeAction")
SubClassOf(schema1:AgreeAction schema1:ReactAction)

# Class: schema1:Airline (Airline)

AnnotationAssertion(rdfs:comment schema1:Airline "An organization that provides flights for passengers.")
AnnotationAssertion(rdfs:label schema1:Airline "Airline")
SubClassOf(schema1:Airline schema1:Organization)

# Class: schema1:Airport (Airport)

AnnotationAssertion(rdfs:comment schema1:Airport "An airport.")
AnnotationAssertion(rdfs:label schema1:Airport "Airport")
SubClassOf(schema1:Airport schema1:CivicStructure)

# Class: schema1:AlignmentObject (AlignmentObject)

AnnotationAssertion(schema1:source schema1:AlignmentObject <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_LRMIClass>)
AnnotationAssertion(rdfs:comment schema1:AlignmentObject "An intangible item that describes an alignment between a learning resource and a node in an educational framework.<br/><br/>

Should not be used where the nature of the alignment can be described using a simple property, for example to express that a resource <a class=\"localLink\" href=\"http://schema.org/teaches\">teaches</a> or <a class=\"localLink\" href=\"http://schema.org/assesses\">assesses</a> a competency.")
AnnotationAssertion(rdfs:label schema1:AlignmentObject "AlignmentObject")
SubClassOf(schema1:AlignmentObject schema1:Intangible)

# Class: schema1:AllocateAction (AllocateAction)

AnnotationAssertion(rdfs:comment schema1:AllocateAction "The act of organizing tasks/objects/events by associating resources to it.")
AnnotationAssertion(rdfs:label schema1:AllocateAction "AllocateAction")
SubClassOf(schema1:AllocateAction schema1:OrganizeAction)

# Class: schema1:AmusementPark (AmusementPark)

AnnotationAssertion(rdfs:comment schema1:AmusementPark "An amusement park.")
AnnotationAssertion(rdfs:label schema1:AmusementPark "AmusementPark")
SubClassOf(schema1:AmusementPark schema1:EntertainmentBusiness)

# Class: schema1:AnalysisNewsArticle (AnalysisNewsArticle)

AnnotationAssertion(schema1:category schema1:AnalysisNewsArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:AnalysisNewsArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:AnalysisNewsArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:AnalysisNewsArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:AnalysisNewsArticle "An AnalysisNewsArticle is a <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> that, while based on factual reporting, incorporates the expertise of the author/producer, offering interpretations and conclusions.")
AnnotationAssertion(rdfs:label schema1:AnalysisNewsArticle "AnalysisNewsArticle")
SubClassOf(schema1:AnalysisNewsArticle schema1:NewsArticle)

# Class: schema1:AnatomicalStructure (AnatomicalStructure)

AnnotationAssertion(schema1:isPartOf schema1:AnatomicalStructure <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:AnatomicalStructure "Any part of the human body, typically a component of an anatomical system. Organs, tissues, and cells are all anatomical structures.")
AnnotationAssertion(rdfs:label schema1:AnatomicalStructure "AnatomicalStructure")
SubClassOf(schema1:AnatomicalStructure schema1:MedicalEntity)

# Class: schema1:AnatomicalSystem (AnatomicalSystem)

AnnotationAssertion(schema1:isPartOf schema1:AnatomicalSystem <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:AnatomicalSystem "An anatomical system is a group of anatomical structures that work together to perform a certain task. Anatomical systems, such as organ systems, are one organizing principle of anatomy, and can includes circulatory, digestive, endocrine, integumentary, immune, lymphatic, muscular, nervous, reproductive, respiratory, skeletal, urinary, vestibular, and other systems.")
AnnotationAssertion(rdfs:label schema1:AnatomicalSystem "AnatomicalSystem")
SubClassOf(schema1:AnatomicalSystem schema1:MedicalEntity)

# Class: schema1:AnimalShelter (AnimalShelter)

AnnotationAssertion(rdfs:comment schema1:AnimalShelter "Animal shelter.")
AnnotationAssertion(rdfs:label schema1:AnimalShelter "AnimalShelter")
SubClassOf(schema1:AnimalShelter schema1:LocalBusiness)

