AnnotationAssertion(rdfs:comment schema1:EntryPoint "An entry point, within some Web-based protocol.")
AnnotationAssertion(rdfs:label schema1:EntryPoint "EntryPoint")
SubClassOf(schema1:EntryPoint schema1:Intangible)

