AnnotationAssertion(rdfs:comment schema1:Occupation "A profession, may involve prolonged training and/or a formal qualification.")
AnnotationAssertion(rdfs:label schema1:Occupation "Occupation")
SubClassOf(schema1:Occupation schema1:Intangible)

# Class: schema1:OccupationalTherapy (OccupationalTherapy)

AnnotationAssertion(schema1:isPartOf schema1:OccupationalTherapy <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:OccupationalTherapy "A treatment of people with physical, emotional, or social problems, using purposeful activity to help them overcome or learn to deal with their problems.")
AnnotationAssertion(rdfs:label schema1:OccupationalTherapy "OccupationalTherapy")
SubClassOf(schema1:OccupationalTherapy schema1:MedicalTherapy)

# Class: schema1:OceanBodyOfWater (OceanBodyOfWater)

