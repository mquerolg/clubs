AnnotationAssertion(rdfs:label schema1:RadioSeries "RadioSeries")
SubClassOf(schema1:RadioSeries schema1:CreativeWorkSeries)

# Class: schema1:RadioStation (RadioStation)

AnnotationAssertion(rdfs:comment schema1:RadioStation "A radio station.")
AnnotationAssertion(rdfs:label schema1:RadioStation "RadioStation")
SubClassOf(schema1:RadioStation schema1:LocalBusiness)

# Class: schema1:Rating (Rating)

AnnotationAssertion(rdfs:comment schema1:Rating "A rating is an evaluation on a numeric scale, such as 1 to 5 stars.")
AnnotationAssertion(rdfs:label schema1:Rating "Rating")
SubClassOf(schema1:Rating schema1:Intangible)

# Class: schema1:ReactAction (ReactAction)

AnnotationAssertion(rdfs:comment schema1:ReactAction "The act of responding instinctively and emotionally to an object, expressing a sentiment.")
AnnotationAssertion(rdfs:label schema1:ReactAction "ReactAction")
SubClassOf(schema1:ReactAction schema1:AssessAction)

# Class: schema1:ReadAction (ReadAction)

AnnotationAssertion(rdfs:comment schema1:ReadAction "The act of consuming written content.")
AnnotationAssertion(rdfs:label schema1:ReadAction "ReadAction")
SubClassOf(schema1:ReadAction schema1:ConsumeAction)

# Class: schema1:RealEstateAgent (RealEstateAgent)

AnnotationAssertion(rdfs:comment schema1:RealEstateAgent "A real-estate agent.")
AnnotationAssertion(rdfs:label schema1:RealEstateAgent "RealEstateAgent")
SubClassOf(schema1:RealEstateAgent schema1:LocalBusiness)

# Class: schema1:RealEstateListing (RealEstateListing)

AnnotationAssertion(schema1:category schema1:RealEstateListing "issue-2348")
AnnotationAssertion(schema1:isPartOf schema1:RealEstateListing <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:RealEstateListing <https://github.com/schemaorg/schemaorg/issues/2348>)
AnnotationAssertion(rdfs:comment schema1:RealEstateListing "A <a class=\"localLink\" href=\"http://schema.org/RealEstateListing\">RealEstateListing</a> is a listing that describes one or more real-estate <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a>s (whose <a class=\"localLink\" href=\"http://schema.org/businessFunction\">businessFunction</a> is typically to lease out, or to sell).
  The <a class=\"localLink\" href=\"http://schema.org/RealEstateListing\">RealEstateListing</a> type itself represents the overall listing, as manifested in some <a class=\"localLink\" href=\"http://schema.org/WebPage\">WebPage</a>.")
AnnotationAssertion(rdfs:label schema1:RealEstateListing "RealEstateListing")
SubClassOf(schema1:RealEstateListing schema1:WebPage)

# Class: schema1:ReceiveAction (ReceiveAction)

AnnotationAssertion(rdfs:comment schema1:ReceiveAction "The act of physically/electronically taking delivery of an object thathas been transferred from an origin to a destination. Reciprocal of SendAction.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/SendAction\">SendAction</a>: The reciprocal of ReceiveAction.</li>
<li><a class=\"localLink\" href=\"http://schema.org/TakeAction\">TakeAction</a>: Unlike TakeAction, ReceiveAction does not imply that the ownership has been transfered (e.g. I can receive a package, but it does not mean the package is now mine).</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:ReceiveAction "ReceiveAction")
SubClassOf(schema1:ReceiveAction schema1:TransferAction)

# Class: schema1:Recipe (Recipe)

AnnotationAssertion(rdfs:comment schema1:Recipe "A recipe. For dietary restrictions covered by the recipe, a few common restrictions are enumerated via <a class=\"localLink\" href=\"http://schema.org/suitableForDiet\">suitableForDiet</a>. The <a class=\"localLink\" href=\"http://schema.org/keywords\">keywords</a> property can also be used to add more detail.")
AnnotationAssertion(rdfs:label schema1:Recipe "Recipe")
SubClassOf(schema1:Recipe schema1:HowTo)

# Class: schema1:Recommendation (Recommendation)

AnnotationAssertion(schema1:category schema1:Recommendation "issue-2405")
AnnotationAssertion(schema1:isPartOf schema1:Recommendation <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:Recommendation <https://github.com/schemaorg/schemaorg/issues/2405>)
AnnotationAssertion(rdfs:comment schema1:Recommendation "<a class=\"localLink\" href=\"http://schema.org/Recommendation\">Recommendation</a> is a type of <a class=\"localLink\" href=\"http://schema.org/Review\">Review</a> that suggests or proposes something as the best option or best course of action. Recommendations may be for products or services, or other concrete things, as in the case of a ranked list or product guide. A <a class=\"localLink\" href=\"http://schema.org/Guide\">Guide</a> may list multiple recommendations for different categories. For example, in a <a class=\"localLink\" href=\"http://schema.org/Guide\">Guide</a> about which TVs to buy, the author may have several <a class=\"localLink\" href=\"http://schema.org/Recommendation\">Recommendation</a>s.")
AnnotationAssertion(rdfs:label schema1:Recommendation "Recommendation")
SubClassOf(schema1:Recommendation schema1:Review)

# Class: schema1:RecommendedDoseSchedule (RecommendedDoseSchedule)

AnnotationAssertion(schema1:isPartOf schema1:RecommendedDoseSchedule <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:RecommendedDoseSchedule "A recommended dosing schedule for a drug or supplement as prescribed or recommended by an authority or by the drug/supplement's manufacturer. Capture the recommending authority in the recognizingAuthority property of MedicalEntity.")
AnnotationAssertion(rdfs:label schema1:RecommendedDoseSchedule "RecommendedDoseSchedule")
SubClassOf(schema1:RecommendedDoseSchedule schema1:DoseSchedule)

# Class: schema1:RecyclingCenter (RecyclingCenter)

AnnotationAssertion(rdfs:comment schema1:RecyclingCenter "A recycling center.")
AnnotationAssertion(rdfs:label schema1:RecyclingCenter "RecyclingCenter")
SubClassOf(schema1:RecyclingCenter schema1:LocalBusiness)

# Class: schema1:RefundTypeEnumeration (RefundTypeEnumeration)

AnnotationAssertion(schema1:category schema1:RefundTypeEnumeration "issue-2288")
AnnotationAssertion(schema1:isPartOf schema1:RefundTypeEnumeration <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:RefundTypeEnumeration <https://github.com/schemaorg/schemaorg/issues/2288>)
AnnotationAssertion(rdfs:comment schema1:RefundTypeEnumeration "RefundTypeEnumeration enumerates several kinds of product return refund types.")
AnnotationAssertion(rdfs:label schema1:RefundTypeEnumeration "RefundTypeEnumeration")
SubClassOf(schema1:RefundTypeEnumeration schema1:Enumeration)

# Class: schema1:RegisterAction (RegisterAction)

AnnotationAssertion(rdfs:comment schema1:RegisterAction "The act of registering to be a user of a service, product or web page.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/JoinAction\">JoinAction</a>: Unlike JoinAction, RegisterAction implies you are registering to be a user of a service, <em>not</em> a group/team of people.</li>
<li>[FollowAction]]: Unlike FollowAction, RegisterAction doesn't imply that the agent is expecting to poll for updates from the object.</li>
<li><a class=\"localLink\" href=\"http://schema.org/SubscribeAction\">SubscribeAction</a>: Unlike SubscribeAction, RegisterAction doesn't imply that the agent is expecting updates from the object.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:RegisterAction "RegisterAction")
SubClassOf(schema1:RegisterAction schema1:InteractAction)

# Class: schema1:RejectAction (RejectAction)

AnnotationAssertion(rdfs:comment schema1:RejectAction "The act of rejecting to/adopting an object.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/AcceptAction\">AcceptAction</a>: The antonym of RejectAction.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:RejectAction "RejectAction")
SubClassOf(schema1:RejectAction schema1:AllocateAction)

# Class: schema1:RentAction (RentAction)

AnnotationAssertion(rdfs:comment schema1:RentAction "The act of giving money in return for temporary use, but not ownership, of an object such as a vehicle or property. For example, an agent rents a property from a landlord in exchange for a periodic payment.")
AnnotationAssertion(rdfs:label schema1:RentAction "RentAction")
SubClassOf(schema1:RentAction schema1:TradeAction)

# Class: schema1:RentalCarReservation (RentalCarReservation)

AnnotationAssertion(rdfs:comment schema1:RentalCarReservation "A reservation for a rental car.<br/><br/>

Note: This type is for information about actual reservations, e.g. in confirmation emails or HTML pages with individual confirmations of reservations.")
AnnotationAssertion(rdfs:label schema1:RentalCarReservation "RentalCarReservation")
SubClassOf(schema1:RentalCarReservation schema1:Reservation)

# Class: schema1:RepaymentSpecification (RepaymentSpecification)

AnnotationAssertion(schema1:category schema1:RepaymentSpecification "issue-1253")
AnnotationAssertion(schema1:isPartOf schema1:RepaymentSpecification <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:RepaymentSpecification <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FIBO>)
AnnotationAssertion(schema1:source schema1:RepaymentSpecification <https://github.com/schemaorg/schemaorg/issues/1253>)
AnnotationAssertion(rdfs:comment schema1:RepaymentSpecification "A structured value representing repayment.")
AnnotationAssertion(rdfs:label schema1:RepaymentSpecification "RepaymentSpecification")
SubClassOf(schema1:RepaymentSpecification schema1:StructuredValue)

# Class: schema1:ReplaceAction (ReplaceAction)

AnnotationAssertion(rdfs:comment schema1:ReplaceAction "The act of editing a recipient by replacing an old object with a new object.")
AnnotationAssertion(rdfs:label schema1:ReplaceAction "ReplaceAction")
SubClassOf(schema1:ReplaceAction schema1:UpdateAction)

# Class: schema1:ReplyAction (ReplyAction)

AnnotationAssertion(rdfs:comment schema1:ReplyAction "The act of responding to a question/message asked/sent by the object. Related to <a class=\"localLink\" href=\"http://schema.org/AskAction\">AskAction</a><br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/AskAction\">AskAction</a>: Appears generally as an origin of a ReplyAction.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:ReplyAction "ReplyAction")
SubClassOf(schema1:ReplyAction schema1:CommunicateAction)

# Class: schema1:Report (Report)

AnnotationAssertion(rdfs:comment schema1:Report "A Report generated by governmental or non-governmental organization.")
AnnotationAssertion(rdfs:label schema1:Report "Report")
SubClassOf(schema1:Report schema1:Article)

# Class: schema1:ReportageNewsArticle (ReportageNewsArticle)

AnnotationAssertion(schema1:category schema1:ReportageNewsArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:ReportageNewsArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:ReportageNewsArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:ReportageNewsArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:ReportageNewsArticle "The <a class=\"localLink\" href=\"http://schema.org/ReportageNewsArticle\">ReportageNewsArticle</a> type is a subtype of <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> representing
 news articles which are the result of journalistic news reporting conventions.<br/><br/>

In practice many news publishers produce a wide variety of article types, many of which might be considered a <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> but not a <a class=\"localLink\" href=\"http://schema.org/ReportageNewsArticle\">ReportageNewsArticle</a>. For example, opinion pieces, reviews, analysis, sponsored or satirical articles, or articles that combine several of these elements.<br/><br/>

The <a class=\"localLink\" href=\"http://schema.org/ReportageNewsArticle\">ReportageNewsArticle</a> type is based on a stricter ideal for \"news\" as a work of journalism, with articles based on factual information either observed or verified by the author, or reported and verified from knowledgeable sources.  This often includes perspectives from multiple viewpoints on a particular issue (distinguishing news reports from public relations or propaganda).  News reports in the <a class=\"localLink\" href=\"http://schema.org/ReportageNewsArticle\">ReportageNewsArticle</a> sense de-emphasize the opinion of the author, with commentary and value judgements typically expressed elsewhere.<br/><br/>

A <a class=\"localLink\" href=\"http://schema.org/ReportageNewsArticle\">ReportageNewsArticle</a> which goes deeper into analysis can also be marked with an additional type of <a class=\"localLink\" href=\"http://schema.org/AnalysisNewsArticle\">AnalysisNewsArticle</a>.")
AnnotationAssertion(rdfs:label schema1:ReportageNewsArticle "ReportageNewsArticle")
SubClassOf(schema1:ReportageNewsArticle schema1:NewsArticle)

# Class: schema1:ReportedDoseSchedule (ReportedDoseSchedule)

AnnotationAssertion(schema1:isPartOf schema1:ReportedDoseSchedule <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:ReportedDoseSchedule "A patient-reported or observed dosing schedule for a drug or supplement.")
AnnotationAssertion(rdfs:label schema1:ReportedDoseSchedule "ReportedDoseSchedule")
SubClassOf(schema1:ReportedDoseSchedule schema1:DoseSchedule)

# Class: schema1:ResearchProject (ResearchProject)

AnnotationAssertion(schema1:category schema1:ResearchProject "issue-383")
AnnotationAssertion(schema1:isPartOf schema1:ResearchProject <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:ResearchProject <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#FundInfoCollab>)
AnnotationAssertion(rdfs:comment schema1:ResearchProject "A Research project.")
AnnotationAssertion(rdfs:label schema1:ResearchProject "ResearchProject")
SubClassOf(schema1:ResearchProject schema1:Project)

# Class: schema1:Reservation (Reservation)

AnnotationAssertion(rdfs:comment schema1:Reservation "Describes a reservation for travel, dining or an event. Some reservations require tickets. <br/><br/>

Note: This type is for information about actual reservations, e.g. in confirmation emails or HTML pages with individual confirmations of reservations. For offers of tickets, restaurant reservations, flights, or rental cars, use <a class=\"localLink\" href=\"http://schema.org/Offer\">Offer</a>.")
AnnotationAssertion(rdfs:label schema1:Reservation "Reservation")
SubClassOf(schema1:Reservation schema1:Intangible)

# Class: schema1:ReservationPackage (ReservationPackage)

AnnotationAssertion(rdfs:comment schema1:ReservationPackage "A group of multiple reservations with common values for all sub-reservations.")
AnnotationAssertion(rdfs:label schema1:ReservationPackage "ReservationPackage")
SubClassOf(schema1:ReservationPackage schema1:Reservation)

# Class: schema1:ReservationStatusType (ReservationStatusType)

AnnotationAssertion(rdfs:comment schema1:ReservationStatusType "Enumerated status values for Reservation.")
AnnotationAssertion(rdfs:label schema1:ReservationStatusType "ReservationStatusType")
SubClassOf(schema1:ReservationStatusType schema1:StatusEnumeration)

# Class: schema1:ReserveAction (ReserveAction)

AnnotationAssertion(rdfs:comment schema1:ReserveAction "Reserving a concrete object.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/ScheduleAction\">ScheduleAction</a></a>: Unlike ScheduleAction, ReserveAction reserves concrete objects (e.g. a table, a hotel) towards a time slot / spatial allocation.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:ReserveAction "ReserveAction")
SubClassOf(schema1:ReserveAction schema1:PlanAction)

# Class: schema1:Reservoir (Reservoir)

AnnotationAssertion(rdfs:comment schema1:Reservoir "A reservoir of water, typically an artificially created lake, like the Lake Kariba reservoir.")
AnnotationAssertion(rdfs:label schema1:Reservoir "Reservoir")
SubClassOf(schema1:Reservoir schema1:BodyOfWater)

# Class: schema1:Residence (Residence)

AnnotationAssertion(rdfs:comment schema1:Residence "The place where a person lives.")
AnnotationAssertion(rdfs:label schema1:Residence "Residence")
SubClassOf(schema1:Residence schema1:Place)

# Class: schema1:Resort (Resort)

AnnotationAssertion(schema1:source schema1:Resort <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#STI_Accommodation_Ontology>)
AnnotationAssertion(rdfs:comment schema1:Resort "A resort is a place used for relaxation or recreation, attracting visitors for holidays or vacations. Resorts are places, towns or sometimes commercial establishment operated by a single company (Source: Wikipedia, the free encyclopedia, see <a href=\"http://en.wikipedia.org/wiki/Resort\">http://en.wikipedia.org/wiki/Resort</a>).
<br /><br />
See also the <a href=\"/docs/hotels.html\">dedicated document on the use of schema.org for marking up hotels and other forms of accommodations</a>.")
AnnotationAssertion(rdfs:label schema1:Resort "Resort")
SubClassOf(schema1:Resort schema1:LodgingBusiness)

# Class: schema1:RespiratoryTherapy (RespiratoryTherapy)

AnnotationAssertion(schema1:isPartOf schema1:RespiratoryTherapy <http://health-lifesci.schema.org>)
AnnotationAssertion(rdfs:comment schema1:RespiratoryTherapy "The therapy that is concerned with the maintenance or improvement of respiratory function (as in patients with pulmonary disease).")
AnnotationAssertion(rdfs:label schema1:RespiratoryTherapy "RespiratoryTherapy")
SubClassOf(schema1:RespiratoryTherapy schema1:MedicalTherapy)

# Class: schema1:Restaurant (Restaurant)

AnnotationAssertion(rdfs:comment schema1:Restaurant "A restaurant.")
AnnotationAssertion(rdfs:label schema1:Restaurant "Restaurant")
SubClassOf(schema1:Restaurant schema1:FoodEstablishment)

# Class: schema1:RestrictedDiet (RestrictedDiet)

AnnotationAssertion(rdfs:comment schema1:RestrictedDiet "A diet restricted to certain foods or preparations for cultural, religious, health or lifestyle reasons.")
AnnotationAssertion(rdfs:label schema1:RestrictedDiet "RestrictedDiet")
SubClassOf(schema1:RestrictedDiet schema1:Enumeration)

# Class: schema1:ResumeAction (ResumeAction)

AnnotationAssertion(rdfs:comment schema1:ResumeAction "The act of resuming a device or application which was formerly paused (e.g. resume music playback or resume a timer).")
AnnotationAssertion(rdfs:label schema1:ResumeAction "ResumeAction")
SubClassOf(schema1:ResumeAction schema1:ControlAction)

# Class: schema1:ReturnAction (ReturnAction)

AnnotationAssertion(rdfs:comment schema1:ReturnAction "The act of returning to the origin that which was previously received (concrete objects) or taken (ownership).")
AnnotationAssertion(rdfs:label schema1:ReturnAction "ReturnAction")
SubClassOf(schema1:ReturnAction schema1:TransferAction)

# Class: schema1:ReturnFeesEnumeration (ReturnFeesEnumeration)

AnnotationAssertion(schema1:category schema1:ReturnFeesEnumeration "issue-2288")
AnnotationAssertion(schema1:isPartOf schema1:ReturnFeesEnumeration <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:ReturnFeesEnumeration <https://github.com/schemaorg/schemaorg/issues/2288>)
AnnotationAssertion(rdfs:comment schema1:ReturnFeesEnumeration "ReturnFeesEnumeration expresses policies for return fees.")
AnnotationAssertion(rdfs:label schema1:ReturnFeesEnumeration "ReturnFeesEnumeration")
SubClassOf(schema1:ReturnFeesEnumeration schema1:Enumeration)

# Class: schema1:Review (Review)

AnnotationAssertion(rdfs:comment schema1:Review "A review of an item - for example, of a restaurant, movie, or store.")
AnnotationAssertion(rdfs:label schema1:Review "Review")
SubClassOf(schema1:Review schema1:CreativeWork)
SubClassOf(schema1:Review ObjectAllValuesFrom(schema1:itemReviewed schema1:Book))

# Class: schema1:ReviewAction (ReviewAction)

AnnotationAssertion(rdfs:comment schema1:ReviewAction "The act of producing a balanced opinion about the object for an audience. An agent reviews an object with participants resulting in a review.")
AnnotationAssertion(rdfs:label schema1:ReviewAction "ReviewAction")
SubClassOf(schema1:ReviewAction schema1:AssessAction)

# Class: schema1:ReviewNewsArticle (ReviewNewsArticle)

AnnotationAssertion(schema1:category schema1:ReviewNewsArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:ReviewNewsArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:ReviewNewsArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:ReviewNewsArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:ReviewNewsArticle "A <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> and <a class=\"localLink\" href=\"http://schema.org/CriticReview\">CriticReview</a> providing a professional critic's assessment of a service, product, performance, or artistic or literary work.")
AnnotationAssertion(rdfs:label schema1:ReviewNewsArticle "ReviewNewsArticle")
SubClassOf(schema1:ReviewNewsArticle schema1:CriticReview)
SubClassOf(schema1:ReviewNewsArticle schema1:NewsArticle)

# Class: schema1:RiverBodyOfWater (RiverBodyOfWater)

AnnotationAssertion(rdfs:comment schema1:RiverBodyOfWater "A river (for example, the broad majestic Shannon).")
AnnotationAssertion(rdfs:label schema1:RiverBodyOfWater "RiverBodyOfWater")
SubClassOf(schema1:RiverBodyOfWater schema1:BodyOfWater)

# Class: schema1:Role (Role)

AnnotationAssertion(rdfs:comment schema1:Role "Represents additional information about a relationship or property. For example a Role can be used to say that a 'member' role linking some SportsTeam to a player occurred during a particular time period. Or that a Person's 'actor' role in a Movie was for some particular characterName. Such properties can be attached to a Role entity, which is then associated with the main entities using ordinary properties like 'member' or 'actor'.<br/><br/>

See also <a href=\"https://blog.schema.org/2014/06/16/introducing-role/\">blog post</a>.")
AnnotationAssertion(rdfs:label schema1:Role "Role")
SubClassOf(schema1:Role schema1:Intangible)

# Class: schema1:RoofingContractor (RoofingContractor)

AnnotationAssertion(rdfs:comment schema1:RoofingContractor "A roofing contractor.")
AnnotationAssertion(rdfs:label schema1:RoofingContractor "RoofingContractor")
SubClassOf(schema1:RoofingContractor schema1:HomeAndConstructionBusiness)

# Class: schema1:Room (Room)

AnnotationAssertion(schema1:source schema1:Room <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#STI_Accommodation_Ontology>)
AnnotationAssertion(rdfs:comment schema1:Room "A room is a distinguishable space within a structure, usually separated from other spaces by interior walls. (Source: Wikipedia, the free encyclopedia, see <a href=\"http://en.wikipedia.org/wiki/Room\">http://en.wikipedia.org/wiki/Room</a>).
<br /><br />
See also the <a href=\"/docs/hotels.html\">dedicated document on the use of schema.org for marking up hotels and other forms of accommodations</a>.")
AnnotationAssertion(rdfs:label schema1:Room "Room")
SubClassOf(schema1:Room schema1:Accommodation)

# Class: schema1:RsvpAction (RsvpAction)

AnnotationAssertion(rdfs:comment schema1:RsvpAction "The act of notifying an event organizer as to whether you expect to attend the event.")
AnnotationAssertion(rdfs:label schema1:RsvpAction "RsvpAction")
SubClassOf(schema1:RsvpAction schema1:InformAction)

# Class: schema1:RsvpResponseType (RsvpResponseType)

AnnotationAssertion(rdfs:comment schema1:RsvpResponseType "RsvpResponseType is an enumeration type whose instances represent responding to an RSVP request.")
AnnotationAssertion(rdfs:label schema1:RsvpResponseType "RsvpResponseType")
SubClassOf(schema1:RsvpResponseType schema1:Enumeration)

# Class: schema1:SaleEvent (SaleEvent)

AnnotationAssertion(rdfs:comment schema1:SaleEvent "Event type: Sales event.")
AnnotationAssertion(rdfs:label schema1:SaleEvent "SaleEvent")
SubClassOf(schema1:SaleEvent schema1:Event)

# Class: schema1:SatiricalArticle (SatiricalArticle)

AnnotationAssertion(schema1:category schema1:SatiricalArticle "issue-1525")
AnnotationAssertion(schema1:isPartOf schema1:SatiricalArticle <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:SatiricalArticle <https://github.com/schemaorg/schemaorg/issues/1525>)
AnnotationAssertion(schema1:source schema1:SatiricalArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:SatiricalArticle "An <a class=\"localLink\" href=\"http://schema.org/Article\">Article</a> whose content is primarily <a href=\"https://en.wikipedia.org/wiki/Satire\">[satirical]</a> in nature, i.e. unlikely to be literally true. A satirical article is sometimes but not necessarily also a <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a>. <a class=\"localLink\" href=\"http://schema.org/ScholarlyArticle\">ScholarlyArticle</a>s are also sometimes satirized.")
AnnotationAssertion(rdfs:label schema1:SatiricalArticle "SatiricalArticle")
SubClassOf(schema1:SatiricalArticle schema1:Article)

# Class: schema1:Schedule (Schedule)

AnnotationAssertion(schema1:category schema1:Schedule "issue-1457")
AnnotationAssertion(schema1:isPartOf schema1:Schedule <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:Schedule <https://github.com/schemaorg/schemaorg/issues/1457>)
AnnotationAssertion(rdfs:comment schema1:Schedule "A schedule defines a repeating time period used to describe a regularly occurring <a class=\"localLink\" href=\"http://schema.org/Event\">Event</a>. At a minimum a schedule will specify <a class=\"localLink\" href=\"http://schema.org/repeatFrequency\">repeatFrequency</a> which describes the interval between occurences of the event. Additional information can be provided to specify the schedule more precisely.
      This includes identifying the day(s) of the week or month when the recurring event will take place, in addition to its start and end time. Schedules may also
      have start and end dates to indicate when they are active, e.g. to define a limited calendar of events.")
AnnotationAssertion(rdfs:label schema1:Schedule "Schedule")
SubClassOf(schema1:Schedule schema1:Intangible)

# Class: schema1:ScheduleAction (ScheduleAction)

AnnotationAssertion(rdfs:comment schema1:ScheduleAction "Scheduling future actions, events, or tasks.<br/><br/>

Related actions:<br/><br/>

<ul>
<li><a class=\"localLink\" href=\"http://schema.org/ReserveAction\">ReserveAction</a>: Unlike ReserveAction, ScheduleAction allocates future actions (e.g. an event, a task, etc) towards a time slot / spatial allocation.</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:ScheduleAction "ScheduleAction")
SubClassOf(schema1:ScheduleAction schema1:PlanAction)

# Class: schema1:ScholarlyArticle (ScholarlyArticle)

AnnotationAssertion(rdfs:comment schema1:ScholarlyArticle "A scholarly article.")
AnnotationAssertion(rdfs:label schema1:ScholarlyArticle "ScholarlyArticle")
SubClassOf(schema1:ScholarlyArticle schema1:Article)

# Class: schema1:School (School)

AnnotationAssertion(rdfs:comment schema1:School "A school.")
AnnotationAssertion(rdfs:label schema1:School "School")
SubClassOf(schema1:School schema1:EducationalOrganization)

# Class: schema1:SchoolDistrict (SchoolDistrict)

AnnotationAssertion(schema1:category schema1:SchoolDistrict "issue-2500")
AnnotationAssertion(schema1:isPartOf schema1:SchoolDistrict <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:SchoolDistrict <https://github.com/schemaorg/schemaorg/issues/2500>)
AnnotationAssertion(rdfs:comment schema1:SchoolDistrict "A School District is an administrative area for the administration of schools.")
AnnotationAssertion(rdfs:label schema1:SchoolDistrict "SchoolDistrict")
SubClassOf(schema1:SchoolDistrict schema1:AdministrativeArea)

# Class: schema1:ScreeningEvent (ScreeningEvent)

AnnotationAssertion(rdfs:comment schema1:ScreeningEvent "A screening of a movie or other video.")
AnnotationAssertion(rdfs:label schema1:ScreeningEvent "ScreeningEvent")
SubClassOf(schema1:ScreeningEvent schema1:Event)

# Class: schema1:Sculpture (Sculpture)

