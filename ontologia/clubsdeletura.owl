AnnotationAssertion(rdfs:comment schema1:Aquarium "Aquarium.")
AnnotationAssertion(rdfs:label schema1:Aquarium "Aquarium")
SubClassOf(schema1:Aquarium schema1:CivicStructure)

# Class: schema1:ArchiveComponent (ArchiveComponent)

