AnnotationAssertion(rdfs:comment schema1:ProfilePage "Web page type: Profile page.")
AnnotationAssertion(rdfs:label schema1:ProfilePage "ProfilePage")
SubClassOf(schema1:ProfilePage schema1:WebPage)

