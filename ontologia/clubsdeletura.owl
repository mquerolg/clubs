AnnotationAssertion(rdfs:comment schema1:EatAction "The act of swallowing solid objects.")
AnnotationAssertion(rdfs:label schema1:EatAction "EatAction")
SubClassOf(schema1:EatAction schema1:ConsumeAction)

# Class: schema1:EducationEvent (EducationEvent)

AnnotationAssertion(rdfs:comment schema1:EducationEvent "Event type: Education event.")
AnnotationAssertion(rdfs:label schema1:EducationEvent "EducationEvent")
SubClassOf(schema1:EducationEvent schema1:Event)

