AnnotationAssertion(rdfs:comment schema1:HousePainter "A house painting service.")
AnnotationAssertion(rdfs:label schema1:HousePainter "HousePainter")
SubClassOf(schema1:HousePainter schema1:HomeAndConstructionBusiness)

# Class: schema1:HowTo (HowTo)

AnnotationAssertion(rdfs:comment schema1:HowTo "Instructions that explain how to achieve a result by performing a sequence of steps.")
AnnotationAssertion(rdfs:label schema1:HowTo "HowTo")
SubClassOf(schema1:HowTo schema1:CreativeWork)

# Class: schema1:HowToDirection (HowToDirection)

AnnotationAssertion(rdfs:comment schema1:HowToDirection "A direction indicating a single action to do in the instructions for how to achieve a result.")
AnnotationAssertion(rdfs:label schema1:HowToDirection "HowToDirection")
SubClassOf(schema1:HowToDirection schema1:CreativeWork)
SubClassOf(schema1:HowToDirection schema1:ListItem)

# Class: schema1:HowToItem (HowToItem)

AnnotationAssertion(rdfs:comment schema1:HowToItem "An item used as either a tool or supply when performing the instructions for how to to achieve a result.")
AnnotationAssertion(rdfs:label schema1:HowToItem "HowToItem")
SubClassOf(schema1:HowToItem schema1:ListItem)

# Class: schema1:HowToSection (HowToSection)

AnnotationAssertion(rdfs:comment schema1:HowToSection "A sub-grouping of steps in the instructions for how to achieve a result (e.g. steps for making a pie crust within a pie recipe).")
AnnotationAssertion(rdfs:label schema1:HowToSection "HowToSection")
SubClassOf(schema1:HowToSection schema1:CreativeWork)
SubClassOf(schema1:HowToSection schema1:ItemList)
SubClassOf(schema1:HowToSection schema1:ListItem)

# Class: schema1:HowToStep (HowToStep)

AnnotationAssertion(rdfs:comment schema1:HowToStep "A step in the instructions for how to achieve a result. It is an ordered list with HowToDirection and/or HowToTip items.")
AnnotationAssertion(rdfs:label schema1:HowToStep "HowToStep")
SubClassOf(schema1:HowToStep schema1:CreativeWork)
SubClassOf(schema1:HowToStep schema1:ItemList)
SubClassOf(schema1:HowToStep schema1:ListItem)

# Class: schema1:HowToSupply (HowToSupply)

AnnotationAssertion(rdfs:comment schema1:HowToSupply "A supply consumed when performing the instructions for how to achieve a result.")
AnnotationAssertion(rdfs:label schema1:HowToSupply "HowToSupply")
SubClassOf(schema1:HowToSupply schema1:HowToItem)

# Class: schema1:HowToTip (HowToTip)

AnnotationAssertion(rdfs:comment schema1:HowToTip "An explanation in the instructions for how to achieve a result. It provides supplementary information about a technique, supply, author's preference, etc. It can explain what could be done, or what should not be done, but doesn't specify what should be done (see HowToDirection).")
AnnotationAssertion(rdfs:label schema1:HowToTip "HowToTip")
SubClassOf(schema1:HowToTip schema1:CreativeWork)
SubClassOf(schema1:HowToTip schema1:ListItem)

# Class: schema1:HowToTool (HowToTool)

AnnotationAssertion(rdfs:comment schema1:HowToTool "A tool used (but not consumed) when performing instructions for how to achieve a result.")
AnnotationAssertion(rdfs:label schema1:HowToTool "HowToTool")
SubClassOf(schema1:HowToTool schema1:HowToItem)

# Class: schema1:IceCreamShop (IceCreamShop)

