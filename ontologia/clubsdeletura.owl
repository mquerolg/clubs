# Class: schema1:DataFeedItem (DataFeedItem)

AnnotationAssertion(rdfs:comment schema1:DataFeedItem "A single item within a larger data feed.")
AnnotationAssertion(rdfs:label schema1:DataFeedItem "DataFeedItem")
SubClassOf(schema1:DataFeedItem schema1:Intangible)

# Class: schema1:DataType (DataType)

AnnotationAssertion(rdfs:comment schema1:DataType "The basic data types such as Integers, Strings, etc.")
AnnotationAssertion(rdfs:label schema1:DataType "DataType")
SubClassOf(schema1:DataType rdfs:Class)

# Class: schema1:Dataset (Dataset)

AnnotationAssertion(schema1:source schema1:Dataset <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_DatasetClass>)
AnnotationAssertion(rdfs:comment schema1:Dataset "A body of structured information describing some topic(s) of interest.")
AnnotationAssertion(rdfs:label schema1:Dataset "Dataset")
EquivalentClasses(schema1:Dataset dcat:Dataset)
SubClassOf(schema1:Dataset schema1:CreativeWork)

# Class: schema1:Date (Date)

AnnotationAssertion(rdfs:comment schema1:Date "A date value in <a href=\"http://en.wikipedia.org/wiki/ISO_8601\">ISO 8601 date format</a>.")
AnnotationAssertion(rdfs:label schema1:Date "Date")

# Class: schema1:DateTime (DateTime)

AnnotationAssertion(rdfs:comment schema1:DateTime "A combination of date and time of day in the form [-]CCYY-MM-DDThh:mm:ss[Z|(+|-)hh:mm] (see Chapter 5.4 of ISO 8601).")
AnnotationAssertion(rdfs:label schema1:DateTime "DateTime")

# Class: schema1:DatedMoneySpecification (DatedMoneySpecification)

AnnotationAssertion(schema1:supersededBy schema1:DatedMoneySpecification schema1:MonetaryAmount)
AnnotationAssertion(rdfs:comment schema1:DatedMoneySpecification "A DatedMoneySpecification represents monetary values with optional start and end dates. For example, this could represent an employee's salary over a specific period of time. <strong>Note:</strong> This type has been superseded by <a class=\"localLink\" href=\"http://schema.org/MonetaryAmount\">MonetaryAmount</a> use of that type is recommended")
AnnotationAssertion(rdfs:label schema1:DatedMoneySpecification "DatedMoneySpecification")
SubClassOf(schema1:DatedMoneySpecification schema1:StructuredValue)

# Class: schema1:DayOfWeek (DayOfWeek)

AnnotationAssertion(schema1:source schema1:DayOfWeek <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:DayOfWeek "The day of the week, e.g. used to specify to which day the opening hours of an OpeningHoursSpecification refer.<br/><br/>

Originally, URLs from <a href=\"http://purl.org/goodrelations/v1\">GoodRelations</a> were used (for <a class=\"localLink\" href=\"http://schema.org/Monday\">Monday</a>, <a class=\"localLink\" href=\"http://schema.org/Tuesday\">Tuesday</a>, <a class=\"localLink\" href=\"http://schema.org/Wednesday\">Wednesday</a>, <a class=\"localLink\" href=\"http://schema.org/Thursday\">Thursday</a>, <a class=\"localLink\" href=\"http://schema.org/Friday\">Friday</a>, <a class=\"localLink\" href=\"http://schema.org/Saturday\">Saturday</a>, <a class=\"localLink\" href=\"http://schema.org/Sunday\">Sunday</a> plus a special entry for <a class=\"localLink\" href=\"http://schema.org/PublicHolidays\">PublicHolidays</a>); these have now been integrated directly into schema.org.")
AnnotationAssertion(rdfs:label schema1:DayOfWeek "DayOfWeek")
SubClassOf(schema1:DayOfWeek schema1:Enumeration)

# Class: schema1:DaySpa (DaySpa)

AnnotationAssertion(rdfs:comment schema1:DaySpa "A day spa.")
AnnotationAssertion(rdfs:label schema1:DaySpa "DaySpa")
SubClassOf(schema1:DaySpa schema1:HealthAndBeautyBusiness)

# Class: schema1:DeactivateAction (DeactivateAction)

AnnotationAssertion(rdfs:comment schema1:DeactivateAction "The act of stopping or deactivating a device or application (e.g. stopping a timer or turning off a flashlight).")
AnnotationAssertion(rdfs:label schema1:DeactivateAction "DeactivateAction")
SubClassOf(schema1:DeactivateAction schema1:ControlAction)

# Class: schema1:DefenceEstablishment (DefenceEstablishment)

AnnotationAssertion(rdfs:comment schema1:DefenceEstablishment "A defence establishment, such as an army or navy base.")
AnnotationAssertion(rdfs:label schema1:DefenceEstablishment "DefenceEstablishment")
SubClassOf(schema1:DefenceEstablishment schema1:GovernmentBuilding)

# Class: schema1:DefinedRegion (DefinedRegion)

AnnotationAssertion(schema1:category schema1:DefinedRegion "issue-2506")
AnnotationAssertion(schema1:isPartOf schema1:DefinedRegion <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:DefinedRegion <https://github.com/schemaorg/schemaorg/issues/2506>)
AnnotationAssertion(rdfs:comment schema1:DefinedRegion "A DefinedRegion is a geographic area defined by potentially arbitrary (rather than political, administrative or natural geographical) criteria. Properties are provided for defining a region by reference to sets of postal codes.<br/><br/>

Examples: a delivery destination when shopping. Region where regional pricing is configured.<br/><br/>

Requirement 1:
Country: US
States: \"NY\", \"CA\"<br/><br/>

Requirement 2:
Country: US
PostalCode Set: { [94000-94585], [97000, 97999], [13000, 13599]}
{ [12345, 12345], [78945, 78945], }
Region = state, canton, prefecture, autonomous community...")
AnnotationAssertion(rdfs:label schema1:DefinedRegion "DefinedRegion")
SubClassOf(schema1:DefinedRegion schema1:StructuredValue)

# Class: schema1:DefinedTerm (DefinedTerm)

AnnotationAssertion(schema1:category schema1:DefinedTerm "issue-894")
AnnotationAssertion(schema1:isPartOf schema1:DefinedTerm <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:DefinedTerm <https://github.com/schemaorg/schemaorg/issues/894>)
AnnotationAssertion(rdfs:comment schema1:DefinedTerm "A word, name, acronym, phrase, etc. with a formal definition. Often used in the context of category or subject classification, glossaries or dictionaries, product or creative work types, etc. Use the name property for the term being defined, use termCode if the term has an alpha-numeric code allocated, use description to provide the definition of the term.")
AnnotationAssertion(rdfs:label schema1:DefinedTerm "DefinedTerm")
SubClassOf(schema1:DefinedTerm schema1:Intangible)

# Class: schema1:DefinedTermSet (DefinedTermSet)

AnnotationAssertion(schema1:category schema1:DefinedTermSet "issue-894")
AnnotationAssertion(schema1:isPartOf schema1:DefinedTermSet <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:DefinedTermSet <https://github.com/schemaorg/schemaorg/issues/894>)
AnnotationAssertion(rdfs:comment schema1:DefinedTermSet "A set of defined terms for example a set of categories or a classification scheme, a glossary, dictionary or enumeration.")
AnnotationAssertion(rdfs:label schema1:DefinedTermSet "DefinedTermSet")
SubClassOf(schema1:DefinedTermSet schema1:CreativeWork)

# Class: schema1:DeleteAction (DeleteAction)

AnnotationAssertion(rdfs:comment schema1:DeleteAction "The act of editing a recipient by removing one of its objects.")
AnnotationAssertion(rdfs:label schema1:DeleteAction "DeleteAction")
SubClassOf(schema1:DeleteAction schema1:UpdateAction)

# Class: schema1:DeliveryChargeSpecification (DeliveryChargeSpecification)

AnnotationAssertion(schema1:source schema1:DeliveryChargeSpecification <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:DeliveryChargeSpecification "The price for the delivery of an offer using a particular delivery method.")
AnnotationAssertion(rdfs:label schema1:DeliveryChargeSpecification "DeliveryChargeSpecification")
SubClassOf(schema1:DeliveryChargeSpecification schema1:PriceSpecification)

# Class: schema1:DeliveryEvent (DeliveryEvent)

AnnotationAssertion(rdfs:comment schema1:DeliveryEvent "An event involving the delivery of an item.")
AnnotationAssertion(rdfs:label schema1:DeliveryEvent "DeliveryEvent")
SubClassOf(schema1:DeliveryEvent schema1:Event)

# Class: schema1:DeliveryMethod (DeliveryMethod)

AnnotationAssertion(schema1:source schema1:DeliveryMethod <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:DeliveryMethod "A delivery method is a standardized procedure for transferring the product or service to the destination of fulfillment chosen by the customer. Delivery methods are characterized by the means of transportation used, and by the organization or group that is the contracting party for the sending organization or person.<br/><br/>

Commonly used values:<br/><br/>

<ul>
<li>http://purl.org/goodrelations/v1#DeliveryModeDirectDownload</li>
<li>http://purl.org/goodrelations/v1#DeliveryModeFreight</li>
<li>http://purl.org/goodrelations/v1#DeliveryModeMail</li>
<li>http://purl.org/goodrelations/v1#DeliveryModeOwnFleet</li>
<li>http://purl.org/goodrelations/v1#DeliveryModePickUp</li>
<li>http://purl.org/goodrelations/v1#DHL</li>
<li>http://purl.org/goodrelations/v1#FederalExpress</li>
<li>http://purl.org/goodrelations/v1#UPS</li>
</ul>
")
AnnotationAssertion(rdfs:label schema1:DeliveryMethod "DeliveryMethod")
SubClassOf(schema1:DeliveryMethod schema1:Enumeration)

# Class: schema1:DeliveryTimeSettings (DeliveryTimeSettings)

AnnotationAssertion(schema1:category schema1:DeliveryTimeSettings "issue-2506")
AnnotationAssertion(schema1:isPartOf schema1:DeliveryTimeSettings <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:DeliveryTimeSettings <https://github.com/schemaorg/schemaorg/issues/2506>)
AnnotationAssertion(rdfs:comment schema1:DeliveryTimeSettings "A DeliveryTimeSettings represents re-usable pieces of shipping information, relating to timing. It is designed for publication on an URL that may be referenced via the <a class=\"localLink\" href=\"http://schema.org/shippingSettingsLink\">shippingSettingsLink</a> property of a <a class=\"localLink\" href=\"http://schema.org/OfferShippingDetails\">OfferShippingDetails</a>. Several occurrences can be published, distinguished (and identified/referenced) by their different values for <a class=\"localLink\" href=\"http://schema.org/transitTimeLabel\">transitTimeLabel</a>.")
AnnotationAssertion(rdfs:label schema1:DeliveryTimeSettings "DeliveryTimeSettings")
SubClassOf(schema1:DeliveryTimeSettings schema1:StructuredValue)

# Class: schema1:Demand (Demand)

AnnotationAssertion(schema1:source schema1:Demand <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:Demand "A demand entity represents the public, not necessarily binding, not necessarily exclusive, announcement by an organization or person to seek a certain type of goods or services. For describing demand using this type, the very same properties used for Offer apply.")
AnnotationAssertion(rdfs:label schema1:Demand "Demand")
SubClassOf(schema1:Demand schema1:Intangible)

