        <AbbreviatedIRI>schema1:CommentAction</AbbreviatedIRI>
        <Literal>CommentAction</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>schema1:CommentPermission</AbbreviatedIRI>
        <Literal>Permission to add comments to the document.</Literal>
    </AnnotationAssertion>
