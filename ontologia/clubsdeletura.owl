AnnotationAssertion(schema1:isPartOf schema1:ArchiveComponent <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:ArchiveComponent <https://github.com/schemaorg/schemaorg/issues/1758>)
AnnotationAssertion(rdfs:comment schema1:ArchiveComponent "An intangible type to be applied to any archive content, carrying with it a set of properties required to describe archival items and collections.")
AnnotationAssertion(rdfs:label schema1:ArchiveComponent "ArchiveComponent"@en)
SubClassOf(schema1:ArchiveComponent schema1:CreativeWork)

# Class: schema1:ArchiveOrganization (ArchiveOrganization)

