# Class: schema1:WPFooter (WPFooter)

AnnotationAssertion(rdfs:comment schema1:WPFooter "The footer section of the page.")
AnnotationAssertion(rdfs:label schema1:WPFooter "WPFooter")
SubClassOf(schema1:WPFooter schema1:WebPageElement)

# Class: schema1:WPHeader (WPHeader)

