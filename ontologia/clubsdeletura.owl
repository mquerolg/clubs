AnnotationAssertion(rdfs:comment schema1:CssSelectorType "Text representing a CSS selector.")
AnnotationAssertion(rdfs:label schema1:CssSelectorType "CssSelectorType")
SubClassOf(schema1:CssSelectorType schema1:Text)

