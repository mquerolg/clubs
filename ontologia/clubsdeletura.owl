AnnotationAssertion(rdfs:comment schema1:ActionAccessSpecification "A set of requirements that a must be fulfilled in order to perform an Action.")
AnnotationAssertion(rdfs:label schema1:ActionAccessSpecification "ActionAccessSpecification")
SubClassOf(schema1:ActionAccessSpecification schema1:Intangible)

