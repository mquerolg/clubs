AnnotationAssertion(schema1:source schema1:EducationalAudience <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_LRMIClass>)
AnnotationAssertion(rdfs:comment schema1:EducationalAudience "An EducationalAudience.")
AnnotationAssertion(rdfs:label schema1:EducationalAudience "EducationalAudience")
SubClassOf(schema1:EducationalAudience schema1:Audience)

# Class: schema1:EducationalOccupationalCredential (EducationalOccupationalCredential)

AnnotationAssertion(schema1:category schema1:EducationalOccupationalCredential "issue-1779")
AnnotationAssertion(schema1:isPartOf schema1:EducationalOccupationalCredential <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:EducationalOccupationalCredential <https://github.com/schemaorg/schemaorg/issues/1779>)
AnnotationAssertion(rdfs:comment schema1:EducationalOccupationalCredential "An educational or occupational credential. A diploma, academic degree, certification, qualification, badge, etc., that may be awarded to a person or other entity that meets the requirements defined by the credentialer.")
AnnotationAssertion(rdfs:label schema1:EducationalOccupationalCredential "EducationalOccupationalCredential")
SubClassOf(schema1:EducationalOccupationalCredential schema1:CreativeWork)

# Class: schema1:EducationalOccupationalProgram (EducationalOccupationalProgram)

AnnotationAssertion(schema1:category schema1:EducationalOccupationalProgram "issue-2289")
AnnotationAssertion(schema1:isPartOf schema1:EducationalOccupationalProgram <http://pending.schema.org>)
AnnotationAssertion(schema1:source schema1:EducationalOccupationalProgram <https://github.com/schemaorg/schemaorg/issues/2289>)
AnnotationAssertion(rdfs:comment schema1:EducationalOccupationalProgram "A program offered by an institution which determines the learning progress to achieve an outcome, usually a credential like a degree or certificate. This would define a discrete set of opportunities (e.g., job, courses) that together constitute a program with a clear start, end, set of requirements, and transition to a new occupational opportunity (e.g., a job), or sometimes a higher educational opportunity (e.g., an advanced degree).")
AnnotationAssertion(rdfs:label schema1:EducationalOccupationalProgram "EducationalOccupationalProgram")
SubClassOf(schema1:EducationalOccupationalProgram schema1:Intangible)

