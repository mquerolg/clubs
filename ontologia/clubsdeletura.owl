# Class: schema1:PriceSpecification (PriceSpecification)

AnnotationAssertion(schema1:source schema1:PriceSpecification <http://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#source_GoodRelationsClass>)
AnnotationAssertion(rdfs:comment schema1:PriceSpecification "A structured value representing a price or price range. Typically, only the subclasses of this type are used for markup. It is recommended to use <a class=\"localLink\" href=\"http://schema.org/MonetaryAmount\">MonetaryAmount</a> to describe independent amounts of money such as a salary, credit card limits, etc.")
AnnotationAssertion(rdfs:label schema1:PriceSpecification "PriceSpecification")
SubClassOf(schema1:PriceSpecification schema1:StructuredValue)

