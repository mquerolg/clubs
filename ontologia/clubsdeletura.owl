AnnotationAssertion(schema1:source schema1:AskPublicNewsArticle <https://www.w3.org/wiki/WebSchemas/SchemaDotOrgSources#TP>)
AnnotationAssertion(rdfs:comment schema1:AskPublicNewsArticle "A <a class=\"localLink\" href=\"http://schema.org/NewsArticle\">NewsArticle</a> expressing an open call by a <a class=\"localLink\" href=\"http://schema.org/NewsMediaOrganization\">NewsMediaOrganization</a> asking the public for input, insights, clarifications, anecdotes, documentation, etc., on an issue, for reporting purposes.")
AnnotationAssertion(rdfs:label schema1:AskPublicNewsArticle "AskPublicNewsArticle")
SubClassOf(schema1:AskPublicNewsArticle schema1:NewsArticle)

